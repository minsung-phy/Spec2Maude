  op $ND :  -> WasmTerminal .


  op bit :  -> WasmType .
  ceq typecheck(i, bit(N_BIT)) = true 
   if typecheck(N_BIT, N) /\ ((i == 0) \/ (i == 1)) .
  op byte :  -> WasmType .
  ceq typecheck(i, byte(N_BYTE)) = true 
   if typecheck(N_BYTE, N) /\ ((i >= 0) /\ (i <= 255)) .
  op uN : WasmTerminal -> WasmType .
  var N_UN : Nat .
  ceq typecheck(i, uN(N_UN)) = true 
   if typecheck(N_UN, N) /\ ((i >= 0) /\ (i <= ((2 ^ N_UN) - 1))) .
  op sN : WasmTerminal -> WasmType .
  var N_SN : Nat .
  ceq typecheck(i, sN(N_SN)) = true 
   if typecheck(N_SN, N) /\ ((((i >= -((2 ^ (N_SN - 1)))) /\ (i <= -(1))) \/ (i == 0)) \/ ((i >= +(1)) /\ (i <= (+((2 ^ (N_SN - 1))) - 1)))) .
