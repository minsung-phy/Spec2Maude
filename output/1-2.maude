  var X : WasmTerminal .
  var _ : WasmTerminal .
  eq setminus1_(UNKNOWN) = 0 .
  eq setminus1_(UNKNOWN) = 0 .
  eq setminus1_(UNKNOWN) = setminus1_(X, w, 0) .


