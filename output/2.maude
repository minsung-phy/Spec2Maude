  op fNmag : WasmTerminal -> WasmType [ctor] .
  var N_FNMAG : Nat . 
  ceq typecheck(i, fNmag(N)) = true 
   if typecheck(N, N) /\ ((M < (2 ^ $M(N))) /\ (((2 - (2 ^ ($E(N) - 1))) <= EXP) /\ (EXP <= ((2 ^ ($E(N) - 1)) - 1)))) .
  var N_FNMAG : Nat . 
  ceq typecheck(i, fNmag(N)) = true 
   if typecheck(N, N) /\ ((M < (2 ^ $M(N))) /\ ((2 - (2 ^ ($E(N) - 1))) == EXP)) .
  op INF :  -> WasmTerminal [ctor] .
  eq typecheck(INF, fNmag(N)) = typecheck(N, N) .
  var N_FNMAG : Nat . 
  ceq typecheck(i, fNmag(N)) = true 
   if typecheck(N, N) /\ ((1 <= M) /\ (M < (2 ^ $M(N)))) .
