  op $is_packtype : WasmTerminal -> WasmTerminal .
  var STORAGETYPE : WasmTerminal .
  var ZT : WasmTerminal .
  eq $is_packtype(ZT) = (ZT == $unpack(ZT)) .



  op nonfuncs :  -> WasmType [ctor] .

  var GLOBAL* : WasmTerminals .
  var MEM* : WasmTerminals .
  var TABLE* : WasmTerminals .
  var ELEM* : WasmTerminals .
  eq typecheck(GLOBAL* MEM* TABLE* ELEM*, nonfuncs) = typecheck(GLOBAL*, global) /\ typecheck(MEM*, mem) /\ typecheck(TABLE*, table) /\ typecheck(ELEM*, elem) .

  op $funcidx_nonfuncs : WasmTerminal -> WasmTerminal .
  var NONFUNCS : WasmTerminal .
  eq funcidx_nonfuncs(UNKNOWN_CASE) = $funcidx-module(MODULE) .


