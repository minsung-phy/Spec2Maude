  op $before : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .
  var TYPEUSE : WasmTerminal .
  var TYPEIDX : WasmTerminal .
  var NAT : WasmTerminal .
  eq before(DEFTYPE) = 0 .
  eq before(_IDX) = (0 < 0) .
  eq before(REC) = (J < I) .


