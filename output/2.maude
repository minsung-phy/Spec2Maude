  var DATAMODE : WasmTerminal .
  eq free_datamode(ACTIVE) = 0 .
  eq free_datamode(PASSIVE) = 0 .


  op $free_data : WasmTerminal -> WasmTerminal .
  var DATA : WasmTerminal .
