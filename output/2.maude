  eq free_elemmode(DECLARE) = 0 .


  op $free_elem : WasmTerminal -> WasmTerminal .
  var ELEM : WasmTerminal .
  eq free_elem(ELEM) = 0 .


  op $free_start : WasmTerminal -> WasmTerminal .
  var START : WasmTerminal .
