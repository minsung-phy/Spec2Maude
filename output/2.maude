  eq free_instr(TABLE.FILL) = $free-tableidx(TABLEIDX) .
  eq free_instr(TABLE.COPY) = 0 .
  eq free_instr(TABLE.INIT) = 0 .
  eq free_instr(ELEM.DROP) = $free-elemidx(ELEMIDX) .
  eq free_instr(LOAD) = 0 .
  eq free_instr(STORE) = 0 .
  eq free_instr(VLOAD) = 0 .
  eq free_instr(VLOAD_LANE) = 0 .
  eq free_instr(VSTORE) = 0 .
  eq free_instr(VSTORE_LANE) = 0 .
  eq free_instr(MEMORY.SIZE) = $free-memidx(MEMIDX) .
  eq free_instr(MEMORY.GROW) = $free-memidx(MEMIDX) .
  eq free_instr(MEMORY.FILL) = $free-memidx(MEMIDX) .
  eq free_instr(MEMORY.COPY) = 0 .
  eq free_instr(MEMORY.INIT) = 0 .
  eq free_instr(DATA.DROP) = $free-dataidx(DATAIDX) .


  op $free_block : WasmTerminal -> WasmTerminal .
  var _ : WasmTerminal .
  eq free_block(0) = 0 .


  op $free_expr : WasmTerminal -> WasmTerminal .
  var EXPR : WasmTerminal .
  eq free_expr(0) = $free-list(0) .

  op elemmode :  -> WasmType [ctor] .
  op ACTIVE _ _ : WasmTerminal WasmTerminals -> WasmTerminal [ctor] .
  var TABLEIDX1 : WasmTerminal .
  var EXPR1 : WasmTerminals .
  eq typecheck(ACTIVE TABLEIDX1 EXPR1, elemmode) = typecheck(TABLEIDX1, tableidx) /\ typecheck(EXPR1, expr) .
  op PASSIVE :  -> WasmTerminal [ctor] .
  eq typecheck(PASSIVE, elemmode) = true .
  op DECLARE :  -> WasmTerminal [ctor] .
  eq typecheck(DECLARE, elemmode) = true .
  op datamode :  -> WasmType [ctor] .
  op ACTIVE _ _ : WasmTerminal WasmTerminals -> WasmTerminal [ctor] .
  var MEMIDX1 : WasmTerminal .
  var EXPR1 : WasmTerminals .
  eq typecheck(ACTIVE MEMIDX1 EXPR1, datamode) = typecheck(MEMIDX1, memidx) /\ typecheck(EXPR1, expr) .
  op PASSIVE :  -> WasmTerminal [ctor] .
  eq typecheck(PASSIVE, datamode) = true .
  op type :  -> WasmType [ctor] .
  op TYPE _ : WasmTerminal -> WasmTerminal [ctor] .
  var RECTYPE1 : WasmTerminal .
  eq typecheck(TYPE RECTYPE1, type) = typecheck(RECTYPE1, rectype) .
  op tag :  -> WasmType [ctor] .
  op TAG _ : WasmTerminal -> WasmTerminal [ctor] .
  var TAGTYPE1 : WasmTerminal .
  eq typecheck(TAG TAGTYPE1, tag) = typecheck(TAGTYPE1, tagtype) .
  op global :  -> WasmType [ctor] .
  op GLOBAL _ _ : WasmTerminal WasmTerminals -> WasmTerminal [ctor] .
  var GLOBALTYPE1 : WasmTerminal .
  var EXPR1 : WasmTerminals .
  eq typecheck(GLOBAL GLOBALTYPE1 EXPR1, global) = typecheck(GLOBALTYPE1, globaltype) /\ typecheck(EXPR1, expr) .
  op mem :  -> WasmType [ctor] .
  op MEMORY _ : WasmTerminal -> WasmTerminal [ctor] .
  var MEMTYPE1 : WasmTerminal .
  eq typecheck(MEMORY MEMTYPE1, mem) = typecheck(MEMTYPE1, memtype) .
  op table :  -> WasmType [ctor] .
  op TABLE _ _ : WasmTerminal WasmTerminals -> WasmTerminal [ctor] .
  var TABLETYPE1 : WasmTerminal .
  var EXPR1 : WasmTerminals .
  eq typecheck(TABLE TABLETYPE1 EXPR1, table) = typecheck(TABLETYPE1, tabletype) /\ typecheck(EXPR1, expr) .
  op data :  -> WasmType [ctor] .
  op DATA _ _ : WasmTerminals WasmTerminal -> WasmTerminal [ctor] .
  var BYTE* : WasmTerminals .
  var DATAMODE1 : WasmTerminal .
  eq typecheck(DATA BYTE* DATAMODE1, data) = typecheck(BYTE*, byte) /\ typecheck(DATAMODE1, datamode) .
  op local :  -> WasmType [ctor] .
  op LOCAL _ : WasmTerminal -> WasmTerminal [ctor] .
  var VALTYPE1 : WasmTerminal .
  eq typecheck(LOCAL VALTYPE1, local) = typecheck(VALTYPE1, valtype) .
  op func :  -> WasmType [ctor] .
  op FUNC _ _ _ : WasmTerminal WasmTerminals WasmTerminals -> WasmTerminal [ctor] .
  var TYPEIDX1 : WasmTerminal .
  var LOCAL* : WasmTerminals .
  var EXPR1 : WasmTerminals .
  eq typecheck(FUNC TYPEIDX1 LOCAL* EXPR1, func) = typecheck(TYPEIDX1, typeidx) /\ typecheck(LOCAL*, local) /\ typecheck(EXPR1, expr) .
  op elem :  -> WasmType [ctor] .
  op ELEM _ _ _ : WasmTerminal WasmTerminals WasmTerminal -> WasmTerminal [ctor] .
  var REFTYPE1 : WasmTerminal .
  var EXPR* : WasmTerminals .
  var ELEMMODE1 : WasmTerminal .
  eq typecheck(ELEM REFTYPE1 EXPR* ELEMMODE1, elem) = typecheck(REFTYPE1, reftype) /\ typecheck(EXPR*, expr) /\ typecheck(ELEMMODE1, elemmode) .
  op start :  -> WasmType [ctor] .
  op START _ : WasmTerminal -> WasmTerminal [ctor] .
  var FUNCIDX1 : WasmTerminal .
  eq typecheck(START FUNCIDX1, start) = typecheck(FUNCIDX1, funcidx) .
  op import :  -> WasmType [ctor] .
  op IMPORT _ _ _ : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  var NAME1 : WasmTerminal .
  var NAME2 : WasmTerminal .
  var EXTERNTYPE1 : WasmTerminal .
  eq typecheck(IMPORT NAME1 NAME2 EXTERNTYPE1, import) = typecheck(NAME1, name) /\ typecheck(NAME2, name) /\ typecheck(EXTERNTYPE1, externtype) .
  op export :  -> WasmType [ctor] .
  op EXPORT _ _ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  var NAME1 : WasmTerminal .
  var EXTERNIDX1 : WasmTerminal .
  eq typecheck(EXPORT NAME1 EXTERNIDX1, export) = typecheck(NAME1, name) /\ typecheck(EXTERNIDX1, externidx) .
  op module :  -> WasmType [ctor] .
  op MODULE _ _ _ _ _ _ _ _ _ _ _ : WasmTerminals WasmTerminals WasmTerminals WasmTerminals WasmTerminals WasmTerminals WasmTerminals WasmTerminals WasmTerminals WasmTerminal WasmTerminals -> WasmTerminal [ctor] .
  var TYPE* : WasmTerminals .
  var IMPORT* : WasmTerminals .
  var TAG* : WasmTerminals .
  var GLOBAL* : WasmTerminals .
  var MEM* : WasmTerminals .
  var TABLE* : WasmTerminals .
  var FUNC* : WasmTerminals .
  var DATA* : WasmTerminals .
  var ELEM* : WasmTerminals .
  var START1 : WasmTerminal .
  var EXPORT* : WasmTerminals .
  eq typecheck(MODULE TYPE* IMPORT* TAG* GLOBAL* MEM* TABLE* FUNC* DATA* ELEM* START1 EXPORT*, module) = typecheck(TYPE*, type) /\ typecheck(IMPORT*, import) /\ typecheck(TAG*, tag) /\ typecheck(GLOBAL*, global) /\ typecheck(MEM*, mem) /\ typecheck(TABLE*, table) /\ typecheck(FUNC*, func) /\ typecheck(DATA*, data) /\ typecheck(ELEM*, elem) /\ typecheck(START1, start) /\ typecheck(EXPORT*, export) .

  op $free_type : WasmTerminal -> WasmTerminal .
  var TYPE : WasmTerminal .
