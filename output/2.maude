  op $funcidx_module : WasmTerminal -> WasmTerminal .
  var MODULE : WasmTerminal .
  var MODULE : WasmTerminal .
  eq $funcidx_module(MODULE) = 0 .


  op $dataidx_funcs : WasmTerminal -> WasmTerminal .
  var _ : WasmTerminal .
  eq dataidx_funcs(0) = 0 .

  op init :  -> WasmType [ctor] .
  op SET :  -> WasmTerminal [ctor] .
  eq typecheck(SET, init) = true .
  op UNSET :  -> WasmTerminal [ctor] .
  eq typecheck(UNSET, init) = true .
  op localtype :  -> WasmType [ctor] .

  var INIT1 : WasmTerminal .
  var VALTYPE1 : WasmTerminal .
  eq typecheck(INIT1 VALTYPE1, localtype) = typecheck(INIT1, init) /\ typecheck(VALTYPE1, valtype) .
  op instrtype :  -> WasmType [ctor] .
  op arrow- _ _ _ : WasmTerminals WasmTerminals WasmTerminals -> WasmTerminal [ctor] .
  var RESULTTYPE1 : WasmTerminals .
  var LOCALIDX* : WasmTerminals .
  var RESULTTYPE2 : WasmTerminals .
  eq typecheck(arrow- RESULTTYPE1 LOCALIDX* RESULTTYPE2, instrtype) = typecheck(RESULTTYPE1, resulttype) /\ typecheck(LOCALIDX*, localidx) /\ typecheck(RESULTTYPE2, resulttype) .
  op context :  -> WasmType [ctor] .


  op $with_locals : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .
  var CONTEXT : WasmTerminal .
  var _ : WasmTerminal .
  var _ : WasmTerminal .
  var C : WasmTerminal .
  eq $with_locals(C) = C .
  var C : WasmTerminal .
  eq $with_locals(C) = $with-locals(0, 0, 0) .


  op $clos_deftypes : WasmTerminal -> WasmTerminal .
  var _ : WasmTerminal .
