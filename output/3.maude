load 2 

mod 3_1_NUMERICS_SCALAR is
  inc DSL-TERM .
  inc DSL-PRETYPE .
  inc DSL-EXEC .

  inc 2_0_VALIDATION .

  subsort Int < WasmTerminal .
  subsort Nat < WasmTerminal .

  op nat : -> WasmType [ctor] . 
  var I : Int .
  var T : WasmTerminal .

  op N :  -> WasmType [ctor] .
  eq typecheck(T, N) =  typecheck(T, WasmType) .
  op M :  -> WasmType [ctor] .
  eq typecheck(T, M) =  typecheck(T, WasmType) .
  op K :  -> WasmType [ctor] .
  eq typecheck(T, K) =  typecheck(T, WasmType) .
  op n :  -> WasmType [ctor] .
  eq typecheck(T, n) =  typecheck(T, WasmType) .
  op m :  -> WasmType [ctor] .
  eq typecheck(T, m) =  typecheck(T, WasmType) .

  op $min : WasmTerminal WasmTerminal -> WasmTerminal .

  vars MIN_I MIN_J : WasmTerminal .
  eq $min(MIN_I, MIN_J) = MIN_I .

  vars MIN_I MIN_J : WasmTerminal .
  eq $min(MIN_I, MIN_J) = MIN_J .


  op $sum : WasmTerminal -> WasmTerminal .
  eq $sum() = 0 .

  var SUM_N : WasmTerminal .
  var SUM_N'* : WasmTerminal .
  ceq $sum(UNKNOWN_EXP) = (SUM_N + $sum(UNKNOWN_EXP)) 
      if typecheck(SUM_N, SUM_N) /\ typecheck(SUM_N'*, SUM_N) .


  op $prod : WasmTerminal -> WasmTerminal .
  eq $prod() = 1 .

  var PROD_N : WasmTerminal .
  var PROD_N'* : WasmTerminal .
  ceq $prod(UNKNOWN_EXP) = (PROD_N * $prod(UNKNOWN_EXP)) 
      if typecheck(PROD_N, PROD_N) /\ typecheck(PROD_N'*, PROD_N) .


  op $opt- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $opt-(UNKNOWN, ) = UNKNOWN_EXP .

  var OPT_W : WasmTerminal .
  ceq $opt-(UNKNOWN, OPT_W) = UNKNOWN_EXP 
      if typecheck(OPT_W, X) .


  op $concat- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $concat-(UNKNOWN, ) =  .

  vars CONCAT_W* CONCAT_W'** : WasmTerminal .
  ceq $concat-(UNKNOWN, UNKNOWN_EXP) = UNKNOWN_EXP 
      if typecheck(CONCAT_W*, X) /\ typecheck(CONCAT_W'**, X) .


  op $concatn- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var CONCATN_N : WasmTerminal .
  ceq $concatn-(UNKNOWN, , CONCATN_N) =  
      if typecheck(CONCATN_N, CONCATN_N) .

  var CONCATN_N : WasmTerminal .
  vars CONCATN_W* CONCATN_W'** : WasmTerminal .
  ceq $concatn-(UNKNOWN, UNKNOWN_EXP, CONCATN_N) = UNKNOWN_EXP 
      if typecheck(CONCATN_W*, X) /\ typecheck(CONCATN_N, CONCATN_N) /\ typecheck(CONCATN_W'**, X) .


  op $concatopt- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $concatopt-(UNKNOWN, ) =  .

  vars CONCATOPT_W? CONCATOPT_W'?* : WasmTerminal .
  ceq $concatopt-(UNKNOWN, UNKNOWN_EXP) = UNKNOWN_EXP 
      if typecheck(CONCATOPT_W?, X) /\ typecheck(CONCATOPT_W'?*, X) .


  op $inv-concat- : WasmTerminal WasmTerminal -> WasmTerminals .



  op $inv-concatn- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .



  op $disjoint- : WasmTerminal WasmTerminal -> WasmTerminal .
  eq $disjoint-(UNKNOWN, ) = UNKNOWN_EXP .

  vars DISJOINT_W DISJOINT_W'* : WasmTerminal .
  ceq $disjoint-(UNKNOWN, UNKNOWN_EXP) = (not (UNKNOWN_EXP) /\ $disjoint-(X, UNKNOWN_EXP)) 
      if typecheck(DISJOINT_W, X) /\ typecheck(DISJOINT_W'*, X) .


  op $setminus1- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var SETMINUS1_W : WasmTerminal .
  ceq $setminus1-(UNKNOWN, SETMINUS1_W, ) = SETMINUS1_W 
      if typecheck(SETMINUS1_W, X) .

  vars SETMINUS1_W SETMINUS1_W1 SETMINUS1_W'* : WasmTerminal .
  ceq $setminus1-(UNKNOWN, SETMINUS1_W, UNKNOWN_EXP) =  
      if typecheck(SETMINUS1_W, X) /\ typecheck(SETMINUS1_W1, X) /\ typecheck(SETMINUS1_W'*, X) .

  vars SETMINUS1_W SETMINUS1_W1 SETMINUS1_W'* : WasmTerminal .
  ceq $setminus1-(UNKNOWN, SETMINUS1_W, UNKNOWN_EXP) = $setminus1-(X, SETMINUS1_W, UNKNOWN_EXP) 
      if typecheck(SETMINUS1_W, X) /\ typecheck(SETMINUS1_W1, X) /\ typecheck(SETMINUS1_W'*, X) .


  op $setminus- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var SETMINUS_W* : WasmTerminal .
  ceq $setminus-(UNKNOWN, , UNKNOWN_EXP) =  
      if typecheck(SETMINUS_W*, X) .

  vars SETMINUS_W1 SETMINUS_W'* SETMINUS_W* : WasmTerminal .
  ceq $setminus-(UNKNOWN, UNKNOWN_EXP, UNKNOWN_EXP) = UNKNOWN_EXP 
      if typecheck(SETMINUS_W1, X) /\ typecheck(SETMINUS_W'*, X) /\ typecheck(SETMINUS_W*, X) .


  op $setproduct2- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var SETPRODUCT2_W1 : WasmTerminal .
  ceq $setproduct2-(UNKNOWN, SETPRODUCT2_W1, ) =  
      if typecheck(SETPRODUCT2_W1, X) .

  vars SETPRODUCT2_W1 SETPRODUCT2_W'* SETPRODUCT2_W** : WasmTerminal .
  ceq $setproduct2-(UNKNOWN, SETPRODUCT2_W1, UNKNOWN_EXP) = UNKNOWN_EXP 
      if typecheck(SETPRODUCT2_W1, X) /\ typecheck(SETPRODUCT2_W'*, X) /\ typecheck(SETPRODUCT2_W**, X) .


  op $setproduct1- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var SETPRODUCT1_W** : WasmTerminal .
  ceq $setproduct1-(UNKNOWN, , UNKNOWN_EXP) =  
      if typecheck(SETPRODUCT1_W**, X) .

  vars SETPRODUCT1_W1 SETPRODUCT1_W'* SETPRODUCT1_W** : WasmTerminal .
  ceq $setproduct1-(UNKNOWN, UNKNOWN_EXP, UNKNOWN_EXP) = UNKNOWN_EXP 
      if typecheck(SETPRODUCT1_W1, X) /\ typecheck(SETPRODUCT1_W'*, X) /\ typecheck(SETPRODUCT1_W**, X) .


  op $setproduct- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $setproduct-(UNKNOWN, ) =  .

  vars SETPRODUCT_W1* SETPRODUCT_W** : WasmTerminal .
  ceq $setproduct-(UNKNOWN, UNKNOWN_EXP) = $setproduct1-(X, UNKNOWN_EXP, $setproduct-(X, UNKNOWN_EXP)) 
      if typecheck(SETPRODUCT_W1*, X) /\ typecheck(SETPRODUCT_W**, X) .


  op $ND :  -> WasmTerminal .


  op bit :  -> WasmType [ctor] .
 
  ceq typecheck(i, bit) = true 
   if ((I == 0) \/ (I == 1)) .
  op byte :  -> WasmType [ctor] .
 
  ceq typecheck(i, byte) = true 
   if ((I >= 0) /\ (I <= 255)) .
  op uN : WasmTerminal -> WasmType [ctor] .
  var N_UN : Nat . 
  ceq typecheck(i, uN(N)) = true 
   if typecheck(N, N) /\ ((I >= 0) /\ (I <= ((2 ^ N) - 1))) .
  op sN : WasmTerminal -> WasmType [ctor] .
  var N_SN : Nat . 
  ceq typecheck(i, sN(N)) = true 
   if typecheck(N, N) /\ ((((I >= - (2 ^ (N - 1))) /\ (I <= - 1)) \/ (I == 0)) \/ ((I >= +(1)) /\ (I <= (+((2 ^ (N - 1))) - 1)))) .
  op iN : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, iN(N)) = typecheck(N, N) /\  typecheck(T, uN(N)) .
  op u8 :  -> WasmType [ctor] .
  eq typecheck(T, u8) =  typecheck(T, uN(8)) .
  op u16 :  -> WasmType [ctor] .
  eq typecheck(T, u16) =  typecheck(T, uN(16)) .
  op u31 :  -> WasmType [ctor] .
  eq typecheck(T, u31) =  typecheck(T, uN(31)) .
  op u32 :  -> WasmType [ctor] .
  eq typecheck(T, u32) =  typecheck(T, uN(32)) .
  op u64 :  -> WasmType [ctor] .
  eq typecheck(T, u64) =  typecheck(T, uN(64)) .
  op s33 :  -> WasmType [ctor] .
  eq typecheck(T, s33) =  typecheck(T, sN(33)) .
  op i32 :  -> WasmType [ctor] .
  eq typecheck(T, i32) =  typecheck(T, iN(32)) .
  op i64 :  -> WasmType [ctor] .
  eq typecheck(T, i64) =  typecheck(T, iN(64)) .
  op i128 :  -> WasmType [ctor] .
  eq typecheck(T, i128) =  typecheck(T, iN(128)) .

  op $signif : WasmTerminal -> WasmTerminal .
  eq $signif(32) = 23 .
  eq $signif(64) = 52 .


  op $expon : WasmTerminal -> WasmTerminal .
  eq $expon(32) = 8 .
  eq $expon(64) = 11 .


  op $M : WasmTerminal -> WasmTerminal .

  var M_N : WasmTerminal .
  ceq $M(M_N) = $signif(M_N) 
      if typecheck(M_N, N) .


  op $E : WasmTerminal -> WasmTerminal .

  var E_N : WasmTerminal .
  ceq $E(E_N) = $expon(E_N) 
      if typecheck(E_N, N) .

  op exp :  -> WasmType [ctor] .
  eq typecheck(T, exp) =  typecheck(T, WasmType) .
  op fNmag : WasmTerminal -> WasmType [ctor] .
  var N_FNMAG : Nat . 
  ceq typecheck(i, fNmag(N)) = true 
   if typecheck(N, N) /\ ((M < (2 ^ $M(N))) /\ (((2 - (2 ^ ($E(N) - 1))) <= EXP) /\ (EXP <= ((2 ^ ($E(N) - 1)) - 1)))) .
  var N_FNMAG : Nat . 
  ceq typecheck(i, fNmag(N)) = true 
   if typecheck(N, N) /\ ((M < (2 ^ $M(N))) /\ ((2 - (2 ^ ($E(N) - 1))) == EXP)) .
  op INF :  -> WasmTerminal [ctor] .
  eq typecheck(INF, fNmag(N)) = typecheck(N, N) .
  var N_FNMAG : Nat . 
  ceq typecheck(i, fNmag(N)) = true 
   if typecheck(N, N) /\ ((1 <= M) /\ (M < (2 ^ $M(N)))) .
  op fN : WasmTerminal -> WasmType [ctor] .
  op POS _ : WasmTerminal -> WasmTerminal [ctor] .
  var FNMAG1 : WasmTerminal .
  eq typecheck(POS FNMAG1, fN(N)) = typecheck(N, N) /\ typecheck(FNMAG1, fNmag(N)) .
  op NEG _ : WasmTerminal -> WasmTerminal [ctor] .
  var FNMAG1 : WasmTerminal .
  eq typecheck(NEG FNMAG1, fN(N)) = typecheck(N, N) /\ typecheck(FNMAG1, fNmag(N)) .
  op f32 :  -> WasmType [ctor] .
  eq typecheck(T, f32) =  typecheck(T, fN(32)) .
  op f64 :  -> WasmType [ctor] .
  eq typecheck(T, f64) =  typecheck(T, fN(64)) .

  op $fzero : WasmTerminal -> WasmTerminal .

  var FZERO_N : WasmTerminal .
  ceq $fzero(FZERO_N) = POS 
      if typecheck(FZERO_N, N) .


  op $fnat : WasmTerminal WasmTerminal -> WasmTerminal .

  vars FNAT_N FNAT_N : WasmTerminal .
  ceq $fnat(FNAT_N, FNAT_N) = POS 
      if typecheck(FNAT_N, N) /\ typecheck(FNAT_N, FNAT_N) .


  op $fone : WasmTerminal -> WasmTerminal .

  var FONE_N : WasmTerminal .
  ceq $fone(FONE_N) = POS 
      if typecheck(FONE_N, N) .


  op $canon- : WasmTerminal -> WasmTerminal .

  var CANON_N : WasmTerminal .
  ceq $canon-(CANON_N) = (2 ^ ($signif(CANON_N) - 1)) 
      if typecheck(CANON_N, N) .

  op vN : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, vN(N)) = typecheck(N, N) /\  typecheck(T, uN(N)) .
  op v128 :  -> WasmType [ctor] .
  eq typecheck(T, v128) =  typecheck(T, vN(128)) .
  op list : WasmTerminal -> WasmType [ctor] .
  var N_LIST : Nat . 
  ceq typecheck(i, list(X)) = true 
   if (UNKNOWN_EXP < (2 ^ 32)) .
  op char :  -> WasmType [ctor] .
 
  ceq typecheck(i, char) = true 
   if (((I >= 0) /\ (I <= 55295)) \/ ((I >= 57344) /\ (I <= 1114111))) .

  op $utf8 : WasmTerminal -> WasmTerminals .


  op name :  -> WasmType [ctor] .
 
  ceq typecheck(i, name) = true 
   if (UNKNOWN_EXP < (2 ^ 32)) .
  op idx :  -> WasmType [ctor] .
  eq typecheck(T, idx) =  typecheck(T, u32) .
  op laneidx :  -> WasmType [ctor] .
  eq typecheck(T, laneidx) =  typecheck(T, u8) .
  op typeidx :  -> WasmType [ctor] .
  eq typecheck(T, typeidx) =  typecheck(T, idx) .
  op funcidx :  -> WasmType [ctor] .
  eq typecheck(T, funcidx) =  typecheck(T, idx) .
  op globalidx :  -> WasmType [ctor] .
  eq typecheck(T, globalidx) =  typecheck(T, idx) .
  op tableidx :  -> WasmType [ctor] .
  eq typecheck(T, tableidx) =  typecheck(T, idx) .
  op memidx :  -> WasmType [ctor] .
  eq typecheck(T, memidx) =  typecheck(T, idx) .
  op tagidx :  -> WasmType [ctor] .
  eq typecheck(T, tagidx) =  typecheck(T, idx) .
  op elemidx :  -> WasmType [ctor] .
  eq typecheck(T, elemidx) =  typecheck(T, idx) .
  op dataidx :  -> WasmType [ctor] .
  eq typecheck(T, dataidx) =  typecheck(T, idx) .
  op labelidx :  -> WasmType [ctor] .
  eq typecheck(T, labelidx) =  typecheck(T, idx) .
  op localidx :  -> WasmType [ctor] .
  eq typecheck(T, localidx) =  typecheck(T, idx) .
  op fieldidx :  -> WasmType [ctor] .
  eq typecheck(T, fieldidx) =  typecheck(T, idx) .
  op externidx :  -> WasmType [ctor] .
  op FUNC _ : WasmTerminal -> WasmTerminal [ctor] .
  var FUNCIDX1 : WasmTerminal .
  eq typecheck(FUNC FUNCIDX1, externidx) = typecheck(FUNCIDX1, funcidx) .
  op GLOBAL _ : WasmTerminal -> WasmTerminal [ctor] .
  var GLOBALIDX1 : WasmTerminal .
  eq typecheck(GLOBAL GLOBALIDX1, externidx) = typecheck(GLOBALIDX1, globalidx) .
  op TABLE _ : WasmTerminal -> WasmTerminal [ctor] .
  var TABLEIDX1 : WasmTerminal .
  eq typecheck(TABLE TABLEIDX1, externidx) = typecheck(TABLEIDX1, tableidx) .
  op MEM _ : WasmTerminal -> WasmTerminal [ctor] .
  var MEMIDX1 : WasmTerminal .
  eq typecheck(MEM MEMIDX1, externidx) = typecheck(MEMIDX1, memidx) .
  op TAG _ : WasmTerminal -> WasmTerminal [ctor] .
  var TAGIDX1 : WasmTerminal .
  eq typecheck(TAG TAGIDX1, externidx) = typecheck(TAGIDX1, tagidx) .

  op $funcsxx : WasmTerminal -> WasmTerminals .
  eq $funcsxx() =  .

  vars FUNCSXX_X FUNCSXX_XX* : WasmTerminal .
  ceq $funcsxx(UNKNOWN_EXP) = UNKNOWN_EXP 
      if typecheck(FUNCSXX_X, idx) /\ typecheck(FUNCSXX_XX*, externidx) .

  vars FUNCSXX_EXTERNIDX FUNCSXX_XX* : WasmTerminal .
  ceq $funcsxx(UNKNOWN_EXP) = $funcsxx(UNKNOWN_EXP) 
      if typecheck(FUNCSXX_EXTERNIDX, FUNCSXX_EXTERNIDX) /\ typecheck(FUNCSXX_XX*, FUNCSXX_EXTERNIDX) .


  op $globalsxx : WasmTerminal -> WasmTerminals .
