  op $tagsxx : WasmTerminal -> WasmTerminals .
  eq $tagsxx() =  .

  vars TAGSXX_X TAGSXX_XX* : WasmTerminal .
  ceq $tagsxx(UNKNOWN_EXP) = UNKNOWN_EXP 
