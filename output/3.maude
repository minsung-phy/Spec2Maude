  op $free-externidx : WasmTerminal -> WasmTerminal .

  var FREE_FUNCIDX : WasmTerminal .
  ceq $free-externidx(FUNC) = $free-funcidx(FREE_FUNCIDX) 
      if typecheck(FREE_FUNCIDX, FREE_FUNCIDX) .

  var FREE_GLOBALIDX : WasmTerminal .
  ceq $free-externidx(GLOBAL) = $free-globalidx(FREE_GLOBALIDX) 
      if typecheck(FREE_GLOBALIDX, FREE_GLOBALIDX) .

  var FREE_TABLEIDX : WasmTerminal .
  ceq $free-externidx(TABLE) = $free-tableidx(FREE_TABLEIDX) 
