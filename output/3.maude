      if typecheck(VEXTBINOP_JNN1, Jnn-1) /\ typecheck(VEXTBINOP_M1, M-1) /\ typecheck(VEXTBINOP_JNN2, Jnn-2) /\ typecheck(VEXTBINOP_M2, M-2) /\ typecheck(VEXTBINOP_HALF, VEXTBINOP_HALF) /\ typecheck(VEXTBINOP_SX, VEXTBINOP_SX) /\ typecheck(VEXTBINOP_V1, vec-(V128)) /\ typecheck(VEXTBINOP_V2, vec-(V128)) .

  vars VEXTBINOP_JNN1 VEXTBINOP_M1 VEXTBINOP_JNN2 VEXTBINOP_M2 VEXTBINOP_V1 VEXTBINOP_V2 : WasmTerminal .
  ceq $vextbinop--(X, X, DOTS, VEXTBINOP_V1, VEXTBINOP_V2) = $ivextbinop--(X, X, 0, S, S, 0, VEXTBINOP_M1, VEXTBINOP_V1, VEXTBINOP_V2) 
      if typecheck(VEXTBINOP_JNN1, Jnn-1) /\ typecheck(VEXTBINOP_M1, M-1) /\ typecheck(VEXTBINOP_JNN2, Jnn-2) /\ typecheck(VEXTBINOP_M2, M-2) /\ typecheck(VEXTBINOP_V1, vec-(V128)) /\ typecheck(VEXTBINOP_V2, vec-(V128)) .

  vars VEXTBINOP_JNN1 VEXTBINOP_M1 VEXTBINOP_JNN2 VEXTBINOP_M2 VEXTBINOP_V1 VEXTBINOP_V2 : WasmTerminal .
  ceq $vextbinop--(X, X, RELAXED_DOTS, VEXTBINOP_V1, VEXTBINOP_V2) = $ivextbinop--(X, X, 0, S, $relaxed2($R-idot(), sx, S, U), 0, VEXTBINOP_M1, VEXTBINOP_V1, VEXTBINOP_V2) 
      if typecheck(VEXTBINOP_JNN1, Jnn-1) /\ typecheck(VEXTBINOP_M1, M-1) /\ typecheck(VEXTBINOP_JNN2, Jnn-2) /\ typecheck(VEXTBINOP_M2, M-2) /\ typecheck(VEXTBINOP_V1, vec-(V128)) /\ typecheck(VEXTBINOP_V2, vec-(V128)) .


  op $vextternop-- : WasmTerminal WasmTerminal WasmTerminal WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars VEXTTERNOP_JNN1 VEXTTERNOP_M1 VEXTTERNOP_JNN2 VEXTTERNOP_M2 VEXTTERNOP_C1 VEXTTERNOP_C2 VEXTTERNOP_C3 VEXTTERNOP_C VEXTTERNOP_JNN VEXTTERNOP_M VEXTTERNOP_C' VEXTTERNOP_C'' : WasmTerminal .
  ceq $vextternop--(X, X, RELAXED_DOT_ADDS, VEXTTERNOP_C1, VEXTTERNOP_C2, VEXTTERNOP_C3) = VEXTTERNOP_C 
      if typecheck(VEXTTERNOP_JNN1, Jnn-1) /\ typecheck(VEXTTERNOP_M1, M-1) /\ typecheck(VEXTTERNOP_JNN2, Jnn-2) /\ typecheck(VEXTTERNOP_M2, M-2) /\ typecheck(VEXTTERNOP_C1, vec-(V128)) /\ typecheck(VEXTTERNOP_C2, vec-(V128)) /\ typecheck(VEXTTERNOP_C3, vec-(V128)) /\ typecheck(VEXTTERNOP_C, vec-(V128)) /\ typecheck(VEXTTERNOP_JNN, Jnn) /\ typecheck(VEXTTERNOP_M, M) /\ typecheck(VEXTTERNOP_C', vec-(V128)) /\ typecheck(VEXTTERNOP_C'', vec-(V128)) .


endm
