  op $memsxx : WasmTerminal -> WasmTerminals .
  eq $memsxx() =  .

  vars MEMSXX_X MEMSXX_XX* : WasmTerminal .
  ceq $memsxx(UNKNOWN_EXP) = UNKNOWN_EXP 
