    -- if c_1* = $lanes_(Fnn X M, v_1)
    -- if c_2* = $lanes_(Fnn X M, v_2)
    -- if c* = $extend__(1, $sizenn(Fnn), S, $f_($sizenn(Fnn), c_1, c_2))*
