       /\ BY_RESULT := builtin.inv-ibytes-aux(BY_BYTES, 1, 0) .

  ceq deffbytesx5fx(FB_N, fN.pos_(FB_MAG)) = builtin.ibytes-aux(_quo_(FB_N, 8), FB_RAW)
    if _rem_(FB_N, 8) = 0
       /\ (builtin.fnmag-valid(FB_N, FB_MAG)) = true
