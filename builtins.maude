       /\ _<_(FI_X, - _^_(2, _-_(FI_N, 1))) .
  ceq builtin.trunc(FI_M, FI_N, sx.s, FI_F) = eps
    if _>_(FI_N, 0)
       /\ (builtin.float-finite(FI_M, FI_F)) = true
       /\ FI_R := builtin.float-rat(FI_M, FI_F)
       /\ FI_X := builtin.trunc-rat-int(FI_R)
       /\ _>_(FI_X, _-_( _^_(2, _-_(FI_N, 1)), 1)) .

  ceq builtin.trunc-sat(FI_M, FI_N, sx.u, FI_F) = uN.wrap(builtin.saturate-u-int(FI_N, FI_X))
    if _>_(FI_N, 0)
       /\ (builtin.float-finite(FI_M, FI_F)) = true
       /\ FI_R := builtin.float-rat(FI_M, FI_F)
       /\ FI_X := builtin.trunc-rat-int(FI_R) .
  ceq builtin.trunc-sat(FI_M, FI_N, sx.s, FI_F) = uN.wrap(builtin.saturate-s-int(FI_N, FI_X))
    if _>_(FI_N, 0)
       /\ (builtin.float-finite(FI_M, FI_F)) = true
       /\ FI_R := builtin.float-rat(FI_M, FI_F)
       /\ FI_X := builtin.trunc-rat-int(FI_R) .
  eq builtin.trunc-sat(FI_M, FI_N, sx.u, fN.pos(fNmag.inf)) = uN.wrap(_-_(_^_(2, FI_N), 1)) .
  eq builtin.trunc-sat(FI_M, FI_N, sx.u, fN.neg(fNmag.inf)) = uN.wrap(0) .
  ceq builtin.trunc-sat(FI_M, FI_N, sx.u, fN.pos(fNmag.nan(FI_FRAC))) = uN.wrap(0)
    if (builtin.fnmag-valid(FI_M, fNmag.nan(FI_FRAC))) = true .
  ceq builtin.trunc-sat(FI_M, FI_N, sx.u, fN.neg(fNmag.nan(FI_FRAC))) = uN.wrap(0)
    if (builtin.fnmag-valid(FI_M, fNmag.nan(FI_FRAC))) = true .
  ceq builtin.trunc-sat(FI_M, FI_N, sx.s, fN.pos(fNmag.inf)) = uN.wrap(_-_(_^_(2, _-_(FI_N, 1)), 1))
    if _>_(FI_N, 0) .
  ceq builtin.trunc-sat(FI_M, FI_N, sx.s, fN.neg(fNmag.inf)) = uN.wrap(builtin.int-to-iN(FI_N, - _^_(2, _-_(FI_N, 1))))
    if _>_(FI_N, 0) .
  ceq builtin.trunc-sat(FI_M, FI_N, sx.s, fN.pos(fNmag.nan(FI_FRAC))) = uN.wrap(0)
    if (builtin.fnmag-valid(FI_M, fNmag.nan(FI_FRAC))) = true .
  ceq builtin.trunc-sat(FI_M, FI_N, sx.s, fN.neg(fNmag.nan(FI_FRAC))) = uN.wrap(0)
    if (builtin.fnmag-valid(FI_M, fNmag.nan(FI_FRAC))) = true .

  ceq builtin.convert(FI_M, FI_N, sx.u, uN.wrap(FI_RESULT)) =
      fN.pos(builtin.rounded-nat-to-fmag(FI_N, FI_RESULT))
    if _>_(FI_M, 0)
       /\ _>_(FI_N, 0)
       /\ _<_(FI_RESULT, _^_(2, FI_M))
       /\ (builtin.fnmag-valid(FI_N, builtin.rounded-nat-to-fmag(FI_N, FI_RESULT))) = true .
  ceq builtin.convert(FI_M, FI_N, sx.s, uN.wrap(FI_RESULT)) =
      fN.pos(builtin.rounded-nat-to-fmag(FI_N, FI_RESULT))
    if _>_(FI_M, 0)
       /\ _>_(FI_N, 0)
       /\ _<_(FI_RESULT, _^_(2, _-_(FI_M, 1)))
       /\ (builtin.fnmag-valid(FI_N, builtin.rounded-nat-to-fmag(FI_N, FI_RESULT))) = true .
  ceq builtin.convert(FI_M, FI_N, sx.s, uN.wrap(FI_RESULT)) =
      fN.neg(builtin.rounded-nat-to-fmag(FI_N, _-_(_^_(2, FI_M), FI_RESULT)))
    if _>_(FI_M, 0)
       /\ _>_(FI_N, 0)
       /\ _>=_(FI_RESULT, _^_(2, _-_(FI_M, 1)))
       /\ _<_(FI_RESULT, _^_(2, FI_M))
       /\ (builtin.fnmag-valid(FI_N, builtin.rounded-nat-to-fmag(FI_N, _-_(_^_(2, FI_M), FI_RESULT)))) = true .

  ceq builtin.demote(64, 32, fN.pos(FI_MAG)) = builtin.demote-f64(fN.pos(FI_MAG))
    if (builtin.fnmag-valid(64, FI_MAG)) = true .
  ceq builtin.demote(64, 32, fN.neg(FI_MAG)) = builtin.demote-f64(fN.neg(FI_MAG))
    if (builtin.fnmag-valid(64, FI_MAG)) = true .

  ceq builtin.promote(32, 64, fN.pos(FI_MAG)) = builtin.promote-f32(fN.pos(FI_MAG))
    if (builtin.fnmag-valid(32, FI_MAG)) = true .
  ceq builtin.promote(32, 64, fN.neg(FI_MAG)) = builtin.promote-f32(fN.neg(FI_MAG))
    if (builtin.fnmag-valid(32, FI_MAG)) = true .

  ceq builtin.fabs(FS_N, fN.pos(FS_MAG)) = fN.pos(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true .
  ceq builtin.fabs(FS_N, fN.neg(FS_MAG)) = fN.pos(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true .

  ceq builtin.fneg(FS_N, fN.pos(FS_MAG)) = fN.neg(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true .
  ceq builtin.fneg(FS_N, fN.neg(FS_MAG)) = fN.pos(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true .

  ceq builtin.fcopysign(FS_N, fN.pos(FS_MAG), fN.pos(FS_MAG2)) = fN.pos(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true
       /\ (builtin.fnmag-valid(FS_N, FS_MAG2)) = true .
  ceq builtin.fcopysign(FS_N, fN.neg(FS_MAG), fN.pos(FS_MAG2)) = fN.pos(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true
       /\ (builtin.fnmag-valid(FS_N, FS_MAG2)) = true .
  ceq builtin.fcopysign(FS_N, fN.pos(FS_MAG), fN.neg(FS_MAG2)) = fN.neg(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true
       /\ (builtin.fnmag-valid(FS_N, FS_MAG2)) = true .
  ceq builtin.fcopysign(FS_N, fN.neg(FS_MAG), fN.neg(FS_MAG2)) = fN.neg(FS_MAG)
    if (builtin.fnmag-valid(FS_N, FS_MAG)) = true
       /\ (builtin.fnmag-valid(FS_N, FS_MAG2)) = true .

  --- Implemented declaration-only builtin: canonical UTF-8 encoding of char*.
  var UTF_C : Nat .
  var UTF_REST : SpectecTerminals .
  eq def.utf8(eps) = eps .
  ceq def.utf8(char.wrap(UTF_C) UTF_REST) =
      byte.wrap(UTF_C) def.utf8(UTF_REST)
    if _<_(UTF_C, 128)
       /\ (typecheckSeq(UTF_REST, syn.char)) = true .
  ceq def.utf8(char.wrap(UTF_C) UTF_REST) =
      byte.wrap(_+_(192, _quo_(UTF_C, 64)))
      byte.wrap(_+_(128, _rem_(UTF_C, 64)))
      def.utf8(UTF_REST)
    if _>=_(UTF_C, 128) /\ _<_(UTF_C, 2048)
       /\ (typecheckSeq(UTF_REST, syn.char)) = true .
  ceq def.utf8(char.wrap(UTF_C) UTF_REST) =
      byte.wrap(_+_(224, _quo_(UTF_C, 4096)))
      byte.wrap(_+_(128, _rem_(_quo_(UTF_C, 64), 64)))
      byte.wrap(_+_(128, _rem_(UTF_C, 64)))
      def.utf8(UTF_REST)
    if _or_(_and_(_>=_(UTF_C, 2048), _<_(UTF_C, 55296)),
             _and_(_>=_(UTF_C, 57344), _<_(UTF_C, 65536)))
       /\ (typecheckSeq(UTF_REST, syn.char)) = true .
  ceq def.utf8(char.wrap(UTF_C) UTF_REST) =
      byte.wrap(_+_(240, _quo_(UTF_C, 262144)))
      byte.wrap(_+_(128, _rem_(_quo_(UTF_C, 4096), 64)))
      byte.wrap(_+_(128, _rem_(_quo_(UTF_C, 64), 64)))
      byte.wrap(_+_(128, _rem_(UTF_C, 64)))
      def.utf8(UTF_REST)
    if _>=_(UTF_C, 65536) /\ _<_(UTF_C, 1114112)
       /\ (typecheckSeq(UTF_REST, syn.char)) = true .

  --- Backend semantics: official-spectec-deterministic.
  --- Source: spectec/src/backend-interpreter/numerics.ml.
  --- Reference revision: d34a973e70ab127476b5d8591c6f558be289b929.
  --- Relaxed madd is separately rounded fmul then fadd, not fused.
  --- This intentionally differs from the direct Wasm interpreter's fused choice.
  vars BDR_M BDR_N BDR_I BDR_J BDR_K : Nat .
  var BDR_SX : SpectecTerminal .
  vars BDR_F1 BDR_F2 BDR_F3 : SpectecTerminal .

  --- official-spectec-deterministic: partial inverse sequence choices.
  var BDI_T : SpectecType .
  var BDI_X : SpectecTerminal .
  vars BDI_XS BDI_REST : SpectecTerminals .
  var BDI_Y : SpectecTerminal .
  op builtin.pair-chunks : SpectecTerminals ~> SpectecTerminals .
  eq builtin.pair-chunks(eps) = eps .
  eq builtin.pair-chunks(BDI_X BDI_Y BDI_REST) =
      seq(BDI_X BDI_Y) builtin.pair-chunks(BDI_REST) .
  ceq builtin.inv-concat(BDI_T, BDI_XS) = builtin.pair-chunks(BDI_XS)
    if _==_(_rem_(len(BDI_XS), 2), 0) .
  var BDI_N : NzNat .
  var BDI_K : Nat .
  op builtin.take-exact : Nat SpectecTerminals ~> SpectecTerminals .
  op builtin.fixed-chunks : NzNat SpectecTerminals ~> SpectecTerminals .
  eq builtin.take-exact(0, BDI_XS) = eps .
  eq builtin.take-exact(s BDI_K, BDI_X BDI_REST) =
      BDI_X builtin.take-exact(BDI_K, BDI_REST) .
  eq builtin.fixed-chunks(BDI_N, eps) = eps .
  ceq builtin.fixed-chunks(BDI_N, BDI_XS) =
      seq(builtin.take-exact(BDI_N, BDI_XS))
      builtin.fixed-chunks(BDI_N, drop(BDI_N, BDI_XS))
    if _>=_(len(BDI_XS), BDI_N) .
  ceq builtin.inv-concatn(BDI_T, BDI_N, BDI_XS) = builtin.fixed-chunks(BDI_N, BDI_XS)
    if _==_(_rem_(len(BDI_XS), BDI_N), 0) .
  eq builtin.nd = bool(false) .
  eq builtin.r-fmadd = relaxed2.wrap(0) .
  eq builtin.r-fmin = relaxed4.wrap(0) .
  eq builtin.r-fmax = relaxed4.wrap(0) .
  eq builtin.r-idot = relaxed2.wrap(0) .
  eq builtin.r-iq15mulr = relaxed2.wrap(0) .
  eq builtin.r-trunc-u = relaxed4.wrap(0) .
  eq builtin.r-trunc-s = relaxed2.wrap(0) .
  eq builtin.r-swizzle = relaxed2.wrap(0) .
  eq builtin.r-laneselect = relaxed2.wrap(0) .
  eq builtin.irelaxed-q15mulr(BDR_N, BDR_SX, uN.wrap(BDR_I), uN.wrap(BDR_J)) = builtin.iq15mulr-sat(BDR_N, BDR_SX, uN.wrap(BDR_I), uN.wrap(BDR_J)) .
  eq builtin.irelaxed-laneselect(BDR_N, uN.wrap(BDR_I), uN.wrap(BDR_J), uN.wrap(BDR_K)) = builtin.ibitselect(BDR_N, uN.wrap(BDR_I), uN.wrap(BDR_J), uN.wrap(BDR_K)) .
  eq builtin.frelaxed-min(BDR_N, BDR_F1, BDR_F2) = builtin.fmin(BDR_N, BDR_F1, BDR_F2) .
  eq builtin.frelaxed-max(BDR_N, BDR_F1, BDR_F2) = builtin.fmax(BDR_N, BDR_F1, BDR_F2) .
  eq builtin.frelaxed-madd(BDR_N, BDR_F1, BDR_F2, BDR_F3) = builtin.fadd(BDR_N, builtin.fmul(BDR_N, BDR_F1, BDR_F2), BDR_F3) .
  eq builtin.frelaxed-nmadd(BDR_N, BDR_F1, BDR_F2, BDR_F3) = builtin.fadd(BDR_N, builtin.fmul(BDR_N, builtin.fneg(BDR_N, BDR_F1), BDR_F2), BDR_F3) .
  eq builtin.relaxed-trunc(BDR_M, BDR_N, BDR_SX, BDR_F1) = builtin.trunc-sat(BDR_M, BDR_N, BDR_SX, BDR_F1) .

endm
