  eq builtin.zbytes-pack(ZB_N, packx5f.wrap_(ZB_PAYLOAD)) = builtin.zbytes-pack(ZB_N, ZB_PAYLOAD) .
  ceq builtin.zbytes-pack(ZB_N, iN.wrap_(ZB_RAW)) = defibytesx5fx(ZB_N, iN.wrap_(ZB_RAW))
