  eq builtin.iand-bits(eps, eps) = eps .
  eq builtin.iand-bits(0 BT_BITS1, 0 BT_BITS2) = 0 builtin.iand-bits(BT_BITS1, BT_BITS2) .
  eq builtin.iand-bits(0 BT_BITS1, 1 BT_BITS2) = 0 builtin.iand-bits(BT_BITS1, BT_BITS2) .
