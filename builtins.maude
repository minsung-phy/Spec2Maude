  op builtin.zbytes-pack : Nat SpectecTerminal -> SpectecTerminals .
  op builtin.inv-zbytes-pack : Nat SpectecTerminals -> SpectecTerminal .
  ceq builtin.zbytes-pack(ZB_N, uN.wrap(ZB_RAW)) = builtin.ibytes(ZB_N, uN.wrap(ZB_RAW))
    if _<_(ZB_RAW, _^_(2, ZB_N)) .
  ceq builtin.inv-zbytes-pack(ZB_N, ZB_BYTES) = uN.wrap(ZB_RAW)
    if _rem_(ZB_N, 8) = 0
       /\ len(ZB_BYTES) = _quo_(ZB_N, 8)
       /\ typecheckSeq(ZB_BYTES, syn.byte)
       /\ ZB_RAW := builtin.inv-ibytes-aux(ZB_BYTES, 1, 0) .

  --- Implemented builtin family: vector lane splitting/reassembly.
  vars LN_W LN_COUNT LN_RAW LN_SCALE LN_ACC : Nat .
  var LN_LT : SpectecTerminal .
  var LN_PAYLOAD : SpectecTerminal .
  var LN_HEAD : SpectecTerminal .
  var LN_MAG : SpectecTerminal .
  vars LN_LANES LN_TAIL : SpectecTerminals .
  op builtin.lane-width : SpectecTerminal -> Nat .
  op builtin.vec-raw : SpectecTerminal -> Nat .
  op builtin.lane-from-bits : SpectecTerminal Nat -> SpectecTerminal .
  op builtin.lane-to-bits : SpectecTerminal SpectecTerminal -> Nat .
  op builtin.lanes-aux : SpectecTerminal Nat Nat Nat -> SpectecTerminals .
  op builtin.inv-lanes-aux : SpectecTerminal Nat SpectecTerminals Nat Nat -> Nat .
  eq builtin.lane-width(numtype.i32) = 32 .
  eq builtin.lane-width(numtype.i64) = 64 .
  eq builtin.lane-width(numtype.f32) = 32 .
  eq builtin.lane-width(numtype.f64) = 64 .
  eq builtin.lane-width(packtype.i8) = 8 .
  eq builtin.lane-width(packtype.i16) = 16 .
  eq builtin.vec-raw(uN.wrap(LN_RAW)) = LN_RAW .
  ceq builtin.lane-from-bits(numtype.i32, LN_RAW) = uN.wrap(LN_RAW)
    if _<_(LN_RAW, _^_(2, 32)) .
  ceq builtin.lane-from-bits(numtype.i64, LN_RAW) = uN.wrap(LN_RAW)
    if _<_(LN_RAW, _^_(2, 64)) .
  ceq builtin.lane-from-bits(packtype.i8, LN_RAW) = uN.wrap(LN_RAW)
    if _<_(LN_RAW, _^_(2, 8)) .
  ceq builtin.lane-from-bits(packtype.i16, LN_RAW) = uN.wrap(LN_RAW)
    if _<_(LN_RAW, _^_(2, 16)) .
  ceq builtin.lane-from-bits(numtype.f32, LN_RAW) = builtin.float-from-bits(32, LN_RAW)
    if _<_(LN_RAW, _^_(2, 32)) .
  ceq builtin.lane-from-bits(numtype.f64, LN_RAW) = builtin.float-from-bits(64, LN_RAW)
    if _<_(LN_RAW, _^_(2, 64)) .
  ceq builtin.lane-to-bits(numtype.i32, uN.wrap(LN_RAW)) = LN_RAW
    if _<_(LN_RAW, _^_(2, 32)) .
  ceq builtin.lane-to-bits(numtype.i64, uN.wrap(LN_RAW)) = LN_RAW
    if _<_(LN_RAW, _^_(2, 64)) .
  ceq builtin.lane-to-bits(packtype.i8, uN.wrap(LN_RAW)) = LN_RAW
    if _<_(LN_RAW, _^_(2, 8)) .
  ceq builtin.lane-to-bits(packtype.i16, uN.wrap(LN_RAW)) = LN_RAW
    if _<_(LN_RAW, _^_(2, 16)) .
  ceq builtin.lane-to-bits(numtype.f32, fN.pos(LN_MAG)) = builtin.float-to-bits(32, fN.pos(LN_MAG))
    if (builtin.fnmag-valid(32, LN_MAG)) = true .
  ceq builtin.lane-to-bits(numtype.f32, fN.neg(LN_MAG)) = builtin.float-to-bits(32, fN.neg(LN_MAG))
    if (builtin.fnmag-valid(32, LN_MAG)) = true .
  ceq builtin.lane-to-bits(numtype.f64, fN.pos(LN_MAG)) = builtin.float-to-bits(64, fN.pos(LN_MAG))
    if (builtin.fnmag-valid(64, LN_MAG)) = true .
  ceq builtin.lane-to-bits(numtype.f64, fN.neg(LN_MAG)) = builtin.float-to-bits(64, fN.neg(LN_MAG))
    if (builtin.fnmag-valid(64, LN_MAG)) = true .
  eq builtin.lanes-aux(LN_LT, LN_W, 0, LN_RAW) = eps .
  ceq builtin.lanes-aux(LN_LT, LN_W, LN_COUNT, LN_RAW) =
      builtin.lane-from-bits(LN_LT, _rem_(LN_RAW, _^_(2, LN_W)))
      builtin.lanes-aux(LN_LT, LN_W, _-_(LN_COUNT, 1), _quo_(LN_RAW, _^_(2, LN_W)))
    if _>_(LN_COUNT, 0) .
  eq builtin.inv-lanes-aux(LN_LT, LN_W, eps, LN_SCALE, LN_ACC) = LN_ACC .
  ceq builtin.inv-lanes-aux(LN_LT, LN_W, LN_HEAD LN_TAIL, LN_SCALE, LN_ACC) =
      builtin.inv-lanes-aux(LN_LT, LN_W, LN_TAIL, _*_(LN_SCALE, _^_(2, LN_W)), _+_(LN_ACC, _*_(LN_RAW, LN_SCALE)))
    if LN_RAW := builtin.lane-to-bits(LN_LT, LN_HEAD)
       /\ _<_(LN_RAW, _^_(2, LN_W)) .

  ceq builtin.ibits(BI_N, uN.wrap(BI_I)) = builtin.ibits-aux(BI_N, BI_I)
    if _<_(BI_I, _^_(2, BI_N)) .

  ceq builtin.inv-ibits(BI_N, BI_BITS) = uN.wrap(BI_RESULT)
    if len(BI_BITS) = BI_N
       /\ typecheckSeq(BI_BITS, syn.bit)
       /\ BI_RESULT := builtin.inv-ibits-aux(BI_BITS, 0) .

  ceq builtin.fbits(FB_N, fN.pos(FB_MAG)) = builtin.ibits-aux(FB_N, FB_RAW)
    if (builtin.fnmag-valid(FB_N, FB_MAG)) = true
       /\ FB_RAW := builtin.float-to-bits(FB_N, fN.pos(FB_MAG)) .
  ceq builtin.fbits(FB_N, fN.neg(FB_MAG)) = builtin.ibits-aux(FB_N, FB_RAW)
    if (builtin.fnmag-valid(FB_N, FB_MAG)) = true
       /\ FB_RAW := builtin.float-to-bits(FB_N, fN.neg(FB_MAG)) .

  ceq builtin.inv-fbits(FB_N, FB_BITS) = builtin.float-from-bits(FB_N, FB_RAW)
    if len(FB_BITS) = FB_N
       /\ typecheckSeq(FB_BITS, syn.bit)
       /\ FB_RAW := builtin.inv-ibits-aux(FB_BITS, 0) .

  ceq builtin.ibytes(BY_N, uN.wrap(BY_I)) = builtin.ibytes-aux(_quo_(BY_N, 8), BY_I)
    if _rem_(BY_N, 8) = 0
       /\ _<_(BY_I, _^_(2, BY_N)) .

  ceq builtin.inv-ibytes(BY_N, BY_BYTES) = uN.wrap(BY_RESULT)
    if _rem_(BY_N, 8) = 0
       /\ len(BY_BYTES) = _quo_(BY_N, 8)
       /\ typecheckSeq(BY_BYTES, syn.byte)
       /\ BY_RESULT := builtin.inv-ibytes-aux(BY_BYTES, 1, 0) .

  ceq builtin.fbytes(FB_N, fN.pos(FB_MAG)) = builtin.ibytes-aux(_quo_(FB_N, 8), FB_RAW)
    if _rem_(FB_N, 8) = 0
       /\ (builtin.fnmag-valid(FB_N, FB_MAG)) = true
       /\ FB_RAW := builtin.float-to-bits(FB_N, fN.pos(FB_MAG)) .
  ceq builtin.fbytes(FB_N, fN.neg(FB_MAG)) = builtin.ibytes-aux(_quo_(FB_N, 8), FB_RAW)
    if _rem_(FB_N, 8) = 0
       /\ (builtin.fnmag-valid(FB_N, FB_MAG)) = true
       /\ FB_RAW := builtin.float-to-bits(FB_N, fN.neg(FB_MAG)) .

  ceq builtin.inv-fbytes(FB_N, FB_BYTES) = builtin.float-from-bits(FB_N, FB_RAW)
    if _rem_(FB_N, 8) = 0
       /\ len(FB_BYTES) = _quo_(FB_N, 8)
       /\ typecheckSeq(FB_BYTES, syn.byte)
       /\ FB_RAW := builtin.inv-ibytes-aux(FB_BYTES, 1, 0) .

  eq builtin.nbytes(numtype.i32, NB_PAYLOAD) = builtin.nbytes-int(32, NB_PAYLOAD) .
  eq builtin.nbytes(numtype.i64, NB_PAYLOAD) = builtin.nbytes-int(64, NB_PAYLOAD) .
  eq builtin.nbytes(numtype.f32, NB_PAYLOAD) = builtin.nbytes-float(32, NB_PAYLOAD) .
  eq builtin.nbytes(numtype.f64, NB_PAYLOAD) = builtin.nbytes-float(64, NB_PAYLOAD) .

  eq builtin.inv-nbytes(numtype.i32, NB_BYTES) = builtin.inv-nbytes-int(32, NB_BYTES) .
  eq builtin.inv-nbytes(numtype.i64, NB_BYTES) = builtin.inv-nbytes-int(64, NB_BYTES) .
  eq builtin.inv-nbytes(numtype.f32, NB_BYTES) = builtin.inv-nbytes-float(32, NB_BYTES) .
  eq builtin.inv-nbytes(numtype.f64, NB_BYTES) = builtin.inv-nbytes-float(64, NB_BYTES) .

  eq builtin.reinterpret(numtype.i32, numtype.f32, NB_PAYLOAD) =
      builtin.inv-nbytes(numtype.f32, builtin.nbytes(numtype.i32, NB_PAYLOAD)) .
  eq builtin.reinterpret(numtype.f32, numtype.i32, NB_PAYLOAD) =
      builtin.inv-nbytes(numtype.i32, builtin.nbytes(numtype.f32, NB_PAYLOAD)) .
  eq builtin.reinterpret(numtype.i64, numtype.f64, NB_PAYLOAD) =
      builtin.inv-nbytes(numtype.f64, builtin.nbytes(numtype.i64, NB_PAYLOAD)) .
  eq builtin.reinterpret(numtype.f64, numtype.i64, NB_PAYLOAD) =
      builtin.inv-nbytes(numtype.i64, builtin.nbytes(numtype.f64, NB_PAYLOAD)) .

  ceq builtin.vbytes(vectype.v128, uN.wrap(BY_I)) =
      builtin.ibytes-aux(_quo_(def.vsize(vectype.v128), 8), BY_I)
    if _<_(BY_I, _^_(2, def.vsize(vectype.v128))) .

  ceq builtin.inv-vbytes(vectype.v128, BY_BYTES) = uN.wrap(BY_RESULT)
    if len(BY_BYTES) = _quo_(def.vsize(vectype.v128), 8)
       /\ typecheckSeq(BY_BYTES, syn.byte)
       /\ BY_RESULT := builtin.inv-ibytes-aux(BY_BYTES, 1, 0) .

  eq builtin.zbytes(numtype.i32, ZB_PAYLOAD) = builtin.nbytes(numtype.i32, ZB_PAYLOAD) .
  eq builtin.zbytes(numtype.i64, ZB_PAYLOAD) = builtin.nbytes(numtype.i64, ZB_PAYLOAD) .
  eq builtin.zbytes(numtype.f32, ZB_PAYLOAD) = builtin.nbytes(numtype.f32, ZB_PAYLOAD) .
  eq builtin.zbytes(numtype.f64, ZB_PAYLOAD) = builtin.nbytes(numtype.f64, ZB_PAYLOAD) .
  eq builtin.zbytes(vectype.v128, ZB_PAYLOAD) = builtin.vbytes(vectype.v128, ZB_PAYLOAD) .
  eq builtin.zbytes(packtype.i8, ZB_PAYLOAD) = builtin.zbytes-pack(8, ZB_PAYLOAD) .
  eq builtin.zbytes(packtype.i16, ZB_PAYLOAD) = builtin.zbytes-pack(16, ZB_PAYLOAD) .

  eq builtin.cbytes(numtype.i32, ZB_PAYLOAD) = builtin.nbytes(numtype.i32, ZB_PAYLOAD) .
  eq builtin.cbytes(numtype.i64, ZB_PAYLOAD) = builtin.nbytes(numtype.i64, ZB_PAYLOAD) .
  eq builtin.cbytes(numtype.f32, ZB_PAYLOAD) = builtin.nbytes(numtype.f32, ZB_PAYLOAD) .
  eq builtin.cbytes(numtype.f64, ZB_PAYLOAD) = builtin.nbytes(numtype.f64, ZB_PAYLOAD) .
  eq builtin.cbytes(vectype.v128, ZB_PAYLOAD) = builtin.vbytes(vectype.v128, ZB_PAYLOAD) .

  eq builtin.inv-zbytes(numtype.i32, ZB_BYTES) = builtin.inv-nbytes(numtype.i32, ZB_BYTES) .
  eq builtin.inv-zbytes(numtype.i64, ZB_BYTES) = builtin.inv-nbytes(numtype.i64, ZB_BYTES) .
  eq builtin.inv-zbytes(numtype.f32, ZB_BYTES) = builtin.inv-nbytes(numtype.f32, ZB_BYTES) .
  eq builtin.inv-zbytes(numtype.f64, ZB_BYTES) = builtin.inv-nbytes(numtype.f64, ZB_BYTES) .
  eq builtin.inv-zbytes(vectype.v128, ZB_BYTES) = builtin.inv-vbytes(vectype.v128, ZB_BYTES) .
  eq builtin.inv-zbytes(packtype.i8, ZB_BYTES) = builtin.inv-zbytes-pack(8, ZB_BYTES) .
  eq builtin.inv-zbytes(packtype.i16, ZB_BYTES) = builtin.inv-zbytes-pack(16, ZB_BYTES) .

  eq builtin.inv-cbytes(numtype.i32, ZB_BYTES) = builtin.inv-nbytes(numtype.i32, ZB_BYTES) .
  eq builtin.inv-cbytes(numtype.i64, ZB_BYTES) = builtin.inv-nbytes(numtype.i64, ZB_BYTES) .
  eq builtin.inv-cbytes(numtype.f32, ZB_BYTES) = builtin.inv-nbytes(numtype.f32, ZB_BYTES) .
  eq builtin.inv-cbytes(numtype.f64, ZB_BYTES) = builtin.inv-nbytes(numtype.f64, ZB_BYTES) .
  eq builtin.inv-cbytes(vectype.v128, ZB_BYTES) = builtin.inv-vbytes(vectype.v128, ZB_BYTES) .

  ceq builtin.lanes(shape.x(LN_LT, dim.wrap(LN_COUNT)), LN_PAYLOAD) =
      builtin.lanes-aux(LN_LT, LN_W, LN_COUNT, LN_RAW)
    if LN_W := builtin.lane-width(LN_LT)
       /\ _*_(LN_W, LN_COUNT) = 128
       /\ LN_RAW := builtin.vec-raw(LN_PAYLOAD)
       /\ _<_(LN_RAW, _^_(2, 128)) .

  ceq builtin.inv-lanes(shape.x(LN_LT, dim.wrap(LN_COUNT)), LN_LANES) =
      uN.wrap(builtin.inv-lanes-aux(LN_LT, LN_W, LN_LANES, 1, 0))
    if LN_W := builtin.lane-width(LN_LT)
       /\ _*_(LN_W, LN_COUNT) = 128
       /\ len(LN_LANES) = LN_COUNT .

  ceq builtin.wrap(BW_M, BW_N, uN.wrap(BW_I)) = uN.wrap(_rem_(BW_I, _^_(2, BW_N)))
    if _>_(BW_N, 0)
       /\ _<_(BW_N, BW_M)
       /\ _<_(BW_I, _^_(2, BW_M)) .

  ceq builtin.extend(BE_M, BE_N, sx.u, uN.wrap(BE_I)) = uN.wrap(BE_I)
    if _<_(BE_M, BE_N)
       /\ _<_(BE_I, _^_(2, BE_M)) .
  ceq builtin.extend(BE_M, BE_N, sx.s, uN.wrap(BE_I)) = uN.wrap(builtin.sign-extend-nat(BE_M, BE_N, BE_I))
    if _>_(BE_M, 0)
       /\ _<_(BE_M, BE_N)
       /\ _<_(BE_I, _^_(2, BE_M)) .

  ceq builtin.iclz(BC_N, uN.wrap(BC_I)) = uN.wrap(builtin.iclz-bits(builtin.ibits-aux(BC_N, BC_I), 0))
    if _>_(BC_N, 0)
       /\ _<_(BC_I, _^_(2, BC_N)) .

  ceq builtin.ictz(BC_N, uN.wrap(BC_I)) = uN.wrap(builtin.ictz-bits(builtin.ibits-aux(BC_N, BC_I), 0))
    if _>_(BC_N, 0)
       /\ _<_(BC_I, _^_(2, BC_N)) .

  ceq builtin.ipopcnt(BC_N, uN.wrap(BC_I)) = uN.wrap(builtin.ipopcnt-bits(builtin.ibits-aux(BC_N, BC_I), 0))
    if _>_(BC_N, 0)
       /\ _<_(BC_I, _^_(2, BC_N)) .

  ceq builtin.inot(BT_N, uN.wrap(BT_I)) = uN.wrap(builtin.inv-ibits-aux(builtin.inot-bits(builtin.ibits-aux(BT_N, BT_I)), 0))
    if _>_(BT_N, 0)
       /\ _<_(BT_I, _^_(2, BT_N)) .

  ceq builtin.irev(BT_N, uN.wrap(BT_I)) = uN.wrap(builtin.inv-ibits-aux(builtin.irev-bits(builtin.ibits-aux(BT_N, BT_I), eps), 0))
    if _>_(BT_N, 0)
       /\ _<_(BT_I, _^_(2, BT_N)) .

  ceq builtin.iand(BT_N, uN.wrap(BT_I), uN.wrap(BT_J)) = uN.wrap(builtin.inv-ibits-aux(builtin.iand-bits(builtin.ibits-aux(BT_N, BT_I), builtin.ibits-aux(BT_N, BT_J)), 0))
    if _>_(BT_N, 0)
       /\ _<_(BT_I, _^_(2, BT_N))
       /\ _<_(BT_J, _^_(2, BT_N)) .

  ceq builtin.iandnot(BT_N, uN.wrap(BT_I), uN.wrap(BT_J)) = uN.wrap(builtin.inv-ibits-aux(builtin.iandnot-bits(builtin.ibits-aux(BT_N, BT_I), builtin.ibits-aux(BT_N, BT_J)), 0))
    if _>_(BT_N, 0)
       /\ _<_(BT_I, _^_(2, BT_N))
       /\ _<_(BT_J, _^_(2, BT_N)) .

  ceq builtin.ior(BT_N, uN.wrap(BT_I), uN.wrap(BT_J)) = uN.wrap(builtin.inv-ibits-aux(builtin.ior-bits(builtin.ibits-aux(BT_N, BT_I), builtin.ibits-aux(BT_N, BT_J)), 0))
    if _>_(BT_N, 0)
       /\ _<_(BT_I, _^_(2, BT_N))
       /\ _<_(BT_J, _^_(2, BT_N)) .

  ceq builtin.ixor(BT_N, uN.wrap(BT_I), uN.wrap(BT_J)) = uN.wrap(builtin.inv-ibits-aux(builtin.ixor-bits(builtin.ibits-aux(BT_N, BT_I), builtin.ibits-aux(BT_N, BT_J)), 0))
    if _>_(BT_N, 0)
       /\ _<_(BT_I, _^_(2, BT_N))
       /\ _<_(BT_J, _^_(2, BT_N)) .

  ceq builtin.ibitselect(BT_N, uN.wrap(BT_I), uN.wrap(BT_J), uN.wrap(BT_K)) =
      uN.wrap(builtin.inv-ibits-aux(
        builtin.ior-bits(
          builtin.iand-bits(builtin.ibits-aux(BT_N, BT_I), builtin.ibits-aux(BT_N, BT_K)),
          builtin.iand-bits(builtin.ibits-aux(BT_N, BT_J), builtin.inot-bits(builtin.ibits-aux(BT_N, BT_K)))),
        0))
    if _>_(BT_N, 0)
       /\ _<_(BT_I, _^_(2, BT_N))
       /\ _<_(BT_J, _^_(2, BT_N))
       /\ _<_(BT_K, _^_(2, BT_N)) .

  ceq builtin.ishl(SH_N, uN.wrap(SH_I), uN.wrap(SH_J)) =
      uN.wrap(_rem_(_*_(SH_I, _^_(2, SH_K)), _^_(2, SH_N)))
    if _<_(SH_I, _^_(2, SH_N))
       /\ _<_(SH_J, _^_(2, 32))
       /\ SH_K := builtin.shift-count(SH_N, SH_J) .

  ceq builtin.ishr(SH_N, sx.u, uN.wrap(SH_I), uN.wrap(SH_J)) =
      uN.wrap(_quo_(SH_I, _^_(2, SH_K)))
    if _<_(SH_I, _^_(2, SH_N))
       /\ _<_(SH_J, _^_(2, 32))
       /\ SH_K := builtin.shift-count(SH_N, SH_J) .
  ceq builtin.ishr(SH_N, sx.s, uN.wrap(SH_I), uN.wrap(SH_J)) = uN.wrap(SH_I)
    if _<_(SH_I, _^_(2, SH_N))
       /\ _<_(SH_J, _^_(2, 32))
       /\ builtin.shift-count(SH_N, SH_J) = 0 .
  ceq builtin.ishr(SH_N, sx.s, uN.wrap(SH_I), uN.wrap(SH_J)) =
      uN.wrap(builtin.sign-extend-nat(sd(SH_N, SH_K), SH_N, _quo_(SH_I, _^_(2, SH_K))))
    if _<_(SH_I, _^_(2, SH_N))
       /\ _<_(SH_J, _^_(2, 32))
       /\ SH_K := builtin.shift-count(SH_N, SH_J)
       /\ _>_(SH_K, 0) .

  ceq builtin.irotl(SH_N, uN.wrap(SH_I), uN.wrap(SH_J)) =
      uN.wrap(_rem_(_+_(_rem_(_*_(SH_I, _^_(2, SH_K)), _^_(2, SH_N)), _quo_(SH_I, _^_(2, sd(SH_N, SH_K)))), _^_(2, SH_N)))
    if _<_(SH_I, _^_(2, SH_N))
       /\ _<_(SH_J, _^_(2, SH_N))
       /\ SH_K := builtin.shift-count(SH_N, SH_J) .

  ceq builtin.irotr(SH_N, uN.wrap(SH_I), uN.wrap(SH_J)) =
      uN.wrap(_rem_(_+_(_quo_(SH_I, _^_(2, SH_K)), _*_( _rem_(SH_I, _^_(2, SH_K)), _^_(2, sd(SH_N, SH_K)))), _^_(2, SH_N)))
    if _<_(SH_I, _^_(2, SH_N))
       /\ _<_(SH_J, _^_(2, SH_N))
       /\ SH_K := builtin.shift-count(SH_N, SH_J) .

  ceq builtin.narrow(NW_M, NW_N, sx.u, uN.wrap(NW_I)) = uN.wrap(NW_I)
    if _>_(NW_M, NW_N)
       /\ _<_(NW_I, _^_(2, NW_N)) .
  ceq builtin.narrow(NW_M, NW_N, sx.u, uN.wrap(NW_I)) = uN.wrap(sd(1, _^_(2, NW_N)))
    if _>_(NW_M, NW_N)
       /\ _>=_(NW_I, _^_(2, NW_N))
       /\ _<_(NW_I, _^_(2, NW_M)) .
  ceq builtin.narrow(NW_M, NW_N, sx.s, uN.wrap(NW_I)) = uN.wrap(NW_I)
    if _>_(NW_M, NW_N)
       /\ _<_(NW_I, _^_(2, sd(1, NW_N))) .
  ceq builtin.narrow(NW_M, NW_N, sx.s, uN.wrap(NW_I)) = uN.wrap(sd(1, _^_(2, sd(1, NW_N))))
    if _>_(NW_M, NW_N)
       /\ _>=_(NW_I, _^_(2, sd(1, NW_N)))
       /\ _<_(NW_I, _^_(2, sd(1, NW_M))) .
  ceq builtin.narrow(NW_M, NW_N, sx.s, uN.wrap(NW_I)) = uN.wrap(_^_(2, sd(1, NW_N)))
    if _>_(NW_M, NW_N)
       /\ _>=_(NW_I, _^_(2, sd(1, NW_M)))
       /\ _<_(NW_I, sd(_^_(2, sd(1, NW_N)), _^_(2, NW_M))) .
  ceq builtin.narrow(NW_M, NW_N, sx.s, uN.wrap(NW_I)) = uN.wrap(_+_(_-_(NW_I, _^_(2, NW_M)), _^_(2, NW_N)))
    if _>_(NW_M, NW_N)
       /\ _>=_(NW_I, sd(_^_(2, sd(1, NW_N)), _^_(2, NW_M)))
       /\ _<_(NW_I, _^_(2, NW_M)) .

  ceq builtin.iavgr(AV_N, sx.u, uN.wrap(AV_I), uN.wrap(AV_J)) =
      uN.wrap(_quo_(_+_(_+_(AV_I, AV_J), 1), 2))
    if _>_(AV_N, 0)
       /\ _<_(AV_I, _^_(2, AV_N))
       /\ _<_(AV_J, _^_(2, AV_N)) .

  ceq builtin.iq15mulr-sat(Q15_N, sx.s, uN.wrap(Q15_I), uN.wrap(Q15_J)) =
      uN.wrap(builtin.wrap-s-int(Q15_N,
        builtin.sat-s-int(Q15_N,
          builtin.floor-div-pow2-int(
