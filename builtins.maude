  eq builtin.inot-bits(0 BT_BITS) = 1 builtin.inot-bits(BT_BITS) .
  eq builtin.inot-bits(1 BT_BITS) = 0 builtin.inot-bits(BT_BITS) .
  eq builtin.irev-bits(eps, BT_BITS2) = BT_BITS2 .
