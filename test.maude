load output.maude

--- Spec2Maude final sanity checks
--- Run with: maude test.maude

mod SPEC2MAUDE-ZERO-CHECK is
  inc SPECTEC-CORE .

  --- Variables used only to instantiate existing translated rules.
  var ST : subtype .
  var TYPE_IDX_ZERO : typeidx .   --- 변수 선언을 모듈 내부로 이동!
endm

--- [1] OSA membership-style typing check over canonical constructors.
red in SPEC2MAUDE-ZERO-CHECK : type-ok(CTORI32A0, num(i32)) .

--- [2] Def evaluation with explicit binding scheduling
red in SPEC2MAUDE-ZERO-CHECK : $rollrt(TYPE_IDX_ZERO, CTORRECA1(ST)) .

--- [3] List/monoid behavior check
red in SPEC2MAUDE-ZERO-CHECK : $concat(eps, eps) .

--- [4] Pure arithmetic reduction
red in SPEC2MAUDE-ZERO-CHECK : $iadd(32, 7, 9) .

quit