  op Step-pure : WasmTerminal WasmTerminal -> Bool .
  eq Step-pure(UNREACHABLE, TRAP) = true .
  eq Step-pure(NOP, eps) = true .

  var DROP_VAL : WasmTerminal .
  ceq Step-pure(DROP_VAL DROP, eps) = true 
      if typecheck(DROP_VAL, val) .

  vars SELECT-TRUE_T*? SELECT-TRUE_VAL1 SELECT-TRUE_VAL2 SELECT-TRUE_WC T* : WasmTerminal .
  ceq Step-pure(SELECT-TRUE_VAL1 SELECT-TRUE_VAL2 CONST I32 SELECT-TRUE_WC SELECT T*, SELECT-TRUE_VAL1) = true 
      if typecheck(SELECT-TRUE_VAL1, val) /\ typecheck(SELECT-TRUE_VAL2, val) /\ typecheck(SELECT-TRUE_WC, num-(I32)) /\ typecheck(SELECT-TRUE_T*?, valtype) /\ (SELECT-TRUE_WC =/= 0) .

  vars SELECT-FALSE_T*? SELECT-FALSE_VAL1 SELECT-FALSE_VAL2 SELECT-FALSE_WC T* : WasmTerminal .
  ceq Step-pure(SELECT-FALSE_VAL1 SELECT-FALSE_VAL2 CONST I32 SELECT-FALSE_WC SELECT T*, SELECT-FALSE_VAL2) = true 
      if typecheck(SELECT-FALSE_VAL1, val) /\ typecheck(SELECT-FALSE_VAL2, val) /\ typecheck(SELECT-FALSE_WC, num-(I32)) /\ typecheck(SELECT-FALSE_T*?, valtype) /\ (SELECT-FALSE_WC == 0) .

  vars IF-TRUE_BT IF-TRUE_INSTR1* IF-TRUE_INSTR2* IF-TRUE_WC : WasmTerminal .
  ceq Step-pure(CONST I32 IF-TRUE_WC w-IF IF-TRUE_BT IF-TRUE_INSTR1* ELSE IF-TRUE_INSTR2*, BLOCK IF-TRUE_BT IF-TRUE_INSTR1*) = true 
      if typecheck(IF-TRUE_WC, num-(I32)) /\ typecheck(IF-TRUE_BT, blocktype) /\ typecheck(IF-TRUE_INSTR1*, instr) /\ typecheck(IF-TRUE_INSTR2*, instr) /\ (IF-TRUE_WC =/= 0) .

  vars IF-FALSE_BT IF-FALSE_INSTR1* IF-FALSE_INSTR2* IF-FALSE_WC : WasmTerminal .
  ceq Step-pure(CONST I32 IF-FALSE_WC w-IF IF-FALSE_BT IF-FALSE_INSTR1* ELSE IF-FALSE_INSTR2*, BLOCK IF-FALSE_BT IF-FALSE_INSTR2*) = true 
      if typecheck(IF-FALSE_WC, num-(I32)) /\ typecheck(IF-FALSE_BT, blocktype) /\ typecheck(IF-FALSE_INSTR1*, instr) /\ typecheck(IF-FALSE_INSTR2*, instr) /\ (IF-FALSE_WC == 0) .

  vars LABEL-VALS_INSTR* LABEL-VALS_VAL* LABEL-VALS_WN VAL : WasmTerminal .
  ceq Step-pure(LABEL- LABEL-VALS_WN lbrace LABEL-VALS_INSTR* rbrace VAL, VAL) = true 
      if typecheck(LABEL-VALS_WN, w-n) /\ typecheck(LABEL-VALS_INSTR*, instr) /\ typecheck(LABEL-VALS_VAL*, val) .

  vars BR-LABEL-ZERO_INSTR'* BR-LABEL-ZERO_INSTR* BR-LABEL-ZERO_VAL'* BR-LABEL-ZERO_VAL* BR-LABEL-ZERO_WL BR-LABEL-ZERO_WN VAL VAL' : WasmTerminal .
  ceq Step-pure(LABEL- BR-LABEL-ZERO_WN lbrace BR-LABEL-ZERO_INSTR'* rbrace VAL' VAL BR BR-LABEL-ZERO_WL BR-LABEL-ZERO_INSTR*, VAL BR-LABEL-ZERO_INSTR'*) = true 
      if typecheck(BR-LABEL-ZERO_WN, w-n) /\ typecheck(BR-LABEL-ZERO_INSTR'*, instr) /\ typecheck(BR-LABEL-ZERO_VAL'*, val) /\ typecheck(BR-LABEL-ZERO_VAL*, val) /\ typecheck(BR-LABEL-ZERO_WL, labelidx) /\ typecheck(BR-LABEL-ZERO_INSTR*, instr) /\ (BR-LABEL-ZERO_WL == 0) .

  vars BR-LABEL-SUCC_INSTR'* BR-LABEL-SUCC_INSTR* BR-LABEL-SUCC_VAL* BR-LABEL-SUCC_WL BR-LABEL-SUCC_WN VAL : WasmTerminal .
  ceq Step-pure(LABEL- BR-LABEL-SUCC_WN lbrace BR-LABEL-SUCC_INSTR'* rbrace VAL BR BR-LABEL-SUCC_WL BR-LABEL-SUCC_INSTR*, VAL BR (BR-LABEL-SUCC_WL - 1)) = true 
      if typecheck(BR-LABEL-SUCC_WN, w-n) /\ typecheck(BR-LABEL-SUCC_INSTR'*, instr) /\ typecheck(BR-LABEL-SUCC_VAL*, val) /\ typecheck(BR-LABEL-SUCC_WL, labelidx) /\ typecheck(BR-LABEL-SUCC_INSTR*, instr) /\ (BR-LABEL-SUCC_WL > 0) .

  vars BR-HANDLER_CATCH* BR-HANDLER_INSTR* BR-HANDLER_VAL* BR-HANDLER_WL BR-HANDLER_WN VAL : WasmTerminal .
  ceq Step-pure(HANDLER- BR-HANDLER_WN lbrace BR-HANDLER_CATCH* rbrace VAL BR BR-HANDLER_WL BR-HANDLER_INSTR*, VAL BR BR-HANDLER_WL) = true 
      if typecheck(BR-HANDLER_WN, w-n) /\ typecheck(BR-HANDLER_CATCH*, catch) /\ typecheck(BR-HANDLER_VAL*, val) /\ typecheck(BR-HANDLER_WL, labelidx) /\ typecheck(BR-HANDLER_INSTR*, instr) .

  vars BR-IF-TRUE_WC BR-IF-TRUE_WL : WasmTerminal .
  ceq Step-pure(CONST I32 BR-IF-TRUE_WC BR-IF BR-IF-TRUE_WL, BR BR-IF-TRUE_WL) = true 
      if typecheck(BR-IF-TRUE_WC, num-(I32)) /\ typecheck(BR-IF-TRUE_WL, labelidx) /\ (BR-IF-TRUE_WC =/= 0) .

  vars BR-IF-FALSE_WC BR-IF-FALSE_WL : WasmTerminal .
  ceq Step-pure(CONST I32 BR-IF-FALSE_WC BR-IF BR-IF-FALSE_WL, eps) = true 
      if typecheck(BR-IF-FALSE_WC, num-(I32)) /\ typecheck(BR-IF-FALSE_WL, labelidx) /\ (BR-IF-FALSE_WC == 0) .

  vars BR-TABLE-LT_L' BR-TABLE-LT_L* BR-TABLE-LT_WI : WasmTerminal .
  ceq Step-pure(CONST I32 BR-TABLE-LT_WI BR-TABLE BR-TABLE-LT_L* BR-TABLE-LT_L', BR index(BR-TABLE-LT_L*, BR-TABLE-LT_WI)) = true 
      if typecheck(BR-TABLE-LT_WI, num-(I32)) /\ typecheck(BR-TABLE-LT_L*, labelidx) /\ typecheck(BR-TABLE-LT_L', labelidx) /\ (BR-TABLE-LT_WI < len(BR-TABLE-LT_L*)) .

