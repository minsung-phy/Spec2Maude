  ceq $unpackfield-(UNPACKFIELD_VALTYPE, eps, UNPACKFIELD_VAL) = UNPACKFIELD_VAL 
      if typecheck(UNPACKFIELD_VALTYPE, valtype) /\ typecheck(UNPACKFIELD_VAL, val) .

  vars UNPACKFIELD_PACKTYPE UNPACKFIELD_SX UNPACKFIELD_WI : WasmTerminal .
  ceq $unpackfield-(UNPACKFIELD_PACKTYPE, UNPACKFIELD_SX, PACK UNPACKFIELD_PACKTYPE UNPACKFIELD_WI) = CONST I32 $extend--($psize(UNPACKFIELD_PACKTYPE), 32, UNPACKFIELD_SX, UNPACKFIELD_WI) 
      if typecheck(UNPACKFIELD_PACKTYPE, packtype) /\ typecheck(UNPACKFIELD_SX, sx) .


