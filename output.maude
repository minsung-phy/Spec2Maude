  op _[._<-_] : SpectecTerminal Qid SpectecTerminals -> SpectecTerminal .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  op _[._=++_] : SpectecTerminal Qid SpectecTerminals -> SpectecTerminal .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  op setItem : RecordItems Qid SpectecTerminals -> RecordItems .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  op _[_<-_] : SpectecTerminals Nat SpectecTerminal -> SpectecTerminals .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
