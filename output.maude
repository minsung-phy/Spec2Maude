  op $free-deftype : WasmTerminal -> WasmTerminal .

  vars FREE_RECTYPE FREE_WN : WasmTerminal .
  ceq $free-deftype(-DEF FREE_RECTYPE FREE_WN) = $free-rectype(FREE_RECTYPE) 
