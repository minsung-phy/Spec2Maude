  --- origin: wasm-3.0/0.1-aux.vars.spectec:6.1-6.32 / script[2]/0003-TypD-m/InstD[1] / InstD
  var SCRIPT_2_0003_TYPD_M_MI1ALIAS1 : [SpectecTerminal] .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:6.1-6.32 / script[2]/0003-TypD-m/InstD[1] / InstD
  var SCRIPT_2_0003_TYPD_M_MI1WRAP1 : Nat .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:6.1-6.32 / script[2]/0003-TypD-m/InstD[1] / InstD
  op M.wrap_ : Nat ~> SpectecTerminal [ctor] .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:6.1-6.32 / script[2]/0003-TypD-m/InstD[1] / InstD
  mb M.wrap_(SCRIPT_2_0003_TYPD_M_MI1WRAP1) : SpectecTerminal .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:6.1-6.32 / script[2]/0003-TypD-m/InstD[1] / InstD
  eq typecheck(SCRIPT_2_0003_TYPD_M_MI1ALIAS1, syn-M) = typecheck(SCRIPT_2_0003_TYPD_M_MI1ALIAS1, syn-nat) .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:6.1-6.32 / script[2]/0003-TypD-m/InstD[1] / InstD
