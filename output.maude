  op $free-tabletype : WasmTerminal -> WasmTerminal .

  vars FREE_ADDRTYPE FREE_LIMITS FREE_REFTYPE : WasmTerminal .
  ceq $free-tabletype((FREE_ADDRTYPE FREE_LIMITS FREE_REFTYPE)) = ($free-addrtype(FREE_ADDRTYPE) ++ $free-reftype(FREE_REFTYPE)) 
      if typecheck(FREE_ADDRTYPE, addrtype) /\ typecheck(FREE_LIMITS, limits) /\ typecheck(FREE_REFTYPE, reftype) .


  op $free-datatype : WasmTerminal -> WasmTerminal .
  eq $free-datatype(OK) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .


  op $free-elemtype : WasmTerminal -> WasmTerminal .

  var FREE_REFTYPE : WasmTerminal .
  ceq $free-elemtype(FREE_REFTYPE) = $free-reftype(FREE_REFTYPE) 
      if typecheck(FREE_REFTYPE, reftype) .


  op $free-externtype : WasmTerminal -> WasmTerminal .

  var FREE_TAGTYPE : WasmTerminal .
  ceq $free-externtype(TAG FREE_TAGTYPE) = $free-tagtype(FREE_TAGTYPE) 
      if typecheck(FREE_TAGTYPE, tagtype) .

  var FREE_GLOBALTYPE : WasmTerminal .
  ceq $free-externtype(GLOBAL FREE_GLOBALTYPE) = $free-globaltype(FREE_GLOBALTYPE) 
      if typecheck(FREE_GLOBALTYPE, globaltype) .

  var FREE_MEMTYPE : WasmTerminal .
  ceq $free-externtype(MEM FREE_MEMTYPE) = $free-memtype(FREE_MEMTYPE) 
      if typecheck(FREE_MEMTYPE, memtype) .

  var FREE_TABLETYPE : WasmTerminal .
  ceq $free-externtype(TABLE FREE_TABLETYPE) = $free-tabletype(FREE_TABLETYPE) 
      if typecheck(FREE_TABLETYPE, tabletype) .

  var FREE_TYPEUSE : WasmTerminal .
  ceq $free-externtype(FUNC FREE_TYPEUSE) = $free-typeuse(FREE_TYPEUSE) 
      if typecheck(FREE_TYPEUSE, typeuse) .


  op $free-moduletype : WasmTerminal -> WasmTerminal .

  vars EXTERNTYPE-1 EXTERNTYPE-2 FREE_EXTERNTYPE1* FREE_EXTERNTYPE2* : WasmTerminal .
  ceq $free-moduletype(FREE_EXTERNTYPE1* arrow FREE_EXTERNTYPE2*) = ($free-list($free-externtype(EXTERNTYPE-1)) ++ $free-list($free-externtype(EXTERNTYPE-2))) 
      if typecheck(FREE_EXTERNTYPE1*, externtype) /\ typecheck(FREE_EXTERNTYPE2*, externtype) .

  op num- : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, num-(INN)) = typecheck(INN, Inn) /\ typecheck(T, iN($sizenn(INN))) .
  eq typecheck(T, num-(FNN)) = typecheck(FNN, Fnn) /\ typecheck(T, fN($sizenn(FNN))) .
  op pack- : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, pack-(PNN)) = typecheck(PNN, Pnn) /\ typecheck(T, iN($psizenn(PNN))) .
  op lane- : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, lane-(NUMTYPE)) = typecheck(NUMTYPE, numtype) /\ typecheck(T, num-(NUMTYPE)) .
  eq typecheck(T, lane-(PACKTYPE)) = typecheck(PACKTYPE, packtype) /\ typecheck(T, pack-(PACKTYPE)) .
  eq typecheck(T, lane-(JNN)) = typecheck(JNN, Jnn) /\ typecheck(T, iN($lsize(JNN))) .
  op vec- : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, vec-(VNN)) = typecheck(VNN, Vnn) /\ typecheck(T, vN($vsize(VNN))) .
