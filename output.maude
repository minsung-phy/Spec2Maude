  op Num-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _NT _WC _WS : WasmTerminal .
  ceq Num-ok(_WS, CONST _NT _WC, _NT) = true 
      if typecheck(_WS, store) /\ typecheck(_NT, numtype) /\ typecheck(_WC, num-(_NT)) .


  op Vec-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _VT _WC _WS : WasmTerminal .
  ceq Vec-ok(_WS, VCONST _VT _WC, _VT) = true 
      if typecheck(_WS, store) /\ typecheck(_VT, vectype) /\ typecheck(_WC, vec-(_VT)) .


  op Ref-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars NULL_HT NULL_HT' NULL_WS : WasmTerminal .
  ceq Ref-ok(NULL_WS, REF.NULL NULL_HT, REF NULL NULL_HT') = true 
      if typecheck(NULL_WS, store) /\ typecheck(NULL_HT, heaptype) /\ typecheck(NULL_HT', heaptype) /\ Heaptype-sub({item('TYPES, eps) ; item('RECS, eps) ; item('TAGS, eps) ; item('GLOBALS, eps) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, eps) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('RETURN, eps) ; item('REFS, eps)} NULL_HT' NULL_HT) .

