  op $free-export : WasmTerminal -> WasmTerminal .

  vars FREE_EXTERNIDX FREE_NAME : WasmTerminal .
  ceq $free-export(EXPORT FREE_NAME FREE_EXTERNIDX) = $free-externidx(FREE_EXTERNIDX) 
      if typecheck(FREE_NAME, name) /\ typecheck(FREE_EXTERNIDX, externidx) .


  op $free-module : WasmTerminal -> WasmTerminal .

  vars DATA ELEM EXPORT FREE_DATA* FREE_ELEM* FREE_EXPORT* FREE_FUNC* FREE_GLOBAL* FREE_IMPORT* FREE_MEM* FREE_START? FREE_TABLE* FREE_TAG* FREE_TYPE* FUNC GLOBAL IMPORT MEM START TABLE TAG TYPE : WasmTerminal .
  ceq $free-module(MODULE FREE_TYPE* FREE_IMPORT* FREE_TAG* FREE_GLOBAL* FREE_MEM* FREE_TABLE* FREE_FUNC* FREE_DATA* FREE_ELEM* FREE_START? FREE_EXPORT*) = (((((((((($free-list($free-type(TYPE)) ++ $free-list($free-tag(TAG))) ++ $free-list($free-global(GLOBAL))) ++ $free-list($free-mem(MEM))) ++ $free-list($free-table(TABLE))) ++ $free-list($free-func(FUNC))) ++ $free-list($free-data(DATA))) ++ $free-list($free-elem(ELEM))) ++ $free-opt($free-start(START))) ++ $free-list($free-import(IMPORT))) ++ $free-list($free-export(EXPORT))) 
      if typecheck(FREE_TYPE*, type) /\ typecheck(FREE_IMPORT*, import) /\ typecheck(FREE_TAG*, tag) /\ typecheck(FREE_GLOBAL*, global) /\ typecheck(FREE_MEM*, mem) /\ typecheck(FREE_TABLE*, table) /\ typecheck(FREE_FUNC*, func) /\ typecheck(FREE_DATA*, data) /\ typecheck(FREE_ELEM*, elem) /\ typecheck(FREE_START?, start) /\ typecheck(FREE_EXPORT*, export) .


  op $funcidx-module : WasmTerminal -> WasmTerminals .

  var FUNCIDX_MODULE : WasmTerminal .
  ceq $funcidx-module(FUNCIDX_MODULE) = value('FUNCS, $free-module(FUNCIDX_MODULE)) 
      if typecheck(FUNCIDX_MODULE, module) .


  op $dataidx-funcs : WasmTerminal -> WasmTerminals .

  vars DATAIDX_FUNC* FUNC : WasmTerminal .
  ceq $dataidx-funcs(DATAIDX_FUNC*) = value('DATAS, $free-list($free-func(FUNC))) 
      if typecheck(DATAIDX_FUNC*, func) .

  op init :  -> WasmType [ctor] .
  op SET :  -> WasmTerminal [ctor] .
  eq typecheck(SET, init) = true .
  op UNSET :  -> WasmTerminal [ctor] .
  eq typecheck(UNSET, init) = true .
  op localtype :  -> WasmType [ctor] .

  var INIT1 : WasmTerminal .
  var VALTYPE1 : WasmTerminal .
  eq typecheck(INIT1 VALTYPE1, localtype) = typecheck(INIT1, init) and typecheck(VALTYPE1, valtype) .
  op instrtype :  -> WasmType [ctor] .
  op _ arrow- _ _ : WasmTerminal WasmTerminals WasmTerminal -> WasmTerminal [ctor] .
  var RESULTTYPE1 : WasmTerminal .
  var LOCALIDX* : WasmTerminals .
  var RESULTTYPE2 : WasmTerminal .
  eq typecheck(RESULTTYPE1 arrow- LOCALIDX* RESULTTYPE2, instrtype) = typecheck(RESULTTYPE1, resulttype) and typecheck(LOCALIDX*, localidx) and typecheck(RESULTTYPE2, resulttype) .
  op context :  -> WasmType [ctor] .
  var F_TYPES_0 : WasmTerminals .
  var F_RECS_1 : WasmTerminals .
  var F_TAGS_2 : WasmTerminals .
  var F_GLOBALS_3 : WasmTerminals .
  var F_MEMS_4 : WasmTerminals .
  var F_TABLES_5 : WasmTerminals .
  var F_FUNCS_6 : WasmTerminals .
  var F_DATAS_7 : WasmTerminals .
  var F_ELEMS_8 : WasmTerminals .
  var F_LOCALS_9 : WasmTerminals .
  var F_LABELS_10 : WasmTerminals .
  var F_RETURN_11 : WasmTerminal .
  var F_REFS_12 : WasmTerminals .
  eq typecheck({item('TYPES, F_TYPES_0) ; item('RECS, F_RECS_1) ; item('TAGS, F_TAGS_2) ; item('GLOBALS, F_GLOBALS_3) ; item('MEMS, F_MEMS_4) ; item('TABLES, F_TABLES_5) ; item('FUNCS, F_FUNCS_6) ; item('DATAS, F_DATAS_7) ; item('ELEMS, F_ELEMS_8) ; item('LOCALS, F_LOCALS_9) ; item('LABELS, F_LABELS_10) ; item('RETURN, F_RETURN_11) ; item('REFS, F_REFS_12)}, context) = typecheck(F_TYPES_0, deftype) /\ typecheck(F_RECS_1, subtype) /\ typecheck(F_TAGS_2, tagtype) /\ typecheck(F_GLOBALS_3, globaltype) /\ typecheck(F_MEMS_4, memtype) /\ typecheck(F_TABLES_5, tabletype) /\ typecheck(F_FUNCS_6, deftype) /\ typecheck(F_DATAS_7, datatype) /\ typecheck(F_ELEMS_8, elemtype) /\ typecheck(F_LOCALS_9, localtype) /\ typecheck(F_LABELS_10, resulttype) /\ typecheck(F_RETURN_11, resulttype) /\ typecheck(F_REFS_12, funcidx) .

  op $with-locals : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  var WITH_WC : WasmTerminal .
  ceq $with-locals(WITH_WC, eps, eps) = WITH_WC 
      if typecheck(WITH_WC, w-C) .

  vars WITH_LCT* WITH_LCT1 WITH_WC WITH_X* WITH_X1 : WasmTerminal .
  ceq $with-locals(WITH_WC, WITH_X1 WITH_X*, WITH_LCT1 WITH_LCT*) = $with-locals(WITH_WC[.'LOCALS[WITH_X1] <- WITH_LCT1], WITH_X*, WITH_LCT*) 
      if typecheck(WITH_WC, w-C) /\ typecheck(WITH_X1, idx) /\ typecheck(WITH_X*, idx) /\ typecheck(WITH_LCT1, localtype) /\ typecheck(WITH_LCT*, localtype) .


  op $clos-deftypes : WasmTerminal -> WasmTerminals .
  eq $clos-deftypes(eps) = eps .

  vars CLOS_DT'* CLOS_DT* CLOS_DTN DT' : WasmTerminal .
  ceq $clos-deftypes(CLOS_DT* CLOS_DTN) = CLOS_DT'* $subst-all-deftype(CLOS_DTN, DT') 
      if typecheck(CLOS_DT*, deftype) /\ typecheck(CLOS_DTN, deftype) /\ typecheck(CLOS_DT'*, deftype) /\ (CLOS_DT'* == $clos-deftypes(CLOS_DT*)) .


  op $clos-valtype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars CLOS_DT* CLOS_WC CLOS_WT DT : WasmTerminal .
  ceq $clos-valtype(CLOS_WC, CLOS_WT) = $subst-all-valtype(CLOS_WT, DT) 
      if typecheck(CLOS_WC, w-C) /\ typecheck(CLOS_WT, valtype) /\ typecheck(CLOS_DT*, deftype) /\ (CLOS_DT* == $clos-deftypes(value('TYPES, CLOS_WC))) .


  op $clos-deftype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars CLOS_DT CLOS_DT'* CLOS_WC DT' : WasmTerminal .
  ceq $clos-deftype(CLOS_WC, CLOS_DT) = $subst-all-deftype(CLOS_DT, DT') 
      if typecheck(CLOS_WC, w-C) /\ typecheck(CLOS_DT, deftype) /\ typecheck(CLOS_DT'*, deftype) /\ (CLOS_DT'* == $clos-deftypes(value('TYPES, CLOS_WC))) .


  op $clos-tagtype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars CLOS_DT* CLOS_JT CLOS_WC DT : WasmTerminal .
  ceq $clos-tagtype(CLOS_WC, CLOS_JT) = $subst-all-tagtype(CLOS_JT, DT) 
      if typecheck(CLOS_WC, w-C) /\ typecheck(CLOS_JT, tagtype) /\ typecheck(CLOS_DT*, deftype) /\ (CLOS_DT* == $clos-deftypes(value('TYPES, CLOS_WC))) .


  op $clos-externtype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars CLOS_DT* CLOS_WC CLOS_XT DT : WasmTerminal .
  ceq $clos-externtype(CLOS_WC, CLOS_XT) = $subst-all-externtype(CLOS_XT, DT) 
      if typecheck(CLOS_WC, w-C) /\ typecheck(CLOS_XT, externtype) /\ typecheck(CLOS_DT*, deftype) /\ (CLOS_DT* == $clos-deftypes(value('TYPES, CLOS_WC))) .


  op $clos-moduletype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars CLOS_DT* CLOS_MMT CLOS_WC DT : WasmTerminal .
  ceq $clos-moduletype(CLOS_WC, CLOS_MMT) = $subst-all-moduletype(CLOS_MMT, DT) 
      if typecheck(CLOS_WC, w-C) /\ typecheck(CLOS_MMT, moduletype) /\ typecheck(CLOS_DT*, deftype) /\ (CLOS_DT* == $clos-deftypes(value('TYPES, CLOS_WC))) .


  op Numtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _NUMTYPE _WC : WasmTerminal .
  ceq Numtype-ok(_WC, _NUMTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_NUMTYPE, numtype) .


  op Vectype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _VECTYPE _WC : WasmTerminal .
  ceq Vectype-ok(_WC, _VECTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_VECTYPE, vectype) .

  op oktypeidx :  -> WasmType [ctor] .
  op OK _ : WasmTerminal -> WasmTerminal [ctor] .
  var TYPEIDX1 : WasmTerminal .
  eq typecheck(OK TYPEIDX1, oktypeidx) = typecheck(TYPEIDX1, typeidx) .
  op oktypeidxnat :  -> WasmType [ctor] .
  op OK _ : WasmTerminal -> WasmTerminal [ctor] .
  var TYPEIDX1 : WasmTerminal .
  eq typecheck(OK TYPEIDX1, oktypeidxnat) = typecheck(TYPEIDX1, typeidx) .

  op Packtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _PACKTYPE _WC : WasmTerminal .
  ceq Packtype-ok(_WC, _PACKTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_PACKTYPE, packtype) .


  op Packtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _PACKTYPE _WC : WasmTerminal .
  ceq Packtype-sub(_WC, _PACKTYPE, _PACKTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_PACKTYPE, packtype) .


  op Numtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _NUMTYPE _WC : WasmTerminal .
  ceq Numtype-sub(_WC, _NUMTYPE, _NUMTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_NUMTYPE, numtype) .


  op Expand : WasmTerminal WasmTerminal -> Bool .

  vars _COMPTYPE _DEFTYPE : WasmTerminal .
  ceq Expand(_DEFTYPE, _COMPTYPE) = true 
      if typecheck(_DEFTYPE, deftype) /\ typecheck(_COMPTYPE, comptype) /\ ($expanddt(_DEFTYPE) == _COMPTYPE) .


  op Vectype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _VECTYPE _WC : WasmTerminal .
  ceq Vectype-sub(_WC, _VECTYPE, _VECTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_VECTYPE, vectype) .


  op $before : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars BEFORE_DEFTYPE BEFORE_WI BEFORE_WX : WasmTerminal .
  ceq $before(BEFORE_DEFTYPE, BEFORE_WX, BEFORE_WI) = true 
      if typecheck(BEFORE_DEFTYPE, deftype) /\ typecheck(BEFORE_WX, idx) .

  vars BEFORE_TYPEIDX BEFORE_WI BEFORE_WX : WasmTerminal .
  ceq $before(-IDX BEFORE_TYPEIDX, BEFORE_WX, BEFORE_WI) = (BEFORE_TYPEIDX < BEFORE_WX) 
      if typecheck(BEFORE_TYPEIDX, typeidx) /\ typecheck(BEFORE_WX, idx) .

  vars BEFORE_WI BEFORE_WJ BEFORE_WX : WasmTerminal .
  ceq $before(REC BEFORE_WJ, BEFORE_WX, BEFORE_WI) = (BEFORE_WJ < BEFORE_WI) 
      if typecheck(BEFORE_WJ, w-n) /\ typecheck(BEFORE_WX, idx) .


  op $unrollht : WasmTerminal WasmTerminal -> WasmTerminal .

  vars UNROLLHT_DEFTYPE UNROLLHT_WC : WasmTerminal .
  ceq $unrollht(UNROLLHT_WC, UNROLLHT_DEFTYPE) = $unrolldt(UNROLLHT_DEFTYPE) 
      if typecheck(UNROLLHT_WC, w-C) /\ typecheck(UNROLLHT_DEFTYPE, deftype) .

  vars UNROLLHT_TYPEIDX UNROLLHT_WC : WasmTerminal .
  ceq $unrollht(UNROLLHT_WC, -IDX UNROLLHT_TYPEIDX) = $unrolldt(index(value('TYPES, UNROLLHT_WC), UNROLLHT_TYPEIDX)) 
      if typecheck(UNROLLHT_WC, w-C) /\ typecheck(UNROLLHT_TYPEIDX, typeidx) .

  vars UNROLLHT_WC UNROLLHT_WI : WasmTerminal .
  ceq $unrollht(UNROLLHT_WC, REC UNROLLHT_WI) = index(value('RECS, UNROLLHT_WC), UNROLLHT_WI) 
      if typecheck(UNROLLHT_WC, w-C) /\ typecheck(UNROLLHT_WI, w-n) .


  op Heaptype-ok : WasmTerminal WasmTerminal -> Bool .

  vars ABS_ABSHEAPTYPE ABS_WC : WasmTerminal .
  ceq Heaptype-ok(ABS_WC, ABS_ABSHEAPTYPE) = true 
      if typecheck(ABS_WC, w-C) /\ typecheck(ABS_ABSHEAPTYPE, absheaptype) .

  vars TYPEUSE_TYPEUSE TYPEUSE_WC : WasmTerminal .
  ceq Heaptype-ok(TYPEUSE_WC, TYPEUSE_TYPEUSE) = true 
      if typecheck(TYPEUSE_WC, w-C) /\ typecheck(TYPEUSE_TYPEUSE, typeuse) /\ Typeuse-ok(TYPEUSE_WC TYPEUSE_TYPEUSE) .


  op Reftype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _HEAPTYPE _WC : WasmTerminal .
  ceq Reftype-ok(_WC, REF NULL _HEAPTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_HEAPTYPE, heaptype) /\ Heaptype-ok(_WC _HEAPTYPE) .


  op Valtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars NUM_NUMTYPE NUM_WC : WasmTerminal .
  ceq Valtype-ok(NUM_WC, NUM_NUMTYPE) = true 
      if typecheck(NUM_WC, w-C) /\ typecheck(NUM_NUMTYPE, numtype) /\ Numtype-ok(NUM_WC NUM_NUMTYPE) .

  vars VEC_VECTYPE VEC_WC : WasmTerminal .
  ceq Valtype-ok(VEC_WC, VEC_VECTYPE) = true 
      if typecheck(VEC_WC, w-C) /\ typecheck(VEC_VECTYPE, vectype) /\ Vectype-ok(VEC_WC VEC_VECTYPE) .

  vars REF_REFTYPE REF_WC : WasmTerminal .
  ceq Valtype-ok(REF_WC, REF_REFTYPE) = true 
      if typecheck(REF_WC, w-C) /\ typecheck(REF_REFTYPE, reftype) /\ Reftype-ok(REF_WC REF_REFTYPE) .

  var BOT_WC : WasmTerminal .
  ceq Valtype-ok(BOT_WC, BOT) = true 
      if typecheck(BOT_WC, w-C) .


  op Typeuse-ok : WasmTerminal WasmTerminal -> Bool .

  vars TYPEIDX_DT TYPEIDX_TYPEIDX TYPEIDX_WC : WasmTerminal .
  ceq Typeuse-ok(TYPEIDX_WC, -IDX TYPEIDX_TYPEIDX) = true 
      if typecheck(TYPEIDX_WC, w-C) /\ typecheck(TYPEIDX_TYPEIDX, typeidx) /\ typecheck(TYPEIDX_DT, deftype) /\ (index(value('TYPES, TYPEIDX_WC), TYPEIDX_TYPEIDX) == TYPEIDX_DT) .

  vars REC_ST REC_WC REC_WI : WasmTerminal .
  ceq Typeuse-ok(REC_WC, REC REC_WI) = true 
      if typecheck(REC_WC, w-C) /\ typecheck(REC_WI, w-n) /\ typecheck(REC_ST, subtype) /\ (index(value('RECS, REC_WC), REC_WI) == REC_ST) .

  vars DEFTYPE_DEFTYPE DEFTYPE_WC : WasmTerminal .
  ceq Typeuse-ok(DEFTYPE_WC, DEFTYPE_DEFTYPE) = true 
      if typecheck(DEFTYPE_WC, w-C) /\ typecheck(DEFTYPE_DEFTYPE, deftype) /\ Deftype-ok(DEFTYPE_WC DEFTYPE_DEFTYPE) .


  op Resulttype-ok : WasmTerminal WasmTerminal -> Bool .

  vars W-T _T* _WC : WasmTerminal .
  ceq Resulttype-ok(_WC, _T*) = true 
      if typecheck(_WC, w-C) /\ typecheck(_T*, valtype) /\ Valtype-ok(_WC W-T) .


  op Fieldtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _STORAGETYPE _WC : WasmTerminal .
  ceq Fieldtype-ok(_WC, (MUT _STORAGETYPE)) = true 
      if typecheck(_WC, w-C) /\ typecheck(_STORAGETYPE, storagetype) /\ Storagetype-ok(_WC _STORAGETYPE) .


  op Storagetype-ok : WasmTerminal WasmTerminal -> Bool .

  vars VAL_VALTYPE VAL_WC : WasmTerminal .
  ceq Storagetype-ok(VAL_WC, VAL_VALTYPE) = true 
      if typecheck(VAL_WC, w-C) /\ typecheck(VAL_VALTYPE, valtype) /\ Valtype-ok(VAL_WC VAL_VALTYPE) .

  vars PACK_PACKTYPE PACK_WC : WasmTerminal .
  ceq Storagetype-ok(PACK_WC, PACK_PACKTYPE) = true 
      if typecheck(PACK_WC, w-C) /\ typecheck(PACK_PACKTYPE, packtype) /\ Packtype-ok(PACK_WC PACK_PACKTYPE) .


  op Comptype-ok : WasmTerminal WasmTerminal -> Bool .

  vars FIELDTYPE STRUCT_FIELDTYPE* STRUCT_WC : WasmTerminal .
  ceq Comptype-ok(STRUCT_WC, STRUCT STRUCT_FIELDTYPE*) = true 
      if typecheck(STRUCT_WC, w-C) /\ typecheck(STRUCT_FIELDTYPE*, fieldtype) /\ Fieldtype-ok(STRUCT_WC FIELDTYPE) .

  vars ARRAY_FIELDTYPE ARRAY_WC : WasmTerminal .
  ceq Comptype-ok(ARRAY_WC, ARRAY ARRAY_FIELDTYPE) = true 
      if typecheck(ARRAY_WC, w-C) /\ typecheck(ARRAY_FIELDTYPE, fieldtype) /\ Fieldtype-ok(ARRAY_WC ARRAY_FIELDTYPE) .

  vars FUNC_T1* FUNC_T2* FUNC_WC : WasmTerminal .
  ceq Comptype-ok(FUNC_WC, FUNC FUNC_T1* arrow FUNC_T2*) = true 
      if typecheck(FUNC_WC, w-C) /\ typecheck(FUNC_T1*, valtype) /\ typecheck(FUNC_T2*, valtype) /\ Resulttype-ok(FUNC_WC FUNC_T1*) /\ Resulttype-ok(FUNC_WC FUNC_T2*) .


  op Subtype-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars COMPTYPE' W-X X' _COMPTYPE _COMPTYPE'* _WC _X'** _X* _X0 : WasmTerminal .
  ceq Subtype-ok(_WC, SUB FINAL -IDX W-X _COMPTYPE, OK _X0) = true 
      if typecheck(_WC, w-C) /\ typecheck(_X*, idx) /\ typecheck(_COMPTYPE, comptype) /\ typecheck(_X0, idx) /\ typecheck(_X'**, idx) /\ typecheck(_COMPTYPE'*, comptype) /\ (len(_X*) <= 1) /\ (W-X < _X0) /\ ($unrolldt(index(value('TYPES, _WC), W-X)) == SUB eps -IDX X' COMPTYPE') /\ Comptype-ok(_WC _COMPTYPE) /\ Comptype-sub(_WC _COMPTYPE COMPTYPE') .


  op Rectype-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars EMPTY_WC EMPTY_WX : WasmTerminal .
  ceq Rectype-ok(EMPTY_WC, REC eps, OK EMPTY_WX) = true 
      if typecheck(EMPTY_WC, w-C) /\ typecheck(EMPTY_WX, idx) .

  vars CONS_SUBTYPE* CONS_SUBTYPE1 CONS_WC CONS_WX : WasmTerminal .
  ceq Rectype-ok(CONS_WC, REC CONS_SUBTYPE1 CONS_SUBTYPE*, OK CONS_WX) = true 
      if typecheck(CONS_WC, w-C) /\ typecheck(CONS_SUBTYPE1, subtype) /\ typecheck(CONS_SUBTYPE*, subtype) /\ typecheck(CONS_WX, idx) /\ Subtype-ok(CONS_WC CONS_SUBTYPE1 OK CONS_WX) /\ Rectype-ok(CONS_WC REC CONS_SUBTYPE* OK (CONS_WX + 1)) .

  vars -REC2_SUBTYPE* -REC2_WC -REC2_WX : WasmTerminal .
  ceq Rectype-ok(-REC2_WC, REC -REC2_SUBTYPE*, OK -REC2_WX) = true 
      if typecheck(-REC2_WC, w-C) /\ typecheck(-REC2_SUBTYPE*, subtype) /\ typecheck(-REC2_WX, idx) /\ Rectype-ok2(({item('TYPES, eps) ; item('RECS, -REC2_SUBTYPE*) ; item('TAGS, eps) ; item('GLOBALS, eps) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, eps) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('RETURN, eps) ; item('REFS, eps)} ++ -REC2_WC) REC -REC2_SUBTYPE* OK -REC2_WX 0) .


  op Subtype-ok2 : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars COMPTYPE' TYPEUSE TYPEUSE'* _COMPTTYPE _COMPTYPE _COMPTYPE'* _TYPEUSE'** _TYPEUSE* _WC _WI _WX : WasmTerminal .
  ceq Subtype-ok2(_WC, SUB FINAL _TYPEUSE* _COMPTTYPE, OK _WX _WI) = true 
      if typecheck(_WC, w-C) /\ typecheck(_TYPEUSE*, typeuse) /\ typecheck(_COMPTTYPE, comptype) /\ typecheck(_WX, idx) /\ typecheck(_TYPEUSE'**, typeuse) /\ typecheck(_COMPTYPE'*, comptype) /\ typecheck(_COMPTYPE, comptype) /\ (len(_TYPEUSE*) <= 1) /\ $before(TYPEUSE, _WX, _WI) /\ ($unrollht(_WC, TYPEUSE) == SUB eps TYPEUSE'* COMPTYPE') /\ Comptype-ok(_WC _COMPTYPE) /\ Comptype-sub(_WC _COMPTYPE COMPTYPE') .


  op Rectype-ok2 : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars EMPTY_WC EMPTY_WI EMPTY_WX : WasmTerminal .
  ceq Rectype-ok2(EMPTY_WC, REC eps, OK EMPTY_WX EMPTY_WI) = true 
      if typecheck(EMPTY_WC, w-C) /\ typecheck(EMPTY_WX, idx) .

  vars CONS_SUBTYPE* CONS_SUBTYPE1 CONS_WC CONS_WI CONS_WX : WasmTerminal .
  ceq Rectype-ok2(CONS_WC, REC CONS_SUBTYPE1 CONS_SUBTYPE*, OK CONS_WX CONS_WI) = true 
      if typecheck(CONS_WC, w-C) /\ typecheck(CONS_SUBTYPE1, subtype) /\ typecheck(CONS_SUBTYPE*, subtype) /\ typecheck(CONS_WX, idx) /\ Subtype-ok2(CONS_WC CONS_SUBTYPE1 OK CONS_WX CONS_WI) /\ Rectype-ok2(CONS_WC REC CONS_SUBTYPE* OK (CONS_WX + 1) (CONS_WI + 1)) .


  op Deftype-ok : WasmTerminal WasmTerminal -> Bool .

  vars SUBTYPE _RECTYPE _SUBTYPE* _WC _WI _WN _WX : WasmTerminal .
  ceq Deftype-ok(_WC, -DEF _RECTYPE _WI) = true 
      if typecheck(_WC, w-C) /\ typecheck(_RECTYPE, rectype) /\ typecheck(_WI, w-n) /\ typecheck(_WX, idx) /\ typecheck(_SUBTYPE*, subtype) /\ typecheck(_WN, w-n) /\ Rectype-ok(_WC _RECTYPE OK _WX) /\ (_RECTYPE == REC SUBTYPE) /\ (_WI < _WN) .


  op Comptype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars FT-1 FT-2 STRUCT_FT'1* STRUCT_FT1* STRUCT_FT2* STRUCT_WC : WasmTerminal .
  ceq Comptype-sub(STRUCT_WC, STRUCT STRUCT_FT1* STRUCT_FT'1*, STRUCT STRUCT_FT2*) = true 
      if typecheck(STRUCT_WC, w-C) /\ typecheck(STRUCT_FT1*, fieldtype) /\ typecheck(STRUCT_FT'1*, fieldtype) /\ typecheck(STRUCT_FT2*, fieldtype) /\ Fieldtype-sub(STRUCT_WC FT-1 FT-2) .

  vars ARRAY_FT1 ARRAY_FT2 ARRAY_WC : WasmTerminal .
  ceq Comptype-sub(ARRAY_WC, ARRAY ARRAY_FT1, ARRAY ARRAY_FT2) = true 
      if typecheck(ARRAY_WC, w-C) /\ typecheck(ARRAY_FT1, fieldtype) /\ typecheck(ARRAY_FT2, fieldtype) /\ Fieldtype-sub(ARRAY_WC ARRAY_FT1 ARRAY_FT2) .

  vars FUNC_T11* FUNC_T12* FUNC_T21* FUNC_T22* FUNC_WC : WasmTerminal .
  ceq Comptype-sub(FUNC_WC, FUNC FUNC_T11* arrow FUNC_T12*, FUNC FUNC_T21* arrow FUNC_T22*) = true 
      if typecheck(FUNC_WC, w-C) /\ typecheck(FUNC_T11*, valtype) /\ typecheck(FUNC_T12*, valtype) /\ typecheck(FUNC_T21*, valtype) /\ typecheck(FUNC_T22*, valtype) /\ Resulttype-sub(FUNC_WC FUNC_T21* FUNC_T11*) /\ Resulttype-sub(FUNC_WC FUNC_T12* FUNC_T22*) .


  op Deftype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars REFL_DEFTYPE1 REFL_DEFTYPE2 REFL_WC : WasmTerminal .
  ceq Deftype-sub(REFL_WC, REFL_DEFTYPE1, REFL_DEFTYPE2) = true 
      if typecheck(REFL_WC, w-C) /\ typecheck(REFL_DEFTYPE1, deftype) /\ typecheck(REFL_DEFTYPE2, deftype) /\ ($clos-deftype(REFL_WC, REFL_DEFTYPE1) == $clos-deftype(REFL_WC, REFL_DEFTYPE2)) .

  vars SUPER_CT SUPER_DEFTYPE1 SUPER_DEFTYPE2 SUPER_FINAL? SUPER_TYPEUSE* SUPER_WC SUPER_WI : WasmTerminal .
  ceq Deftype-sub(SUPER_WC, SUPER_DEFTYPE1, SUPER_DEFTYPE2) = true 
      if typecheck(SUPER_WC, w-C) /\ typecheck(SUPER_DEFTYPE1, deftype) /\ typecheck(SUPER_DEFTYPE2, deftype) /\ typecheck(SUPER_FINAL?, final) /\ typecheck(SUPER_TYPEUSE*, typeuse) /\ typecheck(SUPER_CT, comptype) /\ ($unrolldt(SUPER_DEFTYPE1) == SUB SUPER_FINAL? SUPER_TYPEUSE* SUPER_CT) /\ Heaptype-sub(SUPER_WC index(SUPER_TYPEUSE*, SUPER_WI) SUPER_DEFTYPE2) .


  op Heaptype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars REFL_HEAPTYPE REFL_WC : WasmTerminal .
  ceq Heaptype-sub(REFL_WC, REFL_HEAPTYPE, REFL_HEAPTYPE) = true 
      if typecheck(REFL_WC, w-C) /\ typecheck(REFL_HEAPTYPE, heaptype) .

  vars TRANS_HEAPTYPE' TRANS_HEAPTYPE1 TRANS_HEAPTYPE2 TRANS_WC : WasmTerminal .
  ceq Heaptype-sub(TRANS_WC, TRANS_HEAPTYPE1, TRANS_HEAPTYPE2) = true 
      if typecheck(TRANS_WC, w-C) /\ typecheck(TRANS_HEAPTYPE1, heaptype) /\ typecheck(TRANS_HEAPTYPE2, heaptype) /\ typecheck(TRANS_HEAPTYPE', heaptype) /\ Heaptype-ok(TRANS_WC TRANS_HEAPTYPE') /\ Heaptype-sub(TRANS_WC TRANS_HEAPTYPE1 TRANS_HEAPTYPE') /\ Heaptype-sub(TRANS_WC TRANS_HEAPTYPE' TRANS_HEAPTYPE2) .

  var EQ-ANY_WC : WasmTerminal .
  ceq Heaptype-sub(EQ-ANY_WC, w-EQ, ANY) = true 
      if typecheck(EQ-ANY_WC, w-C) .

  var I31-EQ_WC : WasmTerminal .
  ceq Heaptype-sub(I31-EQ_WC, I31, w-EQ) = true 
      if typecheck(I31-EQ_WC, w-C) .

  var STRUCT-EQ_WC : WasmTerminal .
  ceq Heaptype-sub(STRUCT-EQ_WC, STRUCT, w-EQ) = true 
      if typecheck(STRUCT-EQ_WC, w-C) .

  var ARRAY-EQ_WC : WasmTerminal .
  ceq Heaptype-sub(ARRAY-EQ_WC, ARRAY, w-EQ) = true 
      if typecheck(ARRAY-EQ_WC, w-C) .

  vars STRUCT_DEFTYPE STRUCT_FIELDTYPE* STRUCT_WC : WasmTerminal .
  ceq Heaptype-sub(STRUCT_WC, STRUCT_DEFTYPE, STRUCT) = true 
      if typecheck(STRUCT_WC, w-C) /\ typecheck(STRUCT_DEFTYPE, deftype) /\ typecheck(STRUCT_FIELDTYPE*, fieldtype) /\ Expand(STRUCT_DEFTYPE STRUCT STRUCT_FIELDTYPE*) .

  vars ARRAY_DEFTYPE ARRAY_FIELDTYPE ARRAY_WC : WasmTerminal .
  ceq Heaptype-sub(ARRAY_WC, ARRAY_DEFTYPE, ARRAY) = true 
      if typecheck(ARRAY_WC, w-C) /\ typecheck(ARRAY_DEFTYPE, deftype) /\ typecheck(ARRAY_FIELDTYPE, fieldtype) /\ Expand(ARRAY_DEFTYPE ARRAY ARRAY_FIELDTYPE) .

  vars FUNC_DEFTYPE FUNC_T1* FUNC_T2* FUNC_WC : WasmTerminal .
  ceq Heaptype-sub(FUNC_WC, FUNC_DEFTYPE, FUNC) = true 
      if typecheck(FUNC_WC, w-C) /\ typecheck(FUNC_DEFTYPE, deftype) /\ typecheck(FUNC_T1*, valtype) /\ typecheck(FUNC_T2*, valtype) /\ Expand(FUNC_DEFTYPE FUNC FUNC_T1* arrow FUNC_T2*) .

  vars DEF_DEFTYPE1 DEF_DEFTYPE2 DEF_WC : WasmTerminal .
  ceq Heaptype-sub(DEF_WC, DEF_DEFTYPE1, DEF_DEFTYPE2) = true 
      if typecheck(DEF_WC, w-C) /\ typecheck(DEF_DEFTYPE1, deftype) /\ typecheck(DEF_DEFTYPE2, deftype) /\ Deftype-sub(DEF_WC DEF_DEFTYPE1 DEF_DEFTYPE2) .

  vars TYPEIDX-L_HEAPTYPE TYPEIDX-L_TYPEIDX TYPEIDX-L_WC : WasmTerminal .
  ceq Heaptype-sub(TYPEIDX-L_WC, -IDX TYPEIDX-L_TYPEIDX, TYPEIDX-L_HEAPTYPE) = true 
      if typecheck(TYPEIDX-L_WC, w-C) /\ typecheck(TYPEIDX-L_TYPEIDX, typeidx) /\ typecheck(TYPEIDX-L_HEAPTYPE, heaptype) /\ Heaptype-sub(TYPEIDX-L_WC index(value('TYPES, TYPEIDX-L_WC), TYPEIDX-L_TYPEIDX) TYPEIDX-L_HEAPTYPE) .

  vars TYPEIDX-R_HEAPTYPE TYPEIDX-R_TYPEIDX TYPEIDX-R_WC : WasmTerminal .
  ceq Heaptype-sub(TYPEIDX-R_WC, TYPEIDX-R_HEAPTYPE, -IDX TYPEIDX-R_TYPEIDX) = true 
      if typecheck(TYPEIDX-R_WC, w-C) /\ typecheck(TYPEIDX-R_HEAPTYPE, heaptype) /\ typecheck(TYPEIDX-R_TYPEIDX, typeidx) /\ Heaptype-sub(TYPEIDX-R_WC TYPEIDX-R_HEAPTYPE index(value('TYPES, TYPEIDX-R_WC), TYPEIDX-R_TYPEIDX)) .

  vars REC_CT REC_FINAL? REC_TYPEUSE* REC_WC REC_WI REC_WJ : WasmTerminal .
  ceq Heaptype-sub(REC_WC, REC REC_WI, index(REC_TYPEUSE*, REC_WJ)) = true 
      if typecheck(REC_WC, w-C) /\ typecheck(REC_WI, w-n) /\ typecheck(REC_TYPEUSE*, typeuse) /\ typecheck(REC_FINAL?, final) /\ typecheck(REC_CT, comptype) /\ (index(value('RECS, REC_WC), REC_WI) == SUB REC_FINAL? REC_TYPEUSE* REC_CT) .

  vars NONE_HEAPTYPE NONE_WC : WasmTerminal .
  ceq Heaptype-sub(NONE_WC, NONE, NONE_HEAPTYPE) = true 
      if typecheck(NONE_WC, w-C) /\ typecheck(NONE_HEAPTYPE, heaptype) /\ Heaptype-sub(NONE_WC NONE_HEAPTYPE ANY) .

  vars NOFUNC_HEAPTYPE NOFUNC_WC : WasmTerminal .
  ceq Heaptype-sub(NOFUNC_WC, NOFUNC, NOFUNC_HEAPTYPE) = true 
      if typecheck(NOFUNC_WC, w-C) /\ typecheck(NOFUNC_HEAPTYPE, heaptype) /\ Heaptype-sub(NOFUNC_WC NOFUNC_HEAPTYPE FUNC) .

  vars NOEXN_HEAPTYPE NOEXN_WC : WasmTerminal .
  ceq Heaptype-sub(NOEXN_WC, NOEXN, NOEXN_HEAPTYPE) = true 
      if typecheck(NOEXN_WC, w-C) /\ typecheck(NOEXN_HEAPTYPE, heaptype) /\ Heaptype-sub(NOEXN_WC NOEXN_HEAPTYPE EXN) .

  vars NOEXTERN_HEAPTYPE NOEXTERN_WC : WasmTerminal .
  ceq Heaptype-sub(NOEXTERN_WC, NOEXTERN, NOEXTERN_HEAPTYPE) = true 
      if typecheck(NOEXTERN_WC, w-C) /\ typecheck(NOEXTERN_HEAPTYPE, heaptype) /\ Heaptype-sub(NOEXTERN_WC NOEXTERN_HEAPTYPE EXTERN) .

  vars BOT_HEAPTYPE BOT_WC : WasmTerminal .
  ceq Heaptype-sub(BOT_WC, BOT, BOT_HEAPTYPE) = true 
      if typecheck(BOT_WC, w-C) /\ typecheck(BOT_HEAPTYPE, heaptype) .


  op Reftype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars NONNULL_HT1 NONNULL_HT2 NONNULL_WC : WasmTerminal .
  ceq Reftype-sub(NONNULL_WC, REF eps NONNULL_HT1, REF eps NONNULL_HT2) = true 
      if typecheck(NONNULL_WC, w-C) /\ typecheck(NONNULL_HT1, heaptype) /\ typecheck(NONNULL_HT2, heaptype) /\ Heaptype-sub(NONNULL_WC NONNULL_HT1 NONNULL_HT2) .

  vars NULL_HT1 NULL_HT2 NULL_WC : WasmTerminal .
  ceq Reftype-sub(NULL_WC, REF NULL NULL_HT1, REF NULL NULL_HT2) = true 
      if typecheck(NULL_WC, w-C) /\ typecheck(NULL_HT1, heaptype) /\ typecheck(NULL_HT2, heaptype) /\ Heaptype-sub(NULL_WC NULL_HT1 NULL_HT2) .


  op Valtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars NUM_NUMTYPE1 NUM_NUMTYPE2 NUM_WC : WasmTerminal .
  ceq Valtype-sub(NUM_WC, NUM_NUMTYPE1, NUM_NUMTYPE2) = true 
      if typecheck(NUM_WC, w-C) /\ typecheck(NUM_NUMTYPE1, numtype) /\ typecheck(NUM_NUMTYPE2, numtype) /\ Numtype-sub(NUM_WC NUM_NUMTYPE1 NUM_NUMTYPE2) .

  vars VEC_VECTYPE1 VEC_VECTYPE2 VEC_WC : WasmTerminal .
  ceq Valtype-sub(VEC_WC, VEC_VECTYPE1, VEC_VECTYPE2) = true 
      if typecheck(VEC_WC, w-C) /\ typecheck(VEC_VECTYPE1, vectype) /\ typecheck(VEC_VECTYPE2, vectype) /\ Vectype-sub(VEC_WC VEC_VECTYPE1 VEC_VECTYPE2) .

  vars REF_REFTYPE1 REF_REFTYPE2 REF_WC : WasmTerminal .
  ceq Valtype-sub(REF_WC, REF_REFTYPE1, REF_REFTYPE2) = true 
      if typecheck(REF_WC, w-C) /\ typecheck(REF_REFTYPE1, reftype) /\ typecheck(REF_REFTYPE2, reftype) /\ Reftype-sub(REF_WC REF_REFTYPE1 REF_REFTYPE2) .

  vars BOT_VALTYPE BOT_WC : WasmTerminal .
  ceq Valtype-sub(BOT_WC, BOT, BOT_VALTYPE) = true 
      if typecheck(BOT_WC, w-C) /\ typecheck(BOT_VALTYPE, valtype) .


  op Resulttype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars T-1 T-2 _T1* _T2* _WC : WasmTerminal .
  ceq Resulttype-sub(_WC, _T1*, _T2*) = true 
      if typecheck(_WC, w-C) /\ typecheck(_T1*, valtype) /\ typecheck(_T2*, valtype) /\ Valtype-sub(_WC T-1 T-2) .


  op Storagetype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars VAL_VALTYPE1 VAL_VALTYPE2 VAL_WC : WasmTerminal .
  ceq Storagetype-sub(VAL_WC, VAL_VALTYPE1, VAL_VALTYPE2) = true 
      if typecheck(VAL_WC, w-C) /\ typecheck(VAL_VALTYPE1, valtype) /\ typecheck(VAL_VALTYPE2, valtype) /\ Valtype-sub(VAL_WC VAL_VALTYPE1 VAL_VALTYPE2) .

  vars PACK_PACKTYPE1 PACK_PACKTYPE2 PACK_WC : WasmTerminal .
  ceq Storagetype-sub(PACK_WC, PACK_PACKTYPE1, PACK_PACKTYPE2) = true 
      if typecheck(PACK_WC, w-C) /\ typecheck(PACK_PACKTYPE1, packtype) /\ typecheck(PACK_PACKTYPE2, packtype) /\ Packtype-sub(PACK_WC PACK_PACKTYPE1 PACK_PACKTYPE2) .


  op Fieldtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars CONST_WC CONST_ZT1 CONST_ZT2 : WasmTerminal .
  ceq Fieldtype-sub(CONST_WC, (eps CONST_ZT1), (eps CONST_ZT2)) = true 
      if typecheck(CONST_WC, w-C) /\ typecheck(CONST_ZT1, storagetype) /\ typecheck(CONST_ZT2, storagetype) /\ Storagetype-sub(CONST_WC CONST_ZT1 CONST_ZT2) .

  vars W-VAR_WC W-VAR_ZT1 W-VAR_ZT2 : WasmTerminal .
  ceq Fieldtype-sub(W-VAR_WC, (MUT W-VAR_ZT1), (MUT W-VAR_ZT2)) = true 
      if typecheck(W-VAR_WC, w-C) /\ typecheck(W-VAR_ZT1, storagetype) /\ typecheck(W-VAR_ZT2, storagetype) /\ Storagetype-sub(W-VAR_WC W-VAR_ZT1 W-VAR_ZT2) /\ Storagetype-sub(W-VAR_WC W-VAR_ZT2 W-VAR_ZT1) .


  op Instrtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars LCT W-X _LCT* _T1* _T2* _WC _X* : WasmTerminal .
  ceq Instrtype-ok(_WC, _T1* arrow- _X* _T2*) = true 
      if typecheck(_WC, w-C) /\ typecheck(_T1*, valtype) /\ typecheck(_X*, idx) /\ typecheck(_T2*, valtype) /\ typecheck(_LCT*, localtype) /\ Resulttype-ok(_WC _T1*) /\ Resulttype-ok(_WC _T2*) /\ (index(value('LOCALS, _WC), W-X) == LCT) .


  op Expand-use : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars DEFTYPE_COMPTYPE DEFTYPE_DEFTYPE DEFTYPE_WC : WasmTerminal .
  ceq Expand-use(DEFTYPE_DEFTYPE, DEFTYPE_WC, DEFTYPE_COMPTYPE) = true 
      if typecheck(DEFTYPE_DEFTYPE, deftype) /\ typecheck(DEFTYPE_WC, w-C) /\ typecheck(DEFTYPE_COMPTYPE, comptype) /\ Expand(DEFTYPE_DEFTYPE DEFTYPE_COMPTYPE) .

  vars TYPEIDX_COMPTYPE TYPEIDX_TYPEIDX TYPEIDX_WC : WasmTerminal .
  ceq Expand-use(-IDX TYPEIDX_TYPEIDX, TYPEIDX_WC, TYPEIDX_COMPTYPE) = true 
      if typecheck(TYPEIDX_TYPEIDX, typeidx) /\ typecheck(TYPEIDX_WC, w-C) /\ typecheck(TYPEIDX_COMPTYPE, comptype) /\ Expand(index(value('TYPES, TYPEIDX_WC), TYPEIDX_TYPEIDX) TYPEIDX_COMPTYPE) .


  op Limits-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars W-M _M? _WC _WK _WN : WasmTerminal .
  ceq Limits-ok(_WC, lbrack _WN dotdot W-M rbrack, _WK) = true 
      if typecheck(_WC, w-C) /\ typecheck(_WN, w-n) /\ typecheck(_M?, w-m) /\ (_WN <= _WK) /\ ((_WN <= W-M) and (W-M <= _WK)) .


  op Tagtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _T1* _T2* _TYPEUSE _WC : WasmTerminal .
  ceq Tagtype-ok(_WC, _TYPEUSE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_TYPEUSE, typeuse) /\ typecheck(_T1*, valtype) /\ typecheck(_T2*, valtype) /\ Typeuse-ok(_WC _TYPEUSE) /\ Expand-use(_TYPEUSE _WC FUNC _T1* arrow _T2*) .


  op Globaltype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _WC _WT : WasmTerminal .
  ceq Globaltype-ok(_WC, (MUT _WT)) = true 
      if typecheck(_WC, w-C) /\ typecheck(_WT, valtype) /\ Valtype-ok(_WC _WT) .


  op Memtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _ADDRTYPE _LIMITS _WC : WasmTerminal .
  ceq Memtype-ok(_WC, _ADDRTYPE _LIMITS PAGE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_ADDRTYPE, addrtype) /\ typecheck(_LIMITS, limits) /\ Limits-ok(_WC _LIMITS (2 ^ ($size(_ADDRTYPE) - 16))) .


  op Tabletype-ok : WasmTerminal WasmTerminal -> Bool .

  vars _ADDRTYPE _LIMITS _REFTYPE _WC : WasmTerminal .
  ceq Tabletype-ok(_WC, (_ADDRTYPE _LIMITS _REFTYPE)) = true 
      if typecheck(_WC, w-C) /\ typecheck(_ADDRTYPE, addrtype) /\ typecheck(_LIMITS, limits) /\ typecheck(_REFTYPE, reftype) /\ Limits-ok(_WC _LIMITS ((2 ^ $size(_ADDRTYPE)) - 1)) /\ Reftype-ok(_WC _REFTYPE) .


  op Externtype-ok : WasmTerminal WasmTerminal -> Bool .

  vars TAG_TAGTYPE TAG_WC : WasmTerminal .
  ceq Externtype-ok(TAG_WC, TAG TAG_TAGTYPE) = true 
      if typecheck(TAG_WC, w-C) /\ typecheck(TAG_TAGTYPE, tagtype) /\ Tagtype-ok(TAG_WC TAG_TAGTYPE) .

  vars GLOBAL_GLOBALTYPE GLOBAL_WC : WasmTerminal .
  ceq Externtype-ok(GLOBAL_WC, GLOBAL GLOBAL_GLOBALTYPE) = true 
      if typecheck(GLOBAL_WC, w-C) /\ typecheck(GLOBAL_GLOBALTYPE, globaltype) /\ Globaltype-ok(GLOBAL_WC GLOBAL_GLOBALTYPE) .

  vars MEM_MEMTYPE MEM_WC : WasmTerminal .
  ceq Externtype-ok(MEM_WC, MEM MEM_MEMTYPE) = true 
      if typecheck(MEM_WC, w-C) /\ typecheck(MEM_MEMTYPE, memtype) /\ Memtype-ok(MEM_WC MEM_MEMTYPE) .

  vars TABLE_TABLETYPE TABLE_WC : WasmTerminal .
  ceq Externtype-ok(TABLE_WC, TABLE TABLE_TABLETYPE) = true 
      if typecheck(TABLE_WC, w-C) /\ typecheck(TABLE_TABLETYPE, tabletype) /\ Tabletype-ok(TABLE_WC TABLE_TABLETYPE) .

  vars FUNC_T1* FUNC_T2* FUNC_TYPEUSE FUNC_WC : WasmTerminal .
  ceq Externtype-ok(FUNC_WC, FUNC FUNC_TYPEUSE) = true 
      if typecheck(FUNC_WC, w-C) /\ typecheck(FUNC_TYPEUSE, typeuse) /\ typecheck(FUNC_T1*, valtype) /\ typecheck(FUNC_T2*, valtype) /\ Typeuse-ok(FUNC_WC FUNC_TYPEUSE) /\ Expand-use(FUNC_TYPEUSE FUNC_WC FUNC FUNC_T1* arrow FUNC_T2*) .


  op Instrtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars W-T W-X _T* _T11* _T12* _T21* _T22* _WC _X* _X1* _X2* : WasmTerminal .
  ceq Instrtype-sub(_WC, _T11* arrow- _X1* _T12*, _T21* arrow- _X2* _T22*) = true 
      if typecheck(_WC, w-C) /\ typecheck(_T11*, valtype) /\ typecheck(_X1*, idx) /\ typecheck(_T12*, valtype) /\ typecheck(_T21*, valtype) /\ typecheck(_X2*, idx) /\ typecheck(_T22*, valtype) /\ typecheck(_X*, idx) /\ typecheck(_T*, valtype) /\ Resulttype-sub(_WC _T21* _T11*) /\ Resulttype-sub(_WC _T12* _T22*) /\ (_X* == $setminus-(eps, _X2*, _X1*)) /\ (index(value('LOCALS, _WC), W-X) == (SET W-T)) .


  op Limits-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars M-2 MAX_M1 MAX_M2? MAX_N1 MAX_N2 MAX_WC : WasmTerminal .
  ceq Limits-sub(MAX_WC, lbrack MAX_N1 dotdot MAX_M1 rbrack, lbrack MAX_N2 dotdot M-2 rbrack) = true 
      if typecheck(MAX_WC, w-C) /\ typecheck(MAX_N1, w-n) /\ typecheck(MAX_M1, w-m) /\ typecheck(MAX_N2, w-n) /\ typecheck(MAX_M2?, w-m) /\ (MAX_N1 >= MAX_N2) /\ (MAX_M1 <= M-2) .

  vars EPS_N1 EPS_N2 EPS_WC : WasmTerminal .
  ceq Limits-sub(EPS_WC, lbrack EPS_N1 dotdot eps rbrack, lbrack EPS_N2 dotdot eps rbrack) = true 
      if typecheck(EPS_WC, w-C) /\ typecheck(EPS_N1, w-n) /\ typecheck(EPS_N2, w-n) /\ (EPS_N1 >= EPS_N2) .


  op Tagtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _DEFTYPE1 _DEFTYPE2 _WC : WasmTerminal .
  ceq Tagtype-sub(_WC, _DEFTYPE1, _DEFTYPE2) = true 
      if typecheck(_WC, w-C) /\ typecheck(_DEFTYPE1, deftype) /\ typecheck(_DEFTYPE2, deftype) /\ Deftype-sub(_WC _DEFTYPE1 _DEFTYPE2) /\ Deftype-sub(_WC _DEFTYPE2 _DEFTYPE1) .


  op Globaltype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars CONST_VALTYPE1 CONST_VALTYPE2 CONST_WC : WasmTerminal .
  ceq Globaltype-sub(CONST_WC, (eps CONST_VALTYPE1), (eps CONST_VALTYPE2)) = true 
      if typecheck(CONST_WC, w-C) /\ typecheck(CONST_VALTYPE1, valtype) /\ typecheck(CONST_VALTYPE2, valtype) /\ Valtype-sub(CONST_WC CONST_VALTYPE1 CONST_VALTYPE2) .

  vars W-VAR_VALTYPE1 W-VAR_VALTYPE2 W-VAR_WC : WasmTerminal .
  ceq Globaltype-sub(W-VAR_WC, (MUT W-VAR_VALTYPE1), (MUT W-VAR_VALTYPE2)) = true 
      if typecheck(W-VAR_WC, w-C) /\ typecheck(W-VAR_VALTYPE1, valtype) /\ typecheck(W-VAR_VALTYPE2, valtype) /\ Valtype-sub(W-VAR_WC W-VAR_VALTYPE1 W-VAR_VALTYPE2) /\ Valtype-sub(W-VAR_WC W-VAR_VALTYPE2 W-VAR_VALTYPE1) .


  op Memtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _ADDRTYPE _LIMITS1 _LIMITS2 _WC : WasmTerminal .
  ceq Memtype-sub(_WC, _ADDRTYPE _LIMITS1 PAGE, _ADDRTYPE _LIMITS2 PAGE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_ADDRTYPE, addrtype) /\ typecheck(_LIMITS1, limits) /\ typecheck(_LIMITS2, limits) /\ Limits-sub(_WC _LIMITS1 _LIMITS2) .


  op Tabletype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _ADDRTYPE _LIMITS1 _LIMITS2 _REFTYPE1 _REFTYPE2 _WC : WasmTerminal .
  ceq Tabletype-sub(_WC, (_ADDRTYPE _LIMITS1 _REFTYPE1), (_ADDRTYPE _LIMITS2 _REFTYPE2)) = true 
      if typecheck(_WC, w-C) /\ typecheck(_ADDRTYPE, addrtype) /\ typecheck(_LIMITS1, limits) /\ typecheck(_REFTYPE1, reftype) /\ typecheck(_LIMITS2, limits) /\ typecheck(_REFTYPE2, reftype) /\ Limits-sub(_WC _LIMITS1 _LIMITS2) /\ Reftype-sub(_WC _REFTYPE1 _REFTYPE2) /\ Reftype-sub(_WC _REFTYPE2 _REFTYPE1) .


  op Externtype-sub : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars TAG_TAGTYPE1 TAG_TAGTYPE2 TAG_WC : WasmTerminal .
  ceq Externtype-sub(TAG_WC, TAG TAG_TAGTYPE1, TAG TAG_TAGTYPE2) = true 
      if typecheck(TAG_WC, w-C) /\ typecheck(TAG_TAGTYPE1, tagtype) /\ typecheck(TAG_TAGTYPE2, tagtype) /\ Tagtype-sub(TAG_WC TAG_TAGTYPE1 TAG_TAGTYPE2) .

  vars GLOBAL_GLOBALTYPE1 GLOBAL_GLOBALTYPE2 GLOBAL_WC : WasmTerminal .
  ceq Externtype-sub(GLOBAL_WC, GLOBAL GLOBAL_GLOBALTYPE1, GLOBAL GLOBAL_GLOBALTYPE2) = true 
      if typecheck(GLOBAL_WC, w-C) /\ typecheck(GLOBAL_GLOBALTYPE1, globaltype) /\ typecheck(GLOBAL_GLOBALTYPE2, globaltype) /\ Globaltype-sub(GLOBAL_WC GLOBAL_GLOBALTYPE1 GLOBAL_GLOBALTYPE2) .

  vars MEM_MEMTYPE1 MEM_MEMTYPE2 MEM_WC : WasmTerminal .
  ceq Externtype-sub(MEM_WC, MEM MEM_MEMTYPE1, MEM MEM_MEMTYPE2) = true 
      if typecheck(MEM_WC, w-C) /\ typecheck(MEM_MEMTYPE1, memtype) /\ typecheck(MEM_MEMTYPE2, memtype) /\ Memtype-sub(MEM_WC MEM_MEMTYPE1 MEM_MEMTYPE2) .

  vars TABLE_TABLETYPE1 TABLE_TABLETYPE2 TABLE_WC : WasmTerminal .
  ceq Externtype-sub(TABLE_WC, TABLE TABLE_TABLETYPE1, TABLE TABLE_TABLETYPE2) = true 
      if typecheck(TABLE_WC, w-C) /\ typecheck(TABLE_TABLETYPE1, tabletype) /\ typecheck(TABLE_TABLETYPE2, tabletype) /\ Tabletype-sub(TABLE_WC TABLE_TABLETYPE1 TABLE_TABLETYPE2) .

  vars FUNC_DEFTYPE1 FUNC_DEFTYPE2 FUNC_WC : WasmTerminal .
  ceq Externtype-sub(FUNC_WC, FUNC FUNC_DEFTYPE1, FUNC FUNC_DEFTYPE2) = true 
      if typecheck(FUNC_WC, w-C) /\ typecheck(FUNC_DEFTYPE1, deftype) /\ typecheck(FUNC_DEFTYPE2, deftype) /\ Deftype-sub(FUNC_WC FUNC_DEFTYPE1 FUNC_DEFTYPE2) .


  op Blocktype-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars VALTYPE VALTYPE_VALTYPE? VALTYPE_WC : WasmTerminal .
  ceq Blocktype-ok(VALTYPE_WC, -RESULT VALTYPE_VALTYPE?, eps arrow- eps VALTYPE_VALTYPE?) = true 
      if typecheck(VALTYPE_WC, w-C) /\ typecheck(VALTYPE_VALTYPE?, valtype) /\ Valtype-ok(VALTYPE_WC VALTYPE) .

  vars TYPEIDX_T1* TYPEIDX_T2* TYPEIDX_TYPEIDX TYPEIDX_WC : WasmTerminal .
  ceq Blocktype-ok(TYPEIDX_WC, -IDX TYPEIDX_TYPEIDX, TYPEIDX_T1* arrow- eps TYPEIDX_T2*) = true 
      if typecheck(TYPEIDX_WC, w-C) /\ typecheck(TYPEIDX_TYPEIDX, typeidx) /\ typecheck(TYPEIDX_T1*, valtype) /\ typecheck(TYPEIDX_T2*, valtype) /\ Expand(index(value('TYPES, TYPEIDX_WC), TYPEIDX_TYPEIDX) FUNC TYPEIDX_T1* arrow TYPEIDX_T2*) .


  op Catch-ok : WasmTerminal WasmTerminal -> Bool .

  vars CATCH_T* CATCH_WC CATCH_WL CATCH_WX : WasmTerminal .
  ceq Catch-ok(CATCH_WC, CATCH CATCH_WX CATCH_WL) = true 
      if typecheck(CATCH_WC, w-C) /\ typecheck(CATCH_WX, idx) /\ typecheck(CATCH_WL, labelidx) /\ typecheck(CATCH_T*, valtype) /\ Expand($as-deftype(index(value('TAGS, CATCH_WC), CATCH_WX)) FUNC CATCH_T* arrow eps) /\ Resulttype-sub(CATCH_WC CATCH_T* index(value('LABELS, CATCH_WC), CATCH_WL)) .

  vars CATCH-REF_T* CATCH-REF_WC CATCH-REF_WL CATCH-REF_WX : WasmTerminal .
  ceq Catch-ok(CATCH-REF_WC, CATCH-REF CATCH-REF_WX CATCH-REF_WL) = true 
      if typecheck(CATCH-REF_WC, w-C) /\ typecheck(CATCH-REF_WX, idx) /\ typecheck(CATCH-REF_WL, labelidx) /\ typecheck(CATCH-REF_T*, valtype) /\ Expand($as-deftype(index(value('TAGS, CATCH-REF_WC), CATCH-REF_WX)) FUNC CATCH-REF_T* arrow eps) /\ Resulttype-sub(CATCH-REF_WC CATCH-REF_T* REF eps EXN index(value('LABELS, CATCH-REF_WC), CATCH-REF_WL)) .

