  op $subst-globaltype : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_MUT? SUBST_TU* SUBST_TV* SUBST_WT : WasmTerminal .
  ceq $subst-globaltype((SUBST_MUT? SUBST_WT), SUBST_TV*, SUBST_TU*) = (SUBST_MUT? $subst-valtype(SUBST_WT, SUBST_TV*, SUBST_TU*)) 
      if typecheck(SUBST_MUT?, mut) /\ typecheck(SUBST_WT, valtype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .


  op $subst-memtype : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_AT SUBST_LIM SUBST_TU* SUBST_TV* : WasmTerminal .
  ceq $subst-memtype(SUBST_AT SUBST_LIM PAGE, SUBST_TV*, SUBST_TU*) = SUBST_AT SUBST_LIM PAGE 
      if typecheck(SUBST_AT, addrtype) /\ typecheck(SUBST_LIM, limits) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .


  op $subst-tabletype : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_AT SUBST_LIM SUBST_RT SUBST_TU* SUBST_TV* : WasmTerminal .
  ceq $subst-tabletype((SUBST_AT SUBST_LIM SUBST_RT), SUBST_TV*, SUBST_TU*) = (SUBST_AT SUBST_LIM $subst-reftype(SUBST_RT, SUBST_TV*, SUBST_TU*)) 
      if typecheck(SUBST_AT, addrtype) /\ typecheck(SUBST_LIM, limits) /\ typecheck(SUBST_RT, reftype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .


  op $subst-externtype : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_JT SUBST_TU* SUBST_TV* : WasmTerminal .
  ceq $subst-externtype(TAG SUBST_JT, SUBST_TV*, SUBST_TU*) = TAG $subst-tagtype(SUBST_JT, SUBST_TV*, SUBST_TU*) 
      if typecheck(SUBST_JT, tagtype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .

  vars SUBST_GT SUBST_TU* SUBST_TV* : WasmTerminal .
  ceq $subst-externtype(GLOBAL SUBST_GT, SUBST_TV*, SUBST_TU*) = GLOBAL $subst-globaltype(SUBST_GT, SUBST_TV*, SUBST_TU*) 
      if typecheck(SUBST_GT, globaltype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .

  vars SUBST_TT SUBST_TU* SUBST_TV* : WasmTerminal .
  ceq $subst-externtype(TABLE SUBST_TT, SUBST_TV*, SUBST_TU*) = TABLE $subst-tabletype(SUBST_TT, SUBST_TV*, SUBST_TU*) 
      if typecheck(SUBST_TT, tabletype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .

  vars SUBST_MT SUBST_TU* SUBST_TV* : WasmTerminal .
  ceq $subst-externtype(MEM SUBST_MT, SUBST_TV*, SUBST_TU*) = MEM $subst-memtype(SUBST_MT, SUBST_TV*, SUBST_TU*) 
      if typecheck(SUBST_MT, memtype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .

  vars SUBST_DT SUBST_TU* SUBST_TV* : WasmTerminal .
  ceq $subst-externtype(FUNC SUBST_DT, SUBST_TV*, SUBST_TU*) = FUNC $subst-deftype(SUBST_DT, SUBST_TV*, SUBST_TU*) 
      if typecheck(SUBST_DT, deftype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .


  op $subst-moduletype : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_TU* SUBST_TV* SUBST_XT1* SUBST_XT2* XT-1 XT-2 : WasmTerminal .
  ceq $subst-moduletype(SUBST_XT1* arrow SUBST_XT2*, SUBST_TV*, SUBST_TU*) = $subst-externtype(XT-1, SUBST_TV*, SUBST_TU*) arrow $subst-externtype(XT-2, SUBST_TV*, SUBST_TU*) 
      if typecheck(SUBST_XT1*, externtype) /\ typecheck(SUBST_XT2*, externtype) /\ typecheck(SUBST_TV*, typevar) /\ typecheck(SUBST_TU*, typeuse) .


  op $subst-all-valtype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_I* SUBST_TU* SUBST_WN SUBST_WT TU W-I : WasmTerminal .
  ceq $subst-all-valtype(SUBST_WT, TU) = $subst-valtype(SUBST_WT, -IDX W-I, TU) 
      if typecheck(SUBST_WT, valtype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-reftype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_I* SUBST_RT SUBST_TU* SUBST_WN TU W-I : WasmTerminal .
  ceq $subst-all-reftype(SUBST_RT, TU) = $subst-reftype(SUBST_RT, -IDX W-I, TU) 
      if typecheck(SUBST_RT, reftype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-deftype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_DT SUBST_I* SUBST_TU* SUBST_WN TU W-I : WasmTerminal .
  ceq $subst-all-deftype(SUBST_DT, TU) = $subst-deftype(SUBST_DT, -IDX W-I, TU) 
      if typecheck(SUBST_DT, deftype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-tagtype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_I* SUBST_JT SUBST_TU* SUBST_WN TU W-I : WasmTerminal .
  ceq $subst-all-tagtype(SUBST_JT, TU) = $subst-tagtype(SUBST_JT, -IDX W-I, TU) 
      if typecheck(SUBST_JT, tagtype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-globaltype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_GT SUBST_I* SUBST_TU* SUBST_WN TU W-I : WasmTerminal .
  ceq $subst-all-globaltype(SUBST_GT, TU) = $subst-globaltype(SUBST_GT, -IDX W-I, TU) 
      if typecheck(SUBST_GT, globaltype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-memtype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_I* SUBST_MT SUBST_TU* SUBST_WN TU W-I : WasmTerminal .
  ceq $subst-all-memtype(SUBST_MT, TU) = $subst-memtype(SUBST_MT, -IDX W-I, TU) 
      if typecheck(SUBST_MT, memtype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-tabletype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_I* SUBST_TT SUBST_TU* SUBST_WN TU W-I : WasmTerminal .
  ceq $subst-all-tabletype(SUBST_TT, TU) = $subst-tabletype(SUBST_TT, -IDX W-I, TU) 
      if typecheck(SUBST_TT, tabletype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-externtype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_I* SUBST_TU* SUBST_WN SUBST_XT TU W-I : WasmTerminal .
  ceq $subst-all-externtype(SUBST_XT, TU) = $subst-externtype(SUBST_XT, -IDX W-I, TU) 
      if typecheck(SUBST_XT, externtype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-moduletype : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SUBST_I* SUBST_MMT SUBST_TU* SUBST_WN TU W-I : WasmTerminal .
  ceq $subst-all-moduletype(SUBST_MMT, TU) = $subst-moduletype(SUBST_MMT, -IDX W-I, TU) 
      if typecheck(SUBST_MMT, moduletype) /\ typecheck(SUBST_TU*, typeuse) /\ typecheck(SUBST_WN, w-n) .


  op $subst-all-deftypes : WasmTerminal WasmTerminal -> WasmTerminals .

  var SUBST_TU* : WasmTerminal .
  ceq $subst-all-deftypes(eps, SUBST_TU*) = eps 
      if typecheck(SUBST_TU*, typeuse) .

  vars SUBST_DT* SUBST_DT1 SUBST_TU* : WasmTerminal .
  ceq $subst-all-deftypes(SUBST_DT1 SUBST_DT*, SUBST_TU*) = $subst-all-deftype(SUBST_DT1, SUBST_TU*) $subst-all-deftypes(SUBST_DT*, SUBST_TU*) 
      if typecheck(SUBST_DT1, deftype) /\ typecheck(SUBST_DT*, deftype) /\ typecheck(SUBST_TU*, typeuse) .


  op $rollrt : WasmTerminal WasmTerminal -> WasmTerminal .

  vars ROLLRT_I* ROLLRT_RECTYPE ROLLRT_SUBTYPE* ROLLRT_WN ROLLRT_WX SUBTYPE W-I : WasmTerminal .
  ceq $rollrt(ROLLRT_WX, ROLLRT_RECTYPE) = REC $subst-subtype(SUBTYPE, -IDX (ROLLRT_WX + W-I), REC W-I) 
      if typecheck(ROLLRT_WX, idx) /\ typecheck(ROLLRT_RECTYPE, rectype) /\ typecheck(ROLLRT_SUBTYPE*, subtype) /\ typecheck(ROLLRT_WN, w-n) /\ (ROLLRT_RECTYPE == REC SUBTYPE) .


  op $unrollrt : WasmTerminal -> WasmTerminal .

  vars SUBTYPE UNROLLRT_I* UNROLLRT_RECTYPE UNROLLRT_SUBTYPE* UNROLLRT_WN W-I : WasmTerminal .
  ceq $unrollrt(UNROLLRT_RECTYPE) = REC $subst-subtype(SUBTYPE, REC W-I, -DEF UNROLLRT_RECTYPE W-I) 
      if typecheck(UNROLLRT_RECTYPE, rectype) /\ typecheck(UNROLLRT_SUBTYPE*, subtype) /\ typecheck(UNROLLRT_WN, w-n) /\ (UNROLLRT_RECTYPE == REC SUBTYPE) .


  op $rolldt : WasmTerminal WasmTerminal -> WasmTerminals .

  vars ROLLDT_I* ROLLDT_RECTYPE ROLLDT_SUBTYPE* ROLLDT_WN ROLLDT_WX SUBTYPE W-I : WasmTerminal .
  ceq $rolldt(ROLLDT_WX, ROLLDT_RECTYPE) = -DEF REC SUBTYPE W-I 
      if typecheck(ROLLDT_WX, idx) /\ typecheck(ROLLDT_RECTYPE, rectype) /\ typecheck(ROLLDT_SUBTYPE*, subtype) /\ typecheck(ROLLDT_WN, w-n) /\ ($rollrt(ROLLDT_WX, ROLLDT_RECTYPE) == REC SUBTYPE) .


  op $unrolldt : WasmTerminal -> WasmTerminal .

  vars UNROLLDT_RECTYPE UNROLLDT_SUBTYPE* UNROLLDT_WI : WasmTerminal .
  ceq $unrolldt(-DEF UNROLLDT_RECTYPE UNROLLDT_WI) = index(UNROLLDT_SUBTYPE*, UNROLLDT_WI) 
      if typecheck(UNROLLDT_RECTYPE, rectype) /\ typecheck(UNROLLDT_WI, w-n) /\ typecheck(UNROLLDT_SUBTYPE*, subtype) /\ ($unrollrt(UNROLLDT_RECTYPE) == REC UNROLLDT_SUBTYPE*) .


  op $expanddt : WasmTerminal -> WasmTerminal .

  vars EXPANDDT_COMPTYPE EXPANDDT_DEFTYPE EXPANDDT_FINAL? EXPANDDT_TYPEUSE* : WasmTerminal .
  ceq $expanddt(EXPANDDT_DEFTYPE) = EXPANDDT_COMPTYPE 
      if typecheck(EXPANDDT_DEFTYPE, deftype) /\ typecheck(EXPANDDT_COMPTYPE, comptype) /\ typecheck(EXPANDDT_FINAL?, final) /\ typecheck(EXPANDDT_TYPEUSE*, typeuse) /\ ($unrolldt(EXPANDDT_DEFTYPE) == SUB EXPANDDT_FINAL? EXPANDDT_TYPEUSE* EXPANDDT_COMPTYPE) .


  op $free-addrtype : WasmTerminal -> WasmTerminal .

  var FREE_ADDRTYPE : WasmTerminal .
  ceq $free-addrtype(FREE_ADDRTYPE) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_ADDRTYPE, addrtype) .


  op $free-numtype : WasmTerminal -> WasmTerminal .

  var FREE_NUMTYPE : WasmTerminal .
  ceq $free-numtype(FREE_NUMTYPE) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_NUMTYPE, numtype) .


  op $free-packtype : WasmTerminal -> WasmTerminal .

  var FREE_PACKTYPE : WasmTerminal .
  ceq $free-packtype(FREE_PACKTYPE) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_PACKTYPE, packtype) .


  op $free-lanetype : WasmTerminal -> WasmTerminal .

  var FREE_NUMTYPE : WasmTerminal .
  ceq $free-lanetype(FREE_NUMTYPE) = $free-numtype(FREE_NUMTYPE) 
      if typecheck(FREE_NUMTYPE, numtype) .

  var FREE_PACKTYPE : WasmTerminal .
  ceq $free-lanetype(FREE_PACKTYPE) = $free-packtype(FREE_PACKTYPE) 
      if typecheck(FREE_PACKTYPE, packtype) .


  op $free-vectype : WasmTerminal -> WasmTerminal .

  var FREE_VECTYPE : WasmTerminal .
  ceq $free-vectype(FREE_VECTYPE) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_VECTYPE, vectype) .


  op $free-consttype : WasmTerminal -> WasmTerminal .

  var FREE_NUMTYPE : WasmTerminal .
