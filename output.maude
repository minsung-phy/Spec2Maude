  --- Equations
  sort N .
  cmb ( T ) : N
   if true .

  sort M .
  cmb ( T ) : M
   if true .

  sort K .
  cmb ( T ) : K
   if true .

  sort n .
  cmb ( T ) : n
   if true .

  sort m .
  cmb ( T ) : m
   if true .




  ceq $min ( MIN0-I, MIN0-J ) = MIN0-I 
      if ( ( MIN0-I <= MIN0-J ) ) = true .
  eq $min ( MIN1-I, MIN1-J ) = MIN1-J [owise] .




  eq $sum ( eps ) = 0 .
  eq $sum ( ( SUM1-N SUM1-N ) ) = ( SUM1-N + $sum ( SUM1-N ) ) .





  eq $prod ( eps ) = 1 .
  eq $prod ( ( PROD1-N PROD1-N ) ) = ( PROD1-N * $prod ( PROD1-N ) ) .





  eq $opt ( eps, eps ) = eps .
  eq $opt ( eps, OPT1-W ) = OPT1-W .





  eq $concat ( eps, eps ) = eps .
  eq $concat ( eps, ( CONCAT1-W CONCAT1-W ) ) = CONCAT1-W $concat ( X, CONCAT1-W ) .





  eq $concatn ( eps, eps, CONCATN0-N ) = eps .
  eq $concatn ( eps, ( CONCATN1-W W ), CONCATN1-N ) = CONCATN1-W $concatn ( X, W, CONCATN1-N ) .





  eq $concatopt ( eps, eps ) = eps .
  eq $concatopt ( eps, ( CONCATOPT1-W CONCATOPT1-W ) ) = CONCATOPT1-W $concat ( X, CONCATOPT1-W ) .

















  eq $disjoint ( eps, eps ) = true .
  eq $disjoint ( eps, ( DISJOINT1-W DISJOINT1-W ) ) = ( not ( ( DISJOINT1-W <- DISJOINT1-W ) )  and  $disjoint ( X, DISJOINT1-W ) ) .





  eq $setminus1 ( eps, SETMINUS10-W, eps ) = SETMINUS10-W .
  ceq $setminus1 ( eps, SETMINUS11-W, ( SETMINUS11-WQ SETMINUS11-W ) ) = eps 
      if ( ( SETMINUS11-W == SETMINUS11-WQ ) ) = true .
  eq $setminus1 ( eps, SETMINUS12-W, ( SETMINUS12-WQ SETMINUS12-W ) ) = $setminus1 ( X, SETMINUS12-W, SETMINUS12-W ) [owise] .




  eq $setminus ( eps, eps, SETMINUS0-W ) = eps .
  eq $setminus ( eps, ( SETMINUS1-WQ SETMINUS1-W ), SETMINUS1-W ) = $setminus1 ( X, SETMINUS1-WQ, SETMINUS1-W ) $setminus ( X, SETMINUS1-W, SETMINUS1-W ) .





  eq $setproduct2 ( eps, SETPRODUCT20-WQ, eps ) = eps .
  eq $setproduct2 ( eps, SETPRODUCT21-WQ, ( SETPRODUCT21-W SETPRODUCT21-W ) ) = SETPRODUCT21-WQ SETPRODUCT21-W $setproduct2 ( X, SETPRODUCT21-WQ, SETPRODUCT21-W ) .




  eq $setproduct1 ( eps, eps, SETPRODUCT10-W ) = eps .
  eq $setproduct1 ( eps, ( SETPRODUCT11-WQ SETPRODUCT11-W ), SETPRODUCT11-W ) = $setproduct2 ( X, SETPRODUCT11-WQ, SETPRODUCT11-W ) $setproduct1 ( X, SETPRODUCT11-W, SETPRODUCT11-W ) .




  eq $setproduct ( eps, eps ) = eps .
  eq $setproduct ( eps, ( SETPRODUCT1-WQ SETPRODUCT1-W ) ) = $setproduct1 ( X, SETPRODUCT1-WQ, ( $setproduct ( X, SETPRODUCT1-W ) ) ) .








  sort bit .

  cmb ( T ) : bit
   if I := 0 .

  sort byte .

  cmb ( T ) : byte
   if ( ( ( I >= 0 )  and  ( I <= 255 ) ) ) = true .


  ceq type-ok ( T , uN ( N ) ) = true
   if ( ( ( I >= 0 )  and  ( I <= ( ( 2  ^  N ) - 1 ) ) ) ) = true .


  ceq type-ok ( T , sN ( N ) ) = true
   if I := 0 .

  eq type-ok ( T , iN ( N ) ) = true .

  sort u8 .
  cmb ( T ) : u8
   if true .
  sort u16 .
  cmb ( T ) : u16
   if true .
  sort u31 .
  cmb ( T ) : u31
   if true .
  sort u32 .
  cmb ( T ) : u32
   if true .
  sort u64 .
  cmb ( T ) : u64
   if true .
  sort s33 .
  cmb ( T ) : s33
   if true .
  sort i32 .
  cmb ( T ) : i32
   if true .
  sort i64 .
  cmb ( T ) : i64
   if true .
  sort i128 .
  cmb ( T ) : i128
   if true .



  eq $signif ( 32 ) = 23 .
  eq $signif ( 64 ) = 52 .





  eq $expon ( 32 ) = 8 .
  eq $expon ( 64 ) = 11 .





  eq $M ( M0-N ) = $signif ( M0-N ) .





  eq $E ( E0-N ) = $expon ( E0-N ) .


  sort exp .
  cmb ( T ) : exp
   if true .
  ceq type-ok ( CTORNORMA2 ( M1, EXP1 ) , fNmag ( N ) ) = true
   if ( ( ( M1 < ( 2  ^  $M ( N ) ) )  and  ( ( ( 2 - ( 2  ^  ( $E ( N ) - 1 ) ) ) <= EXP1 )  and  ( EXP1 <= ( ( 2  ^  ( $E ( N ) - 1 ) ) - 1 ) ) ) ) ) = true .
  ceq type-ok ( CTORSUBNORMA1 ( M1 ) , fNmag ( N ) ) = true
   if ( ( ( M1 < ( 2  ^  $M ( N ) ) )  and  ( ( 2 - ( 2  ^  ( $E ( N ) - 1 ) ) ) == EXP ) ) ) = true .
  eq type-ok ( CTORINFA0 , fNmag ( N ) ) = true .
  ceq type-ok ( CTORNANA1 ( M1 ) , fNmag ( N ) ) = true
   if ( ( ( 1 <= M1 )  and  ( M1 < ( 2  ^  $M ( N ) ) ) ) ) = true .
  eq type-ok ( CTORPOSA1 ( FNMAG1 ) , fN ( N ) ) = true .
  eq type-ok ( CTORNEGA1 ( FNMAG1 ) , fN ( N ) ) = true .



  sort f32 .
  cmb ( T ) : f32
   if true .
  sort f64 .
  cmb ( T ) : f64
   if true .



  eq $fzero ( FZERO0-N ) = CTORPOSA1 ( ( CTORSUBNORMA1 ( 0 ) ) ) .





  eq $fnat ( FNAT0-N, FNAT0-N ) = CTORPOSA1 ( ( CTORNORMA2 ( FNAT0-N, 0 ) ) ) .





  eq $fone ( FONE0-N ) = CTORPOSA1 ( ( CTORNORMA2 ( 1, 0 ) ) ) .





  eq $canon ( CANON0-N ) = ( 2  ^  ( $signif ( CANON0-N ) - 1 ) ) .

  eq type-ok ( T , vN ( N ) ) = true .

  sort v128 .
  cmb ( T ) : v128
   if true .

  ceq type-ok ( ( X-LIST-X ) , list ( X ) ) = true
   if ( ( len ( X-LIST-X ) < ( 2  ^  32 ) ) ) = true .
  sort char .

  cmb ( T ) : char
   if ( ( ( ( I >= 0 )  and  ( I <= 55295 ) )  or  ( ( I >= 57344 )  and  ( I <= 1114111 ) ) ) ) = true .






  sort name .

  cmb ( ( CHAR-LIST-CHAR ) ) : name
   if ( ( len ( $utf8 ( CHAR-LIST-CHAR ) ) < ( 2  ^  32 ) ) ) = true .

  sort idx .
  mb ( T ) : idx .

  sort laneidx .
  cmb ( T ) : laneidx
   if T : u8 .

  sort typeidx .
  cmb ( T ) : typeidx
   if T : idx .

  sort funcidx .
  cmb ( T ) : funcidx
   if T : idx .

  sort globalidx .
  cmb ( T ) : globalidx
   if T : idx .

  sort tableidx .
  cmb ( T ) : tableidx
   if T : idx .

  sort memidx .
  cmb ( T ) : memidx
   if T : idx .

  sort tagidx .
  cmb ( T ) : tagidx
   if T : idx .

  sort elemidx .
  cmb ( T ) : elemidx
   if T : idx .

  sort dataidx .
  cmb ( T ) : dataidx
   if T : idx .

  sort labelidx .
  cmb ( T ) : labelidx
   if T : idx .

  sort localidx .
  cmb ( T ) : localidx
   if T : idx .

  sort fieldidx .
  cmb ( T ) : fieldidx
   if T : idx .

  sort externidx .
  mb ( CTORFUNCA1 ( FUNCIDX1 ) ) : externidx .
  mb ( CTORGLOBALA1 ( GLOBALIDX1 ) ) : externidx .
  mb ( CTORTABLEA1 ( TABLEIDX1 ) ) : externidx .
  mb ( CTORMEMA1 ( MEMIDX1 ) ) : externidx .
  mb ( CTORTAGA1 ( TAGIDX1 ) ) : externidx .




  eq $funcsxx ( eps ) = eps .
  eq $funcsxx ( ( CTORFUNCA1 ( FUNCSXX1-X ) FUNCSXX1-XX ) ) = FUNCSXX1-X $funcsxx ( FUNCSXX1-XX ) .
  eq $funcsxx ( ( FUNCSXX2-EXTERNIDX FUNCSXX2-XX ) ) = $funcsxx ( FUNCSXX2-XX ) [owise] .





  eq $globalsxx ( eps ) = eps .
  eq $globalsxx ( ( CTORGLOBALA1 ( GLOBALSXX1-X ) GLOBALSXX1-XX ) ) = GLOBALSXX1-X $globalsxx ( GLOBALSXX1-XX ) .
  eq $globalsxx ( ( GLOBALSXX2-EXTERNIDX GLOBALSXX2-XX ) ) = $globalsxx ( GLOBALSXX2-XX ) [owise] .





  eq $tablesxx ( eps ) = eps .
  eq $tablesxx ( ( CTORTABLEA1 ( TABLESXX1-X ) TABLESXX1-XX ) ) = TABLESXX1-X $tablesxx ( TABLESXX1-XX ) .
  eq $tablesxx ( ( TABLESXX2-EXTERNIDX TABLESXX2-XX ) ) = $tablesxx ( TABLESXX2-XX ) [owise] .





  eq $memsxx ( eps ) = eps .
  eq $memsxx ( ( CTORMEMA1 ( MEMSXX1-X ) MEMSXX1-XX ) ) = MEMSXX1-X $memsxx ( MEMSXX1-XX ) .
  eq $memsxx ( ( MEMSXX2-EXTERNIDX MEMSXX2-XX ) ) = $memsxx ( MEMSXX2-XX ) [owise] .





  eq $tagsxx ( eps ) = eps .
  eq $tagsxx ( ( CTORTAGA1 ( TAGSXX1-X ) TAGSXX1-XX ) ) = TAGSXX1-X $tagsxx ( TAGSXX1-XX ) .
  eq $tagsxx ( ( TAGSXX2-EXTERNIDX TAGSXX2-XX ) ) = $tagsxx ( TAGSXX2-XX ) [owise] .


  sort free .
  cmb ( {item('TYPES, ( F-TYPES-0 )) ; item('FUNCS, ( F-FUNCS-1 )) ; item('GLOBALS, ( F-GLOBALS-2 )) ; item('TABLES, ( F-TABLES-3 )) ; item('MEMS, ( F-MEMS-4 )) ; item('ELEMS, ( F-ELEMS-5 )) ; item('DATAS, ( F-DATAS-6 )) ; item('LOCALS, ( F-LOCALS-7 )) ; item('LABELS, ( F-LABELS-8 )) ; item('TAGS, ( F-TAGS-9 ))} ) : free
   if type-ok ( F-TYPES-0 , typeidx ) /\ type-ok ( F-FUNCS-1 , funcidx ) /\ type-ok ( F-GLOBALS-2 , globalidx ) /\ type-ok ( F-TABLES-3 , tableidx ) /\ type-ok ( F-MEMS-4 , memidx ) /\ type-ok ( F-ELEMS-5 , elemidx ) /\ type-ok ( F-DATAS-6 , dataidx ) /\ type-ok ( F-LOCALS-7 , localidx ) /\ type-ok ( F-LABELS-8 , labelidx ) /\ type-ok ( F-TAGS-9 , tagidx ) .



  eq $free-opt ( eps ) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .
  eq $free-opt ( FREE1-FREE ) = FREE1-FREE .




  eq $free-list ( eps ) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .
  eq $free-list ( ( FREE1-FREE FREE1-FREE ) ) = merge ( FREE1-FREE , $free-list ( FREE1-FREE ) ) .




  eq $free-typeidx ( FREE0-TYPEIDX ) = {item('TYPES, FREE0-TYPEIDX) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .




  eq $free-funcidx ( FREE0-FUNCIDX ) = {item('TYPES, eps) ; item('FUNCS, FREE0-FUNCIDX) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .




