  op $signed- : WasmTerminal WasmTerminal -> WasmTerminal .

  vars SIGNED_WI SIGNED_WN : WasmTerminal .
  ceq $signed-(SIGNED_WN, SIGNED_WI) = SIGNED_WI 
      if typecheck(SIGNED_WN, w-N) /\ (SIGNED_WI < (2 ^ (SIGNED_WN - 1))) .

  vars SIGNED_WI SIGNED_WN : WasmTerminal .
  ceq $signed-(SIGNED_WN, SIGNED_WI) = (SIGNED_WI - (2 ^ SIGNED_WN)) 
      if typecheck(SIGNED_WN, w-N) /\ (((2 ^ (SIGNED_WN - 1)) <= SIGNED_WI) and (SIGNED_WI < (2 ^ SIGNED_WN))) .


  op $inv-signed- : WasmTerminal WasmTerminal -> WasmTerminal .

  vars INV_WI INV_WN : WasmTerminal .
