  --- origin: wasm-3.0/0.1-aux.vars.spectec:5.1-5.32 / script[0]/0001-TypD-n/InstD[1] / InstD
  mb N.wrap_(SCRIPT_0_0001_TYPD_N_NI1WRAP1) : SpectecTerminal .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:5.1-5.32 / script[0]/0001-TypD-n/InstD[1] / InstD
  eq typecheck(SCRIPT_0_0001_TYPD_N_NI1ALIAS1, syn-N) = typecheck(SCRIPT_0_0001_TYPD_N_NI1ALIAS1, syn-nat) .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:5.1-5.32 / script[0]/0001-TypD-n/InstD[1] / InstD
  ceq typecheck(N.wrap_(SCRIPT_0_0001_TYPD_N_NI1WRAP1), syn-N) = true
    if N.wrap_(SCRIPT_0_0001_TYPD_N_NI1WRAP1) : SpectecTerminal /\ typecheck(SCRIPT_0_0001_TYPD_N_NI1WRAP1, syn-nat) .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:5.1-5.32 / script[0]/0001-TypD-n/InstD[1] / InstD
