mod DSL-TERM is
  sort SpectecTerminal .
  sort SpectecType .
endm

mod DSL-PRETYPE is
  inc DSL-TERM .
  inc NAT .
  inc INT .
  inc BOOL .
  sort SpectecTerminals .
  sort SpectecTypes .

  subsort Nat < SpectecTerminal .
  subsort SpectecTerminal < SpectecTerminals .
  subsort SpectecType < SpectecTypes .
  op eps : -> SpectecTerminals .
  op _ _ : SpectecTerminals SpectecTerminals -> SpectecTerminals [ctor assoc id: eps] .

  op syn-nat : -> SpectecType .
  op syn-int : -> SpectecType .
  op typecheck : SpectecTerminal SpectecType -> Bool .
  op typecheck : SpectecTerminals SpectecType -> Bool .
  op typecheck : SpectecTerminals SpectecTypes -> Bool .

  op len : SpectecTerminals -> Nat .
  var W : SpectecTerminal .
  var WTS : SpectecTerminals .

  eq len(eps) = 0 .
  eq len(W WTS) = 1 + len(WTS) .

  var T : SpectecTerminal .
  var TS : SpectecTerminals .

  var WT : SpectecType .
  var N_SPECTEC : Nat .
  var I_SPECTEC : Int .
  eq typecheck(N_SPECTEC, syn-nat) = true .
  eq typecheck(I_SPECTEC, syn-int) = true .
  eq typecheck(eps, WT) = true .
  ceq typecheck(T TS, WT) = typecheck(TS, WT)
      if TS =/= eps /\ typecheck(T, WT) .
  eq typecheck(T, WT) = false [owise] .
  eq typecheck(TS, WT) = false [owise] .

  var N' : Nat .
  op index : SpectecTerminals Nat -> SpectecTerminals .
  eq index(eps, N') = eps .
  eq index(T TS, 0) = T .
  eq index(T TS, s(N')) = index(TS, N') .
endm

mod DSL-RECORD is
  inc DSL-PRETYPE .
  inc QID .
  sort RecordItem .
  sort RecordItems .
  subsort RecordItem < RecordItems .

  op EMPTY : -> RecordItem .
  op _;_ : RecordItems RecordItems -> RecordItems [ctor assoc id: EMPTY].
  op {_} : RecordItems -> SpectecTerminal .

  op item : Qid SpectecTerminals -> RecordItem .

  vars RI RI' : RecordItems . var R : RecordItem .
  vars F F' : Qid .
  var REC : SpectecTerminal .
  vars V V' : SpectecTerminals .

  op value : Qid SpectecTerminal -> SpectecTerminal .
  op value : Qid RecordItems -> SpectecTerminals .
  eq value(F,{RI}) = value(F, RI) .
  eq value(F, EMPTY) = eps .
  eq value(F, item(F, V) ; RI) = V .
  ceq value(F, R ; RI) = value(F, RI) if R =/= EMPTY .

  op _++_ : RecordItems RecordItems -> SpectecTerminal .
  eq RI ++ RI' = {RI ; RI'} .

  op _[._<-_] : SpectecTerminal Qid SpectecTerminals -> SpectecTerminal .
  op _[._<-_] : RecordItems Qid SpectecTerminals -> SpectecTerminal .
  eq {item(F, V) ; RI} [. F <- V'] = {item(F, V') ; RI} .
  ceq {item(F, V) ; RI} [. F' <- V'] = item(F, V) ++ RI[. F' <- V'] if F =/= F' .

  op _[._=++_] : SpectecTerminal Qid SpectecTerminals -> SpectecTerminal .
  eq REC [. F =++ V'] = REC [. F <- (value(F, REC) V') ] .

  op _[_<-_] : SpectecTerminals SpectecTerminal SpectecTerminal -> SpectecTerminals [prec 50] .

  var H : SpectecTerminal .
  vars L : SpectecTerminals .
  vars IDX : Nat .
  vars VALUE NEWVALUE : SpectecTerminal .

  eq eps [ IDX <- NEWVALUE ] = eps .
  eq (H L) [ 0 <- NEWVALUE ] = NEWVALUE L .
  eq (H L) [ s(IDX) <- NEWVALUE ] = H (L [ IDX <- NEWVALUE ]) .
endm

mod SPECTEC-CORE is
  inc DSL-RECORD .
  inc BOOL .
  inc INT .

  --- Base Sorts
  subsort Int < SpectecTerminal .
  --- Nat < SpectecTerminal is provided by DSL-PRETYPE.

  --- Source category/type tags are represented as SpectecType terms.
  --- Source syntax constructors live on the broad SpectecTerminal carrier.

  --- Syntax-category membership is represented by typecheck plus mb/cmb axioms.

  --- Bool wrapper emitted because source defs return Bool as a terminal.
  op w-bool : Bool -> SpectecTerminal [ctor] .

  --- Internal placeholder for an empty source optional inside an iterated field.
  --- It preserves sequence positions but is not a source value/category witness.
  op $none : -> SpectecTerminal [ctor] .

  --- Source category names are not emitted as Maude syntax sorts.

  --- Judgement sort for RelD relations.
  --- Strict C1: source relation rules lower to primary `rl/crl => valid`.
  --- Definitional equations remain `eq/ceq` when they translate source defs.
  sort Judgement .
  sort ValidJudgement .
  subsort ValidJudgement < Judgement .
  op valid : -> ValidJudgement [ctor] .
  op index : SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $repeat : SpectecTerminals Int -> SpectecTerminals .
  op $nat-range-from : SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $idx-range : SpectecTerminal -> SpectecTerminals .
  op $idx-range-from : SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $rec-range : SpectecTerminal -> SpectecTerminals .
  op $def-range : SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op slice : SpectecTerminals SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op _<-_ : SpectecTerminal SpectecTerminals -> Bool .

  --- Generic record merge combinator emitted because source record composition uses it.
  op merge : SpectecTerminal SpectecTerminal -> SpectecTerminal [ctor] .

  --- Record literals/updates come from DSL-RECORD and have sort SpectecTerminal.
  --- This keeps the baseline surface aligned with the SpecTec terminal model.

  --- Execution wrappers generated from source Step relation declarations.
  --- The wrapper result sorts prevent rewrite conditions from being
  --- satisfied by zero-step matching an unreduced relation call.
  sorts StepConf StepPureConf StepReadConf StepsConf .
  subsort Config < StepConf .
  subsort SpectecTerminals < StepPureConf .
  subsort SpectecTerminals < StepReadConf .
  subsort Config < StepsConf .
  op _;_ : Store Frame -> SpectecTerminal [ctor prec 55] .
  op _;_ : State SpectecTerminals -> SpectecTerminal [ctor prec 60] .
  op step : Config -> StepConf [frozen (1)] .
  op step-pure : SpectecTerminals -> StepPureConf [frozen (1)] .
  op step-read : Config -> StepReadConf [frozen (1)] .
  op steps : Config -> StepsConf .

  --- Common variables (declared once)
  var EC : Config .
  op EXP : -> Int .
  var ZS : State .

  --- Generic SpecTec sequence indexing: xs[i*] maps scalar index over i*.
  --- This is representation substrate for source meta-expressions, not a
  --- judgement-specific executable shortcut.
  var INDEX-I : Nat .
  vars INDEX-TS INDEX-IS : SpectecTerminals .
  eq index(INDEX-TS, eps) = eps .
  ceq index(INDEX-TS, INDEX-I INDEX-IS) = index(INDEX-TS, INDEX-I) index(INDEX-TS, INDEX-IS)
   if INDEX-IS =/= eps .

  --- Generic SpecTec membership test: x <- xs.
  vars MEMBER-X MEMBER-Y : SpectecTerminal .
  var MEMBER-YS : SpectecTerminals .
  eq MEMBER-X <- eps = false .
  eq MEMBER-X <- MEMBER-X MEMBER-YS = true .
  ceq MEMBER-X <- MEMBER-Y MEMBER-YS = MEMBER-X <- MEMBER-YS
   if MEMBER-X =/= MEMBER-Y .

  --- Generic SpecTec fixed repetition: e^n becomes $repeat(e,n).
  var REPEAT_N : Int .
  var REPEAT_ELEM : SpectecTerminals .
  var REPEAT_REST : SpectecTerminals .
  var REPEAT_SINGLE : SpectecTerminal .
  var REPEAT_WT : SpectecType .
  vars REPEAT_I REPEAT_COUNT : Int .
  var REPEAT_KIND_ELEM : [SpectecTerminals] .
  eq $repeat(REPEAT_KIND_ELEM, 0) = eps .
  eq $repeat(REPEAT_ELEM, 0) = eps .
  eq len($repeat(REPEAT_ELEM, 0) REPEAT_REST) = len(REPEAT_REST) .
  ceq len($repeat(REPEAT_ELEM, REPEAT_N) REPEAT_REST) = _+_ ( _*_ ( REPEAT_N, len(REPEAT_ELEM) ), len(REPEAT_REST) )

      if _>_(REPEAT_N, 0) .
  eq typecheck($repeat(REPEAT_ELEM, 0) REPEAT_REST, REPEAT_WT) = typecheck(REPEAT_REST, REPEAT_WT) .
  ceq typecheck($repeat(REPEAT_ELEM, REPEAT_N) REPEAT_REST, REPEAT_WT) = typecheck(REPEAT_REST, REPEAT_WT)




      if ( REPEAT_N > 0 ) /\ typecheck(REPEAT_ELEM, REPEAT_WT) .
  eq slice($repeat(REPEAT_SINGLE, REPEAT_N), REPEAT_I, 0) = eps .
  ceq slice($repeat(REPEAT_SINGLE, REPEAT_N), 0, REPEAT_COUNT) = REPEAT_SINGLE slice($repeat(REPEAT_SINGLE, _-_ ( REPEAT_N, 1 )), 0, _-_ ( REPEAT_COUNT, 1 ))

      if _>_(REPEAT_N, 0) /\ _>_(REPEAT_COUNT, 0) .
  ceq slice($repeat(REPEAT_SINGLE, REPEAT_N), REPEAT_I, REPEAT_COUNT) = slice($repeat(REPEAT_SINGLE, _-_ ( REPEAT_N, REPEAT_I )), 0, REPEAT_COUNT)

      if _>_(REPEAT_I, 0) /\ _>=_(REPEAT_N, REPEAT_I) .
  ceq $repeat(REPEAT_ELEM, REPEAT_N) = ( REPEAT_ELEM $repeat(REPEAT_ELEM, _-_ ( REPEAT_N, 1 )) )

      if _>_(REPEAT_N, 0) /\ _<=_(REPEAT_N, 1024) .

  --- Generic SpecTec indexed repetition: e^(i<n) for source index i.
  vars LISTN-N LISTN-START : Nat .
  var LISTN-RT : SpectecTerminal .
  eq $nat-range-from(LISTN-START, 0) = eps .
  ceq $nat-range-from(LISTN-START, LISTN-N) = $nat-range-from(LISTN-START, _-_ ( LISTN-N, 1 )) _+_ ( LISTN-START, _-_ ( LISTN-N, 1 ) )

      if _>_(LISTN-N, 0) .
  eq $idx-range(0) = eps .
  ceq $idx-range(LISTN-N) = $idx-range(_-_ ( LISTN-N, 1 )) ( w--idx(( _-_ ( LISTN-N, 1 ) )) )

      if _>_(LISTN-N, 0) .
  eq $idx-range-from(LISTN-START, 0) = eps .
  ceq $idx-range-from(LISTN-START, LISTN-N) = $idx-range-from(LISTN-START, _-_ ( LISTN-N, 1 )) ( w--idx(( _+_ ( LISTN-START, _-_ ( LISTN-N, 1 ) ) )) )

      if _>_(LISTN-N, 0) .
  eq $rec-range(0) = eps .
  ceq $rec-range(LISTN-N) = ( rec-typevar(( _-_ ( LISTN-N, 1 ) )) ) $rec-range(_-_ ( LISTN-N, 1 ))

      if _>_(LISTN-N, 0) .
  eq $def-range(LISTN-RT, 0) = eps .
  ceq $def-range(LISTN-RT, LISTN-N) = ( w--def(LISTN-RT, ( _-_ ( LISTN-N, 1 ) )) ) $def-range(LISTN-RT, _-_ ( LISTN-N, 1 ))

      if _>_(LISTN-N, 0) .

  --- Generic SpecTec sequence slicing: xs[i : n].
  vars SLICE_I SLICE_N : Int .
  var SLICE_ELEM : SpectecTerminal .
  var SLICE_REST : SpectecTerminals .
  eq slice(SLICE_REST, SLICE_I, 0) = eps .
  ceq slice(( SLICE_ELEM SLICE_REST ), 0, SLICE_N) = ( SLICE_ELEM slice(SLICE_REST, 0, _-_ ( SLICE_N, 1 )) )

      if _>_(SLICE_N, 0) .
  ceq slice(( SLICE_ELEM SLICE_REST ), SLICE_I, SLICE_N) = slice(SLICE_REST, _-_ ( SLICE_I, 1 ), SLICE_N)

      if _>_(SLICE_I, 0) .

  --- Auto-collected tokens
  ops ELSE dotdot lbrace rbrace rbrack : -> SpectecTerminal [ctor] .


  --- Auto-declared helper calls
  op $f : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $f : SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $f : SpectecTerminal SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .


  --- Declarations
  op $ANYREF :  -> SpectecTerminal .
  op $ARRAYREF :  -> SpectecTerminal .
  op $E : Nat -> SpectecTerminal .
  op $EQREF :  -> SpectecTerminal .
  op $EXNREF :  -> SpectecTerminal .
  op $EXTERNREF :  -> SpectecTerminal .
  op $FN : Nat -> SpectecTerminal .
  op $FUNCREF :  -> SpectecTerminal .
  op $I31REF :  -> SpectecTerminal .
  op $IN : Nat -> SpectecTerminal .
  op $JN : Nat -> SpectecTerminal .
  op $Ki :  -> SpectecTerminal .
  op $M : Nat -> SpectecTerminal .
  op $ND :  -> Bool .
  op $NULLEXNREF :  -> SpectecTerminal .
  op $NULLEXTERNREF :  -> SpectecTerminal .
  op $NULLFUNCREF :  -> SpectecTerminal .
  op $NULLREF :  -> SpectecTerminal .
  op $R-fmadd :  -> SpectecTerminal .
  op $R-fmax :  -> SpectecTerminal .
  op $R-fmin :  -> SpectecTerminal .
  op $R-idot :  -> SpectecTerminal .
  op $R-iq15mulr :  -> SpectecTerminal .
  op $R-laneselect :  -> SpectecTerminal .
  op $R-swizzle :  -> SpectecTerminal .
  op $R-trunc-s :  -> SpectecTerminal .
  op $R-trunc-u :  -> SpectecTerminal .
  op $STRUCTREF :  -> SpectecTerminal .
  op $add-arrayinst : State SpectecTerminals -> State .
  op $add-exninst : State SpectecTerminals -> State .
  op $add-structinst : State SpectecTerminals -> State .
  op $allocdata : Store SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op $allocdatas : Store SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $allocelem : Store SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op $allocelems : Store SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $allocexport : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $allocexports : SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op $allocfunc : Store SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $allocfuncs : Store SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $allocglobal : Store SpectecTerminals SpectecTerminal -> SpectecTerminals .
  op $allocglobals : Store SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $allocmem : Store SpectecTerminal -> SpectecTerminals .
  op $allocmems : Store SpectecTerminals -> SpectecTerminals .
  op $allocmodule : Store SpectecTerminal SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $alloctable : Store SpectecTerminals SpectecTerminal -> SpectecTerminals .
  op $alloctables : Store SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $alloctag : Store SpectecTerminal -> SpectecTerminals .
  op $alloctags : Store SpectecTerminals -> SpectecTerminals .
  op $alloctypes : SpectecTerminals -> SpectecTerminals .
  op $apply-fvbinop-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $apply-fvrelop-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $apply-fvternop-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $apply-fvunop-f : SpectecTerminal Nat SpectecTerminal -> SpectecTerminals .
  op $apply-ivbinop-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $apply-ivbinopsx-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $apply-ivbinopsxnd-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $apply-ivextbinop-f : SpectecTerminal Nat SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $apply-ivextunop-f : SpectecTerminal Nat SpectecTerminals -> SpectecTerminals .
  op $apply-ivrelop-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $apply-ivrelopsx-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $apply-ivshiftop-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $apply-ivshiftopsx-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $apply-ivswizzlop-f : SpectecTerminal Nat SpectecTerminals SpectecTerminal -> SpectecTerminal .
  op $apply-ivternopnd-f : SpectecTerminal Nat SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $apply-ivunop-f : SpectecTerminal Nat SpectecTerminal -> SpectecTerminal .
  op $arrayinst : State -> SpectecTerminals .
  op $as-deftype : SpectecTerminal -> SpectecTerminal .
  op $before : SpectecTerminal SpectecTerminal SpectecTerminal -> Bool .
  op $binop : SpectecTerminal SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $blocktype : State SpectecTerminal -> SpectecTerminal .
  op $bool : SpectecTerminal -> SpectecTerminal .
  op $canon : Nat -> SpectecTerminal .
  op $cbytes : SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $ceilz : SpectecTerminal -> SpectecTerminal .
  op $clos-deftype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-deftypes : SpectecTerminals -> SpectecTerminals .
  op $clos-externtype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-moduletype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-tagtype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-valtype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $concat : SpectecTerminals -> SpectecTerminals .
  op $concatn : SpectecTerminals SpectecTerminal -> SpectecTerminals .
  op $concatopt : SpectecTerminals -> SpectecTerminals .
  op $const : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $cont-allocdatas-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocelems-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocfuncs-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocglobals-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmems-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c1 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c2 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c3 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c4 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c5 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c6 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $cont-allocmodule-r0-c7 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminals .
