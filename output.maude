  op $packfield- : WasmTerminal WasmTerminal -> WasmTerminal .

  vars PACKFIELD_VAL PACKFIELD_VALTYPE : WasmTerminal .
  ceq $packfield-(PACKFIELD_VALTYPE, PACKFIELD_VAL) = PACKFIELD_VAL 
      if typecheck(PACKFIELD_VALTYPE, valtype) /\ typecheck(PACKFIELD_VAL, val) .

  vars PACKFIELD_PACKTYPE PACKFIELD_WI : WasmTerminal .
  ceq $packfield-(PACKFIELD_PACKTYPE, CONST I32 PACKFIELD_WI) = PACK PACKFIELD_PACKTYPE $wrap--(32, $psize(PACKFIELD_PACKTYPE), PACKFIELD_WI) 
      if typecheck(PACKFIELD_PACKTYPE, packtype) /\ typecheck(PACKFIELD_WI, num-(I32)) .


  op $unpackfield- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

