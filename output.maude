  op $free-tagtype : WasmTerminal -> WasmTerminal .

  var FREE_DEFTYPE : WasmTerminal .
  ceq $free-tagtype(FREE_DEFTYPE) = $free-deftype(FREE_DEFTYPE) 
      if typecheck(FREE_DEFTYPE, deftype) .


  op $free-globaltype : WasmTerminal -> WasmTerminal .

  vars FREE_MUT? FREE_VALTYPE : WasmTerminal .
  ceq $free-globaltype((FREE_MUT? FREE_VALTYPE)) = $free-valtype(FREE_VALTYPE) 
      if typecheck(FREE_MUT?, mut) /\ typecheck(FREE_VALTYPE, valtype) .


  op $free-memtype : WasmTerminal -> WasmTerminal .

  vars FREE_ADDRTYPE FREE_LIMITS : WasmTerminal .
  ceq $free-memtype(FREE_ADDRTYPE FREE_LIMITS PAGE) = $free-addrtype(FREE_ADDRTYPE) 
