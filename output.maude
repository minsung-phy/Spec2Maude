  --- origin: wasm-3.0/0.1-aux.vars.spectec:5.1-5.32 / script[0]/0001-TypD-n/InstD[1] / InstD
  ceq proj.N.wrap.0_(N.wrap_(SCRIPT_0_0001_TYPD_N_NI1WRAP1)) = SCRIPT_0_0001_TYPD_N_NI1WRAP1
    if N.wrap_(SCRIPT_0_0001_TYPD_N_NI1WRAP1) : SpectecTerminal .

