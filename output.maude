  --- Equations
  --- Generic carrier for source nested sequences such as (X*)*.
  eq $setproduct($seq(NESTED-HEAD) NESTED-REST) = $setproduct-nested($seq(NESTED-HEAD) NESTED-REST) .
  eq $setproduct-nested(eps) = $seq(eps) .
  eq $setproduct-nested($seq(NESTED-HEAD) NESTED-REST) = $setproduct1-nested(NESTED-HEAD, $setproduct-nested(NESTED-REST)) .
  eq $setproduct1-nested(eps, NESTED-PRODUCTS) = eps .
  eq $setproduct1-nested(NESTED-W NESTED-TAIL, NESTED-PRODUCTS) = $setproduct2-nested(NESTED-W, NESTED-PRODUCTS) $setproduct1-nested(NESTED-TAIL, NESTED-PRODUCTS) .
  eq $setproduct2-nested(NESTED-W, eps) = eps .
  eq $setproduct2-nested(NESTED-W, $seq(NESTED-HEAD) NESTED-REST) = $seq(NESTED-W NESTED-HEAD) $setproduct2-nested(NESTED-W, NESTED-REST) .

  eq typecheck(T_SPECTEC, syn-N) = typecheck(T_SPECTEC, syn-nat) .

  eq typecheck(T_SPECTEC, syn-M) = typecheck(T_SPECTEC, syn-nat) .

  eq typecheck(T_SPECTEC, syn-K) = typecheck(T_SPECTEC, syn-nat) .

  eq typecheck(T_SPECTEC, syn-n) = typecheck(T_SPECTEC, syn-nat) .

  eq typecheck(T_SPECTEC, syn-m) = typecheck(T_SPECTEC, syn-nat) .




  ceq $min(MIN0-LOWI, MIN0-LOWJ) = MIN0-LOWI

      if _<=_(MIN0-LOWI, MIN0-LOWJ) .
  eq $min(MIN1-LOWI, MIN1-LOWJ) = MIN1-LOWJ [owise] .




  eq $sum(eps) = 0 .
  eq $sum(( SUM1-LOWN SUM1-NSQ )) = _+_(SUM1-LOWN, $sum(SUM1-NSQ)) .





  eq $prod(eps) = 1 .
  eq $prod(( PROD1-LOWN PROD1-NSQ )) = _*_(PROD1-LOWN, $prod(PROD1-NSQ)) .





  eq $opt(eps) = eps .
  eq $opt(OPT1-LOWW) = OPT1-LOWW .





  eq $concat(eps) = eps .
  eq $concat(( CONCAT1-WS CONCAT1-WSQ )) = CONCAT1-WS $concat(CONCAT1-WSQ) .





  eq $concatn(eps, CONCATN0-LOWN) = eps .
  eq $concatn(( $repeat ( CONCATN1-WS, CONCATN1-LOWN ) $map-Srepeat-a2-s0(CONCATN1-WSQ, CONCATN1-LOWN) ), CONCATN1-LOWN) = $repeat ( CONCATN1-WS, CONCATN1-LOWN ) $concatn(( $map-Srepeat-a2-s0-nested(CONCATN1-WSQ, CONCATN1-LOWN) ), CONCATN1-LOWN) .





  eq $concatopt(eps) = eps .
  eq $concatopt(( CONCATOPT1-WS CONCATOPT1-WSQ )) = CONCATOPT1-WS $concat(CONCATOPT1-WSQ) .

















  eq $disjoint(eps) = true .
  eq $disjoint(( DISJOINT1-LOWW DISJOINT1-WSQ )) = _and_ ( not ( ( DISJOINT1-LOWW <- DISJOINT1-WSQ ) ), $disjoint(DISJOINT1-WSQ) ) .





  eq $setminus1(SETMINUS10-LOWW, eps) = SETMINUS10-LOWW .
  ceq $setminus1(SETMINUS11-LOWW, ( SETMINUS11-W1 SETMINUS11-WSQ )) = eps

      if $raw-lit(SETMINUS11-LOWW) == $raw-lit(SETMINUS11-W1) .
  eq $setminus1(SETMINUS12-LOWW, ( SETMINUS12-W1 SETMINUS12-WSQ )) = $setminus1(SETMINUS12-LOWW, SETMINUS12-WSQ) [owise] .




  eq $setminus(eps, SETMINUS0-WS) = eps .
