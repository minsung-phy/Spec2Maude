  var _ : WasmTerminal .



  op $disjoint_ : WasmTerminal WasmTerminal -> WasmTerminal .
  var _ : WasmTerminal .
  eq disjoint_(UNKNOWN) = 0 .
  eq disjoint_(UNKNOWN) = (not (0) /\ disjoint_(X, 0)) .


  op $setminus1_ : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .
  var X : WasmTerminal .
  var _ : WasmTerminal .
  eq setminus1_(UNKNOWN) = 0 .
  eq setminus1_(UNKNOWN) = 0 .
  eq setminus1_(UNKNOWN) = setminus1_(X, W, 0) .


  op $setminus_ : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .
