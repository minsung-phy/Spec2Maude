  eq $free-datamode(PASSIVE) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .


