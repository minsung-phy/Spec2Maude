  op $free-valtype : WasmTerminal -> WasmTerminal .

  var FREE_NUMTYPE : WasmTerminal .
  ceq $free-valtype(FREE_NUMTYPE) = $free-numtype(FREE_NUMTYPE) 
      if typecheck(FREE_NUMTYPE, numtype) .

  var FREE_VECTYPE : WasmTerminal .
  ceq $free-valtype(FREE_VECTYPE) = $free-vectype(FREE_VECTYPE) 
      if typecheck(FREE_VECTYPE, vectype) .

  var FREE_REFTYPE : WasmTerminal .
  ceq $free-valtype(FREE_REFTYPE) = $free-reftype(FREE_REFTYPE) 
      if typecheck(FREE_REFTYPE, reftype) .
  eq $free-valtype(BOT) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .


  op $free-resulttype : WasmTerminal -> WasmTerminal .

  vars FREE_VALTYPE* VALTYPE : WasmTerminal .
  ceq $free-resulttype(FREE_VALTYPE*) = $free-list($free-valtype(VALTYPE)) 
      if typecheck(FREE_VALTYPE*, valtype) .


  op $free-storagetype : WasmTerminal -> WasmTerminal .

  var FREE_VALTYPE : WasmTerminal .
  ceq $free-storagetype(FREE_VALTYPE) = $free-valtype(FREE_VALTYPE) 
      if typecheck(FREE_VALTYPE, valtype) .

  var FREE_PACKTYPE : WasmTerminal .
  ceq $free-storagetype(FREE_PACKTYPE) = $free-packtype(FREE_PACKTYPE) 
      if typecheck(FREE_PACKTYPE, packtype) .


  op $free-fieldtype : WasmTerminal -> WasmTerminal .

  vars FREE_MUT? FREE_STORAGETYPE : WasmTerminal .
  ceq $free-fieldtype((FREE_MUT? FREE_STORAGETYPE)) = $free-storagetype(FREE_STORAGETYPE) 
      if typecheck(FREE_MUT?, mut) /\ typecheck(FREE_STORAGETYPE, storagetype) .


  op $free-comptype : WasmTerminal -> WasmTerminal .

  vars FIELDTYPE FREE_FIELDTYPE* : WasmTerminal .
  ceq $free-comptype(STRUCT FREE_FIELDTYPE*) = $free-list($free-fieldtype(FIELDTYPE)) 
      if typecheck(FREE_FIELDTYPE*, fieldtype) .

  var FREE_FIELDTYPE : WasmTerminal .
  ceq $free-comptype(ARRAY FREE_FIELDTYPE) = $free-fieldtype(FREE_FIELDTYPE) 
      if typecheck(FREE_FIELDTYPE, fieldtype) .

  vars FREE_RESULTTYPE1 FREE_RESULTTYPE2 : WasmTerminal .
  ceq $free-comptype(FUNC FREE_RESULTTYPE1 arrow FREE_RESULTTYPE2) = ($free-resulttype(FREE_RESULTTYPE1) ++ $free-resulttype(FREE_RESULTTYPE2)) 
      if typecheck(FREE_RESULTTYPE1, resulttype) /\ typecheck(FREE_RESULTTYPE2, resulttype) .


  op $free-subtype : WasmTerminal -> WasmTerminal .

  vars FREE_COMPTYPE FREE_FINAL? FREE_TYPEUSE* TYPEUSE : WasmTerminal .
  ceq $free-subtype(SUB FREE_FINAL? FREE_TYPEUSE* FREE_COMPTYPE) = ($free-list($free-typeuse(TYPEUSE)) ++ $free-comptype(FREE_COMPTYPE)) 
      if typecheck(FREE_FINAL?, final) /\ typecheck(FREE_TYPEUSE*, typeuse) /\ typecheck(FREE_COMPTYPE, comptype) .


  op $free-rectype : WasmTerminal -> WasmTerminal .

  vars FREE_SUBTYPE* SUBTYPE : WasmTerminal .
  ceq $free-rectype(REC FREE_SUBTYPE*) = $free-list($free-subtype(SUBTYPE)) 
