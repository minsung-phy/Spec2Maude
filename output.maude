   if typecheck(N_LIST, N) /\ (0 < (2 ^ 32)) .
  op char :  -> WasmType .
  ceq typecheck(i, char(N_CHAR)) = true 
   if typecheck(N_CHAR, N) /\ (((i >= 0) /\ (i <= 55295)) \/ ((i >= 57344) /\ (i <= 1114111))) .

