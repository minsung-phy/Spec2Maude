  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var B : Bool .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var N : Nat .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var N2 : Nat .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var I : Int .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var I2 : Int .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var R : Rat .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var F : Float .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var FQ : Qid .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var FQ2 : Qid .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var S : String .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var K : [SpectecTerminal] .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var X : SpectecTerminal .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var Y : SpectecTerminal .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var REC : SpectecTerminal .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var XS : SpectecTerminals .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var YS : SpectecTerminals .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var VAL : SpectecTerminals .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var VAL2 : SpectecTerminals .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var RI : RecordItems .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var RI2 : RecordItems .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  var T : SpectecType .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq len(eps) = 0 .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq len(X) = 1 .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq len(X XS) = _+_(1, len(XS))
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq natOfInt(N) = N .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq intOfRat(I) = I .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq natOfRat(N) = N .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq ratIsInt(I) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq ratIsInt(R) = false [owise] .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq modNat(N, N2) = N rem N2
    if _=/=_(N2, 0) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq modInt(I, I2) = I rem I2
    if _=/=_(I2, 0) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq allLen(eps, N) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq allLen(seq(YS), N) = _==_(len(YS), N) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq allLen(seq(YS) XS, N) = _and_(_==_(len(YS), N), allLen(XS, N))
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq isOpt(eps) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq isOpt(X) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq isOpt(X XS) = false
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq allOpt(eps) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq allOpt(seq(YS)) = isOpt(YS) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq allOpt(seq(YS) XS) = _and_(isOpt(YS), allOpt(XS))
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq contains(X, eps) = false .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq contains(X, Y) = _==_(X, Y) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq contains(X, Y XS) = _or_(_==_(X, Y), contains(X, XS))
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq isTrue(bool(B)) = B .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq isTrue(K) = false [owise] .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheck(bool(B), syn-bool) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheck(N, syn-nat) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheck(I, syn-int) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheck(rat(R), syn-rat) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheck(float(F), syn-real) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheck(text(S), syn-text) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckSeq(eps, T) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckSeq(X, T) = typecheck(X, T) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq typecheckSeq(X XS, T) = _and_(typecheck(X, T), typecheckSeq(XS, T))
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckOptSeq(eps, T) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckOptSeq(seq(YS), T) = _and_(isOpt(YS), typecheckSeq(YS, T)) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq typecheckOptSeq(seq(YS) XS, T) = _and_(_and_(isOpt(YS), typecheckSeq(YS, T)), typecheckOptSeq(XS, T))
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckOptSeq(XS, T) = false [owise] .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckSeqOpt(eps, T) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckSeqOpt(seq(YS), T) = typecheckSeq(YS, T) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckSeqOpt(XS, T) = false [owise] .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckNestedSeq(eps, T) = true .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckNestedSeq(seq(YS), T) = typecheckSeq(YS, T) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq typecheckNestedSeq(seq(YS) XS, T) = _and_(typecheckSeq(YS, T), typecheckNestedSeq(XS, T))
    if _=/=_(XS, eps) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheckNestedSeq(XS, T) = false [owise] .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq value(FQ, { RI }) = value(FQ, RI) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq value(FQ, EMPTY) = eps .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq value(FQ, item(FQ, VAL) ; RI) = VAL .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq value(FQ, item(FQ2, VAL) ; RI) = value(FQ, RI)
    if _=/=_(FQ, FQ2) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq RI ++ RI2 = { (RI ; RI2) } .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq ({ RI }) [. FQ <- VAL2 ] = { setItem(RI, FQ, VAL2) } .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq setItem(EMPTY, FQ, VAL2) = item(FQ, VAL2) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq setItem(item(FQ, VAL) ; RI, FQ, VAL2) = item(FQ, VAL2) ; RI .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  ceq setItem(item(FQ, VAL) ; RI, FQ2, VAL2) = item(FQ, VAL) ; setItem(RI, FQ2, VAL2)
    if _=/=_(FQ, FQ2) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq REC [. FQ =++ VAL2 ] = REC [. FQ <- (value(FQ, REC) VAL2) ] .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq index(X XS, 0) = X .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq index(X XS, s N2) = index(XS, N2) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq eps [ N <- Y ] = eps .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq (X XS) [ 0 <- Y ] = Y XS .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq (X XS) [ (s N2) <- Y ] = X (XS [ N2 <- Y ]) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq drop(0, XS) = XS .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq drop(s N, eps) = eps .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq drop(s N, X XS) = drop(N, XS) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq slice(XS, N, 0) = eps .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq slice(eps, s N, N2) = eps .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq slice(eps, 0, s N) = eps .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq slice(X XS, 0, s N) = X slice(XS, 0, N) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq slice(X XS, s N, N2) = slice(XS, N, N2) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq splice(XS, 0, N, VAL) = VAL drop(N, XS) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq splice(X XS, s N, 0, VAL) = X splice(XS, N, 0, VAL) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq splice(eps, s N, s N2, VAL) = eps .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq splice(X XS, s N, s N2, VAL) = X splice(XS, N, N2, VAL) .

  --- origin: <Spec2Maude minimal runtime prelude> / prelude / Prelude
  eq typecheck(K, T) = false [owise] .

  --- origin: wasm-3.0/0.1-aux.vars.spectec:5.1-5.32 / script[0]/0001-TypD-n / TypD
