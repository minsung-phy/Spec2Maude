      if typecheck(VEXTTERNOP_WC, w-C) /\ typecheck(VEXTTERNOP_SH1, ishape) /\ typecheck(VEXTTERNOP_SH2, ishape) /\ typecheck(VEXTTERNOP_VEXTTERNOP, vextternop--(VEXTTERNOP_SH2, VEXTTERNOP_SH1)) .

  vars VNARROW_SH1 VNARROW_SH2 VNARROW_SX VNARROW_WC : WasmTerminal .
  ceq Instr-ok(VNARROW_WC, VNARROW VNARROW_SH1 VNARROW_SH2 VNARROW_SX, V128 V128 arrow- eps V128) = true 
      if typecheck(VNARROW_WC, w-C) /\ typecheck(VNARROW_SH1, ishape) /\ typecheck(VNARROW_SH2, ishape) /\ typecheck(VNARROW_SX, sx) .

  vars VCVTOP_SH1 VCVTOP_SH2 VCVTOP_VCVTOP VCVTOP_WC : WasmTerminal .
  ceq Instr-ok(VCVTOP_WC, VCVTOP VCVTOP_SH1 VCVTOP_SH2 VCVTOP_VCVTOP, V128 arrow- eps V128) = true 
      if typecheck(VCVTOP_WC, w-C) /\ typecheck(VCVTOP_SH1, shape) /\ typecheck(VCVTOP_SH2, shape) /\ typecheck(VCVTOP_VCVTOP, vcvtop--(VCVTOP_SH2, VCVTOP_SH1)) .


  op Instrs-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  var EMPTY_WC : WasmTerminal .
  ceq Instrs-ok(EMPTY_WC, eps, eps arrow- eps eps) = true 
      if typecheck(EMPTY_WC, w-C) .

  vars INIT SEQ_INIT* SEQ_INSTR1 SEQ_INSTR2* SEQ_T* SEQ_T1* SEQ_T2* SEQ_T3* SEQ_WC SEQ_X1* SEQ_X2* W-T X-1 : WasmTerminal .
  ceq Instrs-ok(SEQ_WC, SEQ_INSTR1 SEQ_INSTR2*, SEQ_T1* arrow- SEQ_X1* SEQ_X2* SEQ_T3*) = true 
      if typecheck(SEQ_WC, w-C) /\ typecheck(SEQ_INSTR1, instr) /\ typecheck(SEQ_INSTR2*, instr) /\ typecheck(SEQ_T1*, valtype) /\ typecheck(SEQ_X1*, idx) /\ typecheck(SEQ_X2*, idx) /\ typecheck(SEQ_T3*, valtype) /\ typecheck(SEQ_T2*, valtype) /\ typecheck(SEQ_INIT*, init) /\ typecheck(SEQ_T*, valtype) /\ Instr-ok(SEQ_WC SEQ_INSTR1 SEQ_T1* arrow- SEQ_X1* SEQ_T2*) /\ (index(value('LOCALS, SEQ_WC), X-1) == (INIT W-T)) /\ Instrs-ok($with-locals(SEQ_WC, SEQ_X1*, (SET W-T)) SEQ_INSTR2* SEQ_T2* arrow- SEQ_X2* SEQ_T3*) .

  vars SUB_INSTR* SUB_IT SUB_IT' SUB_WC : WasmTerminal .
  ceq Instrs-ok(SUB_WC, SUB_INSTR*, SUB_IT') = true 
      if typecheck(SUB_WC, w-C) /\ typecheck(SUB_INSTR*, instr) /\ typecheck(SUB_IT', instrtype) /\ typecheck(SUB_IT, instrtype) /\ Instrs-ok(SUB_WC SUB_INSTR* SUB_IT) /\ Instrtype-sub(SUB_WC SUB_IT SUB_IT') /\ Instrtype-ok(SUB_WC SUB_IT') .

  vars FRAME_INSTR* FRAME_T* FRAME_T1* FRAME_T2* FRAME_WC FRAME_X* : WasmTerminal .
  ceq Instrs-ok(FRAME_WC, FRAME_INSTR*, FRAME_T* FRAME_T1* arrow- FRAME_X* FRAME_T* FRAME_T2*) = true 
      if typecheck(FRAME_WC, w-C) /\ typecheck(FRAME_INSTR*, instr) /\ typecheck(FRAME_T*, valtype) /\ typecheck(FRAME_T1*, valtype) /\ typecheck(FRAME_X*, idx) /\ typecheck(FRAME_T2*, valtype) /\ Instrs-ok(FRAME_WC FRAME_INSTR* FRAME_T1* arrow- FRAME_X* FRAME_T2*) /\ Resulttype-ok(FRAME_WC FRAME_T*) .


  op Expr-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _INSTR* _T* _WC : WasmTerminal .
  ceq Expr-ok(_WC, _INSTR*, _T*) = true 
      if typecheck(_WC, w-C) /\ typecheck(_INSTR*, instr) /\ typecheck(_T*, valtype) /\ Instrs-ok(_WC _INSTR* eps arrow- eps _T*) .


  op Nondefaultable : WasmTerminal -> Bool .

  var _WT : WasmTerminal .
  ceq Nondefaultable(_WT) = true 
      if typecheck(_WT, valtype) /\ ($default-(_WT) == eps) .


  op Instr-const : WasmTerminal WasmTerminal -> Bool .

  vars CONST_CNT CONST_NT CONST_WC : WasmTerminal .
  ceq Instr-const(CONST_WC, CONST CONST_NT CONST_CNT) = true 
      if typecheck(CONST_WC, w-C) /\ typecheck(CONST_NT, numtype) /\ typecheck(CONST_CNT, num-(CONST_NT)) .

  vars VCONST_CVT VCONST_VT VCONST_WC : WasmTerminal .
  ceq Instr-const(VCONST_WC, VCONST VCONST_VT VCONST_CVT) = true 
      if typecheck(VCONST_WC, w-C) /\ typecheck(VCONST_VT, vectype) /\ typecheck(VCONST_CVT, vec-(VCONST_VT)) .

  vars REF-NULL_HT REF-NULL_WC : WasmTerminal .
  ceq Instr-const(REF-NULL_WC, REF.NULL REF-NULL_HT) = true 
      if typecheck(REF-NULL_WC, w-C) /\ typecheck(REF-NULL_HT, heaptype) .

  var REF-I31_WC : WasmTerminal .
  ceq Instr-const(REF-I31_WC, REF.I31) = true 
      if typecheck(REF-I31_WC, w-C) .

  vars REF-FUNC_WC REF-FUNC_WX : WasmTerminal .
  ceq Instr-const(REF-FUNC_WC, REF.FUNC REF-FUNC_WX) = true 
      if typecheck(REF-FUNC_WC, w-C) /\ typecheck(REF-FUNC_WX, idx) .

  vars STRUCT-NEW_WC STRUCT-NEW_WX : WasmTerminal .
  ceq Instr-const(STRUCT-NEW_WC, STRUCT.NEW STRUCT-NEW_WX) = true 
      if typecheck(STRUCT-NEW_WC, w-C) /\ typecheck(STRUCT-NEW_WX, idx) .

  vars STRUCT-NEW-DEFAULT_WC STRUCT-NEW-DEFAULT_WX : WasmTerminal .
  ceq Instr-const(STRUCT-NEW-DEFAULT_WC, STRUCT.NEW-DEFAULT STRUCT-NEW-DEFAULT_WX) = true 
      if typecheck(STRUCT-NEW-DEFAULT_WC, w-C) /\ typecheck(STRUCT-NEW-DEFAULT_WX, idx) .

  vars ARRAY-NEW_WC ARRAY-NEW_WX : WasmTerminal .
  ceq Instr-const(ARRAY-NEW_WC, ARRAY.NEW ARRAY-NEW_WX) = true 
      if typecheck(ARRAY-NEW_WC, w-C) /\ typecheck(ARRAY-NEW_WX, idx) .

  vars ARRAY-NEW-DEFAULT_WC ARRAY-NEW-DEFAULT_WX : WasmTerminal .
  ceq Instr-const(ARRAY-NEW-DEFAULT_WC, ARRAY.NEW-DEFAULT ARRAY-NEW-DEFAULT_WX) = true 
      if typecheck(ARRAY-NEW-DEFAULT_WC, w-C) /\ typecheck(ARRAY-NEW-DEFAULT_WX, idx) .

  vars ARRAY-NEW-FIXED_WC ARRAY-NEW-FIXED_WN ARRAY-NEW-FIXED_WX : WasmTerminal .
  ceq Instr-const(ARRAY-NEW-FIXED_WC, ARRAY.NEW-FIXED ARRAY-NEW-FIXED_WX ARRAY-NEW-FIXED_WN) = true 
      if typecheck(ARRAY-NEW-FIXED_WC, w-C) /\ typecheck(ARRAY-NEW-FIXED_WX, idx) /\ typecheck(ARRAY-NEW-FIXED_WN, w-n) .

  var ANY-CONVERT-EXTERN_WC : WasmTerminal .
  ceq Instr-const(ANY-CONVERT-EXTERN_WC, ANY.CONVERT-EXTERN) = true 
      if typecheck(ANY-CONVERT-EXTERN_WC, w-C) .

  var EXTERN-CONVERT-ANY_WC : WasmTerminal .
  ceq Instr-const(EXTERN-CONVERT-ANY_WC, EXTERN.CONVERT-ANY) = true 
      if typecheck(EXTERN-CONVERT-ANY_WC, w-C) .

  vars GLOBAL-GET_WC GLOBAL-GET_WT GLOBAL-GET_WX : WasmTerminal .
  ceq Instr-const(GLOBAL-GET_WC, GLOBAL.GET GLOBAL-GET_WX) = true 
      if typecheck(GLOBAL-GET_WC, w-C) /\ typecheck(GLOBAL-GET_WX, idx) /\ typecheck(GLOBAL-GET_WT, valtype) /\ (index(value('GLOBALS, GLOBAL-GET_WC), GLOBAL-GET_WX) == (eps GLOBAL-GET_WT)) .

  vars BINOP_BINOP BINOP_INN BINOP_WC : WasmTerminal .
  ceq Instr-const(BINOP_WC, BINOP BINOP_INN BINOP_BINOP) = true 
      if typecheck(BINOP_WC, w-C) /\ typecheck(BINOP_INN, Inn) /\ typecheck(BINOP_BINOP, binop-(BINOP_INN)) /\ (BINOP_INN <- I32 I64) /\ (BINOP_BINOP <- ADD SUB MUL) .


  op Expr-const : WasmTerminal WasmTerminal -> Bool .

  vars INSTR _INSTR* _WC : WasmTerminal .
  ceq Expr-const(_WC, _INSTR*) = true 
      if typecheck(_WC, w-C) /\ typecheck(_INSTR*, instr) /\ Instr-const(_WC INSTR) .


  op Expr-ok-const : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _EXPR _WC _WT : WasmTerminal .
  ceq Expr-ok-const(_WC, _EXPR, _WT) = true 
      if typecheck(_WC, w-C) /\ typecheck(_EXPR, expr) /\ typecheck(_WT, valtype) /\ Expr-ok(_WC _EXPR _WT) /\ Expr-const(_WC _EXPR) .


  op Type-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _DT* _RECTYPE _WC _WX : WasmTerminal .
  ceq Type-ok(_WC, TYPE _RECTYPE, _DT*) = true 
      if typecheck(_WC, w-C) /\ typecheck(_RECTYPE, rectype) /\ typecheck(_DT*, deftype) /\ typecheck(_WX, idx) /\ (_WX == len(value('TYPES, _WC))) /\ (_DT* == $rolldt(_WX, _RECTYPE)) /\ Rectype-ok((_WC ++ {item('TYPES, _DT*) ; item('RECS, eps) ; item('TAGS, eps) ; item('GLOBALS, eps) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, eps) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('RETURN, eps) ; item('REFS, eps)}) _RECTYPE OK _WX) .


  op Tag-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _TAGTYPE _WC : WasmTerminal .
  ceq Tag-ok(_WC, TAG _TAGTYPE, $clos-tagtype(_WC, _TAGTYPE)) = true 
      if typecheck(_WC, w-C) /\ typecheck(_TAGTYPE, tagtype) /\ Tagtype-ok(_WC _TAGTYPE) .


  op Global-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _EXPR _GLOBALTYPE _WC _WT : WasmTerminal .
  ceq Global-ok(_WC, GLOBAL _GLOBALTYPE _EXPR, _GLOBALTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_GLOBALTYPE, globaltype) /\ typecheck(_EXPR, expr) /\ typecheck(_WT, valtype) /\ Globaltype-ok(_WC _GLOBALTYPE) /\ (_GLOBALTYPE == (MUT _WT)) /\ Expr-ok-const(_WC _EXPR _WT) .


  op Mem-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _MEMTYPE _WC : WasmTerminal .
  ceq Mem-ok(_WC, MEMORY _MEMTYPE, _MEMTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_MEMTYPE, memtype) /\ Memtype-ok(_WC _MEMTYPE) .


  op Table-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _AT _EXPR _LIM _RT _TABLETYPE _WC : WasmTerminal .
  ceq Table-ok(_WC, TABLE _TABLETYPE _EXPR, _TABLETYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_TABLETYPE, tabletype) /\ typecheck(_EXPR, expr) /\ typecheck(_AT, addrtype) /\ typecheck(_LIM, limits) /\ typecheck(_RT, reftype) /\ Tabletype-ok(_WC _TABLETYPE) /\ (_TABLETYPE == (_AT _LIM _RT)) /\ Expr-ok-const(_WC _EXPR _RT) .


  op Local-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars SET_WC SET_WT : WasmTerminal .
  ceq Local-ok(SET_WC, LOCAL SET_WT, (SET SET_WT)) = true 
      if typecheck(SET_WC, w-C) /\ typecheck(SET_WT, valtype) /\ Defaultable(SET_WT) .

  vars UNSET_WC UNSET_WT : WasmTerminal .
  ceq Local-ok(UNSET_WC, LOCAL UNSET_WT, (UNSET UNSET_WT)) = true 
      if typecheck(UNSET_WC, w-C) /\ typecheck(UNSET_WT, valtype) /\ Nondefaultable(UNSET_WT) .


  op Func-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars LCT LOCAL T-1 _EXPR _LCT* _LOCAL* _T1* _T2* _WC _WX : WasmTerminal .
  ceq Func-ok(_WC, FUNC _WX _LOCAL* _EXPR, index(value('TYPES, _WC), _WX)) = true 
      if typecheck(_WC, w-C) /\ typecheck(_WX, idx) /\ typecheck(_LOCAL*, local) /\ typecheck(_EXPR, expr) /\ typecheck(_T1*, valtype) /\ typecheck(_T2*, valtype) /\ typecheck(_LCT*, localtype) /\ Expand(index(value('TYPES, _WC), _WX) FUNC _T1* arrow _T2*) /\ Local-ok(_WC LOCAL LCT) /\ Expr-ok((_WC ++ {item('TYPES, eps) ; item('RECS, eps) ; item('TAGS, eps) ; item('GLOBALS, eps) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, eps) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('LOCALS, (SET T-1) _LCT*) ; item('LABELS, _T2*) ; item('RETURN, _T2*) ; item('REFS, eps)}) _EXPR _T2*) .


  op Datamode-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  var PASSIVE_WC : WasmTerminal .
  ceq Datamode-ok(PASSIVE_WC, PASSIVE, OK) = true 
      if typecheck(PASSIVE_WC, w-C) .

  vars ACTIVE_AT ACTIVE_EXPR ACTIVE_LIM ACTIVE_WC ACTIVE_WX : WasmTerminal .
  ceq Datamode-ok(ACTIVE_WC, ACTIVE ACTIVE_WX ACTIVE_EXPR, OK) = true 
      if typecheck(ACTIVE_WC, w-C) /\ typecheck(ACTIVE_WX, idx) /\ typecheck(ACTIVE_EXPR, expr) /\ typecheck(ACTIVE_AT, addrtype) /\ typecheck(ACTIVE_LIM, limits) /\ (index(value('MEMS, ACTIVE_WC), ACTIVE_WX) == ACTIVE_AT ACTIVE_LIM PAGE) /\ Expr-ok-const(ACTIVE_WC ACTIVE_EXPR ACTIVE_AT) .


  op Data-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _B* _DATAMODE _WC : WasmTerminal .
  ceq Data-ok(_WC, DATA _B* _DATAMODE, OK) = true 
      if typecheck(_WC, w-C) /\ typecheck(_B*, byte) /\ typecheck(_DATAMODE, datamode) /\ Datamode-ok(_WC _DATAMODE OK) .


  op Elemmode-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars PASSIVE_RT PASSIVE_WC : WasmTerminal .
  ceq Elemmode-ok(PASSIVE_WC, PASSIVE, PASSIVE_RT) = true 
      if typecheck(PASSIVE_WC, w-C) /\ typecheck(PASSIVE_RT, reftype) .

  vars DECLARE_RT DECLARE_WC : WasmTerminal .
  ceq Elemmode-ok(DECLARE_WC, DECLARE, DECLARE_RT) = true 
      if typecheck(DECLARE_WC, w-C) /\ typecheck(DECLARE_RT, reftype) .

  vars ACTIVE_AT ACTIVE_EXPR ACTIVE_LIM ACTIVE_RT ACTIVE_RT' ACTIVE_WC ACTIVE_WX : WasmTerminal .
  ceq Elemmode-ok(ACTIVE_WC, ACTIVE ACTIVE_WX ACTIVE_EXPR, ACTIVE_RT) = true 
      if typecheck(ACTIVE_WC, w-C) /\ typecheck(ACTIVE_WX, idx) /\ typecheck(ACTIVE_EXPR, expr) /\ typecheck(ACTIVE_RT, reftype) /\ typecheck(ACTIVE_AT, addrtype) /\ typecheck(ACTIVE_LIM, limits) /\ typecheck(ACTIVE_RT', reftype) /\ (index(value('TABLES, ACTIVE_WC), ACTIVE_WX) == (ACTIVE_AT ACTIVE_LIM ACTIVE_RT')) /\ Reftype-sub(ACTIVE_WC ACTIVE_RT ACTIVE_RT') /\ Expr-ok-const(ACTIVE_WC ACTIVE_EXPR ACTIVE_AT) .


  op Elem-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars EXPR _ELEMMODE _ELEMTYPE _EXPR* _WC : WasmTerminal .
  ceq Elem-ok(_WC, ELEM _ELEMTYPE _EXPR* _ELEMMODE, _ELEMTYPE) = true 
      if typecheck(_WC, w-C) /\ typecheck(_ELEMTYPE, elemtype) /\ typecheck(_EXPR*, expr) /\ typecheck(_ELEMMODE, elemmode) /\ Reftype-ok(_WC _ELEMTYPE) /\ Expr-ok-const(_WC EXPR _ELEMTYPE) /\ Elemmode-ok(_WC _ELEMMODE _ELEMTYPE) .


  op Start-ok : WasmTerminal WasmTerminal -> Bool .

  vars _WC _WX : WasmTerminal .
  ceq Start-ok(_WC, START _WX) = true 
      if typecheck(_WC, w-C) /\ typecheck(_WX, idx) /\ Expand(index(value('FUNCS, _WC), _WX) FUNC eps arrow eps) .


  op Import-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _NAME1 _NAME2 _WC _XT : WasmTerminal .
  ceq Import-ok(_WC, IMPORT _NAME1 _NAME2 _XT, $clos-externtype(_WC, _XT)) = true 
      if typecheck(_WC, w-C) /\ typecheck(_NAME1, name) /\ typecheck(_NAME2, name) /\ typecheck(_XT, externtype) /\ Externtype-ok(_WC _XT) .


  op Externidx-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars TAG_JT TAG_WC TAG_WX : WasmTerminal .
  ceq Externidx-ok(TAG_WC, TAG TAG_WX, TAG TAG_JT) = true 
      if typecheck(TAG_WC, w-C) /\ typecheck(TAG_WX, idx) /\ typecheck(TAG_JT, tagtype) /\ (index(value('TAGS, TAG_WC), TAG_WX) == TAG_JT) .

  vars GLOBAL_GT GLOBAL_WC GLOBAL_WX : WasmTerminal .
  ceq Externidx-ok(GLOBAL_WC, GLOBAL GLOBAL_WX, GLOBAL GLOBAL_GT) = true 
      if typecheck(GLOBAL_WC, w-C) /\ typecheck(GLOBAL_WX, idx) /\ typecheck(GLOBAL_GT, globaltype) /\ (index(value('GLOBALS, GLOBAL_WC), GLOBAL_WX) == GLOBAL_GT) .

  vars MEM_MT MEM_WC MEM_WX : WasmTerminal .
  ceq Externidx-ok(MEM_WC, MEM MEM_WX, MEM MEM_MT) = true 
      if typecheck(MEM_WC, w-C) /\ typecheck(MEM_WX, idx) /\ typecheck(MEM_MT, memtype) /\ (index(value('MEMS, MEM_WC), MEM_WX) == MEM_MT) .

  vars TABLE_TT TABLE_WC TABLE_WX : WasmTerminal .
  ceq Externidx-ok(TABLE_WC, TABLE TABLE_WX, TABLE TABLE_TT) = true 
      if typecheck(TABLE_WC, w-C) /\ typecheck(TABLE_WX, idx) /\ typecheck(TABLE_TT, tabletype) /\ (index(value('TABLES, TABLE_WC), TABLE_WX) == TABLE_TT) .

  vars FUNC_DT FUNC_WC FUNC_WX : WasmTerminal .
  ceq Externidx-ok(FUNC_WC, FUNC FUNC_WX, FUNC FUNC_DT) = true 
      if typecheck(FUNC_WC, w-C) /\ typecheck(FUNC_WX, idx) /\ typecheck(FUNC_DT, deftype) /\ (index(value('FUNCS, FUNC_WC), FUNC_WX) == FUNC_DT) .


  op Export-ok : WasmTerminal WasmTerminal WasmTerminal WasmTerminal -> Bool .

  vars _EXTERNIDX _NAME _WC _XT : WasmTerminal .
  ceq Export-ok(_WC, EXPORT _NAME _EXTERNIDX, _NAME, _XT) = true 
      if typecheck(_WC, w-C) /\ typecheck(_NAME, name) /\ typecheck(_EXTERNIDX, externidx) /\ typecheck(_XT, externtype) /\ Externidx-ok(_WC _EXTERNIDX _XT) .


  op Globals-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  var EMPTY_WC : WasmTerminal .
  ceq Globals-ok(EMPTY_WC, eps, eps) = true 
      if typecheck(EMPTY_WC, w-C) .

  vars CONS_GLOBAL* CONS_GLOBAL1 CONS_GT* CONS_GT1 CONS_WC : WasmTerminal .
  ceq Globals-ok(CONS_WC, CONS_GLOBAL1 CONS_GLOBAL*, CONS_GT1 CONS_GT*) = true 
      if typecheck(CONS_WC, w-C) /\ typecheck(CONS_GLOBAL1, global) /\ typecheck(CONS_GLOBAL*, global) /\ typecheck(CONS_GT1, globaltype) /\ typecheck(CONS_GT*, globaltype) /\ Global-ok(CONS_WC CONS_GLOBAL1 CONS_GT1) /\ Globals-ok((CONS_WC ++ {item('TYPES, eps) ; item('RECS, eps) ; item('TAGS, eps) ; item('GLOBALS, CONS_GT1) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, eps) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('RETURN, eps) ; item('REFS, eps)}) CONS_GLOBAL* CONS_GT*) .


  op Types-ok : WasmTerminal WasmTerminal WasmTerminal -> Bool .

  var EMPTY_WC : WasmTerminal .
  ceq Types-ok(EMPTY_WC, eps, eps) = true 
      if typecheck(EMPTY_WC, w-C) .

  vars CONS_DT* CONS_DT1* CONS_TYPE* CONS_TYPE1 CONS_WC : WasmTerminal .
  ceq Types-ok(CONS_WC, CONS_TYPE1 CONS_TYPE*, CONS_DT1* CONS_DT*) = true 
      if typecheck(CONS_WC, w-C) /\ typecheck(CONS_TYPE1, type) /\ typecheck(CONS_TYPE*, type) /\ typecheck(CONS_DT1*, deftype) /\ typecheck(CONS_DT*, deftype) /\ Type-ok(CONS_WC CONS_TYPE1 CONS_DT1*) /\ Types-ok((CONS_WC ++ {item('TYPES, CONS_DT1*) ; item('RECS, eps) ; item('TAGS, eps) ; item('GLOBALS, eps) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, eps) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('RETURN, eps) ; item('REFS, eps)}) CONS_TYPE* CONS_DT*) .

  op nonfuncs :  -> WasmType [ctor] .

  var GLOBAL* : WasmTerminals .
  var MEM* : WasmTerminals .
  var TABLE* : WasmTerminals .
  var ELEM* : WasmTerminals .
  eq typecheck(GLOBAL* MEM* TABLE* ELEM*, nonfuncs) = typecheck(GLOBAL*, global) and typecheck(MEM*, mem) and typecheck(TABLE*, table) and typecheck(ELEM*, elem) .

  op $funcidx-nonfuncs : WasmTerminal -> WasmTerminals .

  vars FUNCIDX_ELEM* FUNCIDX_GLOBAL* FUNCIDX_MEM* FUNCIDX_TABLE* : WasmTerminal .
  ceq $funcidx-nonfuncs((FUNCIDX_GLOBAL* FUNCIDX_MEM* FUNCIDX_TABLE* FUNCIDX_ELEM*)) = $funcidx-module(MODULE eps eps eps FUNCIDX_GLOBAL* FUNCIDX_MEM* FUNCIDX_TABLE* eps eps FUNCIDX_ELEM* eps eps) 
      if typecheck(FUNCIDX_GLOBAL*, global) /\ typecheck(FUNCIDX_MEM*, mem) /\ typecheck(FUNCIDX_TABLE*, table) /\ typecheck(FUNCIDX_ELEM*, elem) .


  op Module-ok : WasmTerminal WasmTerminal -> Bool .

  vars DATA DT ELEM EXPORT FUNC IMPORT JT MEM MT NM OK RT START TABLE TAG TT XT-E XT-I _C' _DATA* _DT'* _DT* _DTI* _ELEM* _EXPORT* _FUNC* _GLOBAL* _GT* _GTI* _IMPORT* _JT* _JTI* _MEM* _MT* _MTI* _NM* _OK* _RT* _START? _TABLE* _TAG* _TT* _TTI* _TYPE* _WC _X* _XTE* _XTI* : WasmTerminal .
  ceq Module-ok(MODULE _TYPE* _IMPORT* _TAG* _GLOBAL* _MEM* _TABLE* _FUNC* _DATA* _ELEM* _START? _EXPORT*, $clos-moduletype(_WC, _XTI* arrow _XTE*)) = true 
