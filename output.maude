  op $free-absheaptype : WasmTerminal -> WasmTerminal .

  var FREE_ABSHEAPTYPE : WasmTerminal .
  ceq $free-absheaptype(FREE_ABSHEAPTYPE) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_ABSHEAPTYPE, absheaptype) .


  op $free-typevar : WasmTerminal -> WasmTerminal .

  var FREE_TYPEIDX : WasmTerminal .
  ceq $free-typevar(-IDX FREE_TYPEIDX) = $free-typeidx(FREE_TYPEIDX) 
      if typecheck(FREE_TYPEIDX, typeidx) .

  var FREE_WN : WasmTerminal .
  ceq $free-typevar(REC FREE_WN) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_WN, w-n) .


  op $free-heaptype : WasmTerminal -> WasmTerminal .

  var FREE_ABSHEAPTYPE : WasmTerminal .
  ceq $free-heaptype(FREE_ABSHEAPTYPE) = $free-absheaptype(FREE_ABSHEAPTYPE) 
      if typecheck(FREE_ABSHEAPTYPE, absheaptype) .

  var FREE_TYPEUSE : WasmTerminal .
  ceq $free-heaptype(FREE_TYPEUSE) = $free-typeuse(FREE_TYPEUSE) 
      if typecheck(FREE_TYPEUSE, typeuse) .


  op $free-reftype : WasmTerminal -> WasmTerminal .

  vars FREE_HEAPTYPE FREE_NULL? : WasmTerminal .
  ceq $free-reftype(REF FREE_NULL? FREE_HEAPTYPE) = $free-heaptype(FREE_HEAPTYPE) 
      if typecheck(FREE_NULL?, null) /\ typecheck(FREE_HEAPTYPE, heaptype) .


  op $free-typeuse : WasmTerminal -> WasmTerminal .

  var FREE_TYPEVAR : WasmTerminal .
  ceq $free-typeuse(FREE_TYPEVAR) = $free-typevar(FREE_TYPEVAR) 
