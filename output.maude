  ceq $inv-signed-(INV_WN, INV_WI) = (INV_WI + (2 ^ INV_WN)) 
      if typecheck(INV_WN, w-N) /\ ((- (2 ^ (INV_WN - 1)) <= INV_WI) and (INV_WI < 0)) .


