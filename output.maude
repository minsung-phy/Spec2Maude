  op $growtable : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars GROWTABLE_AT GROWTABLE_I' GROWTABLE_J? GROWTABLE_R'* GROWTABLE_RT GROWTABLE_TABLEINST GROWTABLE_TABLEINST' GROWTABLE_WI GROWTABLE_WN GROWTABLE_WR W-J : WasmTerminal .
