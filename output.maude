  eq free_heaptype(TYPEUSE) = free_typeuse(TYPEUSE) .


  op $free_reftype : WasmTerminal -> WasmTerminal .
  var REFTYPE : WasmTerminal .
  eq free_reftype(REF) = free_heaptype(HEAPTYPE) .


  op $free_typeuse : WasmTerminal -> WasmTerminal .
  var TYPEUSE : WasmTerminal .
  eq free_typeuse(TYPEVAR) = free_typevar(TYPEVAR) .
  eq free_typeuse(DEFTYPE) = free_deftype(DEFTYPE) .


  op $free_valtype : WasmTerminal -> WasmTerminal .
  var VALTYPE : WasmTerminal .
  eq free_valtype(NUMTYPE) = free_numtype(NUMTYPE) .
  eq free_valtype(VECTYPE) = free_vectype(VECTYPE) .
  eq free_valtype(REFTYPE) = free_reftype(REFTYPE) .
  eq free_valtype(BOT) = 0 .


  op $free_resulttype : WasmTerminal -> WasmTerminal .
  var RESULTTYPE : WasmTerminal .
  eq free_resulttype(UNKNOWN_CASE) = free_list(0) .


  op $free_storagetype : WasmTerminal -> WasmTerminal .
  var STORAGETYPE : WasmTerminal .
  eq free_storagetype(VALTYPE) = free_valtype(VALTYPE) .
  eq free_storagetype(PACKTYPE) = free_packtype(PACKTYPE) .


  op $free_fieldtype : WasmTerminal -> WasmTerminal .
  var FIELDTYPE : WasmTerminal .
  eq free_fieldtype(UNKNOWN_CASE) = free_storagetype(STORAGETYPE) .


  op $free_comptype : WasmTerminal -> WasmTerminal .
  var COMPTYPE : WasmTerminal .
  eq free_comptype(STRUCT) = free_list(0) .
  eq free_comptype(ARRAY) = free_fieldtype(FIELDTYPE) .
  eq free_comptype(FUNC) = 0 .


  op $free_subtype : WasmTerminal -> WasmTerminal .
  var SUBTYPE : WasmTerminal .
  eq free_subtype(SUB) = 0 .


  op $free_rectype : WasmTerminal -> WasmTerminal .
  var RECTYPE : WasmTerminal .
  eq free_rectype(REC) = free_list(0) .


  op $free_deftype : WasmTerminal -> WasmTerminal .
  var DEFTYPE : WasmTerminal .
  eq free_deftype(_DEF) = free_rectype(RECTYPE) .


  op $free_tagtype : WasmTerminal -> WasmTerminal .
  var TAGTYPE : WasmTerminal .
  eq free_tagtype(DEFTYPE) = free_deftype(DEFTYPE) .


  op $free_globaltype : WasmTerminal -> WasmTerminal .
  var GLOBALTYPE : WasmTerminal .
  eq free_globaltype(UNKNOWN_CASE) = free_valtype(VALTYPE) .


  op $free_memtype : WasmTerminal -> WasmTerminal .
  var MEMTYPE : WasmTerminal .
  eq free_memtype(UNKNOWN_CASE) = free_addrtype(ADDRTYPE) .


  op $free_tabletype : WasmTerminal -> WasmTerminal .
  var TABLETYPE : WasmTerminal .
  eq free_tabletype(UNKNOWN_CASE) = 0 .


  op $free_datatype : WasmTerminal -> WasmTerminal .
  var DATATYPE : WasmTerminal .
  eq free_datatype(OK) = 0 .


  op $free_elemtype : WasmTerminal -> WasmTerminal .
  var ELEMTYPE : WasmTerminal .
  var REFTYPE : WasmTerminal .
  eq $free_elemtype(REFTYPE) = free_reftype(REFTYPE) .


  op $free_externtype : WasmTerminal -> WasmTerminal .
  var EXTERNTYPE : WasmTerminal .
  eq free_externtype(TAG) = free_tagtype(TAGTYPE) .
  eq free_externtype(GLOBAL) = free_globaltype(GLOBALTYPE) .
  eq free_externtype(MEM) = free_memtype(MEMTYPE) .
  eq free_externtype(TABLE) = free_tabletype(TABLETYPE) .
  eq free_externtype(FUNC) = free_typeuse(TYPEUSE) .


  op $free_moduletype : WasmTerminal -> WasmTerminal .
  var MODULETYPE : WasmTerminal .
  eq free_moduletype(UNKNOWN_CASE) = 0 .


endm
