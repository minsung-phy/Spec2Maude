load dsl/pretype 

mod SPECTEC-CORE is
  inc DSL-RECORD .

  --- Base Sort subsumptions
  subsort Int < WasmTerminal .
  subsort Nat < WasmTerminal .

  --- Shape cross-product operator (atom 'X', length=1 → w-X)
  op _ w-X _ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  --- Pack separator (atom '_' → '-' → w--)
  op w-- : -> WasmTerminal [ctor] .

  --- Additional utility ops
  op slice : WasmTerminals WasmTerminal WasmTerminal -> WasmTerminals .
  op _<-_ : WasmTerminal WasmTerminals -> Bool .

  --- Common variables
  var I : Int .
  var T : WasmTerminal .
  var TS : WasmTerminals .

  op w-N :  -> WasmType [ctor] .
  eq typecheck(T, w-N) = true .
  op w-M :  -> WasmType [ctor] .
  eq typecheck(T, w-M) = true .
  op w-K :  -> WasmType [ctor] .
  eq typecheck(T, w-K) = true .
  op w-n :  -> WasmType [ctor] .
  eq typecheck(T, w-n) = true .
  op w-m :  -> WasmType [ctor] .
  eq typecheck(T, w-m) = true .

  op $min : WasmTerminal WasmTerminal -> WasmTerminal .

  vars MIN_WI MIN_WJ : WasmTerminal .
  ceq $min(MIN_WI, MIN_WJ) = MIN_WI 
      if (MIN_WI <= MIN_WJ) .

  vars MIN_WI MIN_WJ : WasmTerminal .
  ceq $min(MIN_WI, MIN_WJ) = MIN_WJ [owise] .


  op $sum : WasmTerminal -> WasmTerminal .
  eq $sum(eps) = 0 .

  vars SUM_N'* SUM_WN : WasmTerminal .
  ceq $sum(SUM_WN SUM_N'*) = (SUM_WN + $sum(SUM_N'*)) 
      if typecheck(SUM_WN, w-n) /\ typecheck(SUM_N'*, w-n) .


  op $prod : WasmTerminal -> WasmTerminal .
  eq $prod(eps) = 1 .

  vars PROD_N'* PROD_WN : WasmTerminal .
  ceq $prod(PROD_WN PROD_N'*) = (PROD_WN * $prod(PROD_N'*)) 
      if typecheck(PROD_WN, w-n) /\ typecheck(PROD_N'*, w-n) .


  op $opt- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $opt-(eps, eps) = eps .

  var OPT_WW : WasmTerminal .
  ceq $opt-(eps, OPT_WW) = OPT_WW 
      if typecheck(OPT_WW, w-X) .


  op $concat- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $concat-(eps, eps) = eps .

  vars CONCAT_W'** CONCAT_W* W'* : WasmTerminal .
  ceq $concat-(eps, CONCAT_W* W'*) = CONCAT_W* $concat-(eps, W'*) 
      if typecheck(CONCAT_W*, w-X) /\ typecheck(CONCAT_W'**, w-X) .


  op $concatn- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var CONCATN_WN : WasmTerminal .
  ceq $concatn-(eps, eps, CONCATN_WN) = eps 
      if typecheck(CONCATN_WN, w-n) .

  vars CONCATN_W'** CONCATN_W* CONCATN_WN W' W-W : WasmTerminal .
  ceq $concatn-(eps, W-W W', CONCATN_WN) = W-W $concatn-(eps, W', CONCATN_WN) 
      if typecheck(CONCATN_W*, w-X) /\ typecheck(CONCATN_WN, w-n) /\ typecheck(CONCATN_W'**, w-X) .


  op $concatopt- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $concatopt-(eps, eps) = eps .

  vars CONCATOPT_W'?* CONCATOPT_W? W'? : WasmTerminal .
  ceq $concatopt-(eps, CONCATOPT_W? W'?) = CONCATOPT_W? $concat-(eps, W'?) 
      if typecheck(CONCATOPT_W?, w-X) /\ typecheck(CONCATOPT_W'?*, w-X) .


  op $inv-concat- : WasmTerminal WasmTerminal -> WasmTerminals .



  op $inv-concatn- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .



  op $disjoint- : WasmTerminal WasmTerminal -> WasmTerminal .
  eq $disjoint-(eps, eps) = true .

  vars DISJOINT_W'* DISJOINT_WW : WasmTerminal .
  ceq $disjoint-(eps, DISJOINT_WW DISJOINT_W'*) = (not ((DISJOINT_WW <- DISJOINT_W'*)) and $disjoint-(eps, DISJOINT_W'*)) 
      if typecheck(DISJOINT_WW, w-X) /\ typecheck(DISJOINT_W'*, w-X) .


  op $setminus1- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var SETMINUS1_WW : WasmTerminal .
  ceq $setminus1-(eps, SETMINUS1_WW, eps) = SETMINUS1_WW 
      if typecheck(SETMINUS1_WW, w-X) .

  vars SETMINUS1_W'* SETMINUS1_W1 SETMINUS1_WW : WasmTerminal .
  ceq $setminus1-(eps, SETMINUS1_WW, SETMINUS1_W1 SETMINUS1_W'*) = eps 
      if typecheck(SETMINUS1_WW, w-X) /\ typecheck(SETMINUS1_W1, w-X) /\ typecheck(SETMINUS1_W'*, w-X) /\ (SETMINUS1_WW == SETMINUS1_W1) .

  vars SETMINUS1_W'* SETMINUS1_W1 SETMINUS1_WW : WasmTerminal .
  ceq $setminus1-(eps, SETMINUS1_WW, SETMINUS1_W1 SETMINUS1_W'*) = $setminus1-(eps, SETMINUS1_WW, SETMINUS1_W'*) 
      if typecheck(SETMINUS1_WW, w-X) /\ typecheck(SETMINUS1_W1, w-X) /\ typecheck(SETMINUS1_W'*, w-X) [owise] .


  op $setminus- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var SETMINUS_W* : WasmTerminal .
  ceq $setminus-(eps, eps, SETMINUS_W*) = eps 
      if typecheck(SETMINUS_W*, w-X) .

  vars SETMINUS_W'* SETMINUS_W* SETMINUS_W1 : WasmTerminal .
  ceq $setminus-(eps, SETMINUS_W1 SETMINUS_W'*, SETMINUS_W*) = $setminus1-(eps, SETMINUS_W1, SETMINUS_W*) $setminus-(eps, SETMINUS_W'*, SETMINUS_W*) 
      if typecheck(SETMINUS_W1, w-X) /\ typecheck(SETMINUS_W'*, w-X) /\ typecheck(SETMINUS_W*, w-X) .


  op $setproduct2- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  var SETPRODUCT2_W1 : WasmTerminal .
  ceq $setproduct2-(eps, SETPRODUCT2_W1, eps) = eps 
      if typecheck(SETPRODUCT2_W1, w-X) .

  vars SETPRODUCT2_W'* SETPRODUCT2_W** SETPRODUCT2_W1 W* : WasmTerminal .
  ceq $setproduct2-(eps, SETPRODUCT2_W1, SETPRODUCT2_W'* W*) = SETPRODUCT2_W1 SETPRODUCT2_W'* $setproduct2-(eps, SETPRODUCT2_W1, W*) 
      if typecheck(SETPRODUCT2_W1, w-X) /\ typecheck(SETPRODUCT2_W'*, w-X) /\ typecheck(SETPRODUCT2_W**, w-X) .


  op $setproduct1- : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminals .

  vars SETPRODUCT1_W** W* : WasmTerminal .
  ceq $setproduct1-(eps, eps, W*) = eps 
      if typecheck(SETPRODUCT1_W**, w-X) .

  vars SETPRODUCT1_W'* SETPRODUCT1_W** SETPRODUCT1_W1 W* : WasmTerminal .
  ceq $setproduct1-(eps, SETPRODUCT1_W1 SETPRODUCT1_W'*, W*) = $setproduct2-(eps, SETPRODUCT1_W1, W*) $setproduct1-(eps, SETPRODUCT1_W'*, W*) 
      if typecheck(SETPRODUCT1_W1, w-X) /\ typecheck(SETPRODUCT1_W'*, w-X) /\ typecheck(SETPRODUCT1_W**, w-X) .


  op $setproduct- : WasmTerminal WasmTerminal -> WasmTerminals .
  eq $setproduct-(eps, eps) = eps .

  vars SETPRODUCT_W** SETPRODUCT_W1* W* : WasmTerminal .
  ceq $setproduct-(eps, SETPRODUCT_W1* W*) = $setproduct1-(eps, SETPRODUCT_W1*, $setproduct-(eps, W*)) 
      if typecheck(SETPRODUCT_W1*, w-X) /\ typecheck(SETPRODUCT_W**, w-X) .


  op $ND :  -> WasmTerminal .


  op bit :  -> WasmType [ctor] .
  var W-I : WasmTerminal .
  ceq typecheck(W-I, bit) = true 
   if ((W-I == 0) or (W-I == 1)) .
  op byte :  -> WasmType [ctor] .
  var W-I : WasmTerminal .
  ceq typecheck(W-I, byte) = true 
   if ((W-I >= 0) and (W-I <= 255)) .
  op uN : WasmTerminal -> WasmType [ctor] .
  var W-I : WasmTerminal .
  ceq typecheck(W-I, uN(W-N)) = true 
   if typecheck(W-N, w-N) /\ ((W-I >= 0) and (W-I <= ((2 ^ W-N) - 1))) .
  op sN : WasmTerminal -> WasmType [ctor] .
  var W-I : WasmTerminal .
  ceq typecheck(W-I, sN(W-N)) = true 
   if typecheck(W-N, w-N) /\ ((((W-I >= - (2 ^ (W-N - 1))) and (W-I <= - 1)) or (W-I == 0)) or ((W-I >= +(1)) and (W-I <= (+((2 ^ (W-N - 1))) - 1)))) .
  op iN : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, iN(W-N)) = typecheck(W-N, w-N) /\ typecheck(T, uN(W-N)) .
  op u8 :  -> WasmType [ctor] .
  eq typecheck(T, u8) = typecheck(T, uN(8)) .
  op u16 :  -> WasmType [ctor] .
  eq typecheck(T, u16) = typecheck(T, uN(16)) .
  op u31 :  -> WasmType [ctor] .
  eq typecheck(T, u31) = typecheck(T, uN(31)) .
  op u32 :  -> WasmType [ctor] .
  eq typecheck(T, u32) = typecheck(T, uN(32)) .
  op u64 :  -> WasmType [ctor] .
  eq typecheck(T, u64) = typecheck(T, uN(64)) .
  op s33 :  -> WasmType [ctor] .
  eq typecheck(T, s33) = typecheck(T, sN(33)) .
  op i32 :  -> WasmType [ctor] .
  eq typecheck(T, i32) = typecheck(T, iN(32)) .
  op i64 :  -> WasmType [ctor] .
  eq typecheck(T, i64) = typecheck(T, iN(64)) .
  op i128 :  -> WasmType [ctor] .
  eq typecheck(T, i128) = typecheck(T, iN(128)) .

  op $signif : WasmTerminal -> WasmTerminal .
  eq $signif(32) = 23 .
  eq $signif(64) = 52 .


  op $expon : WasmTerminal -> WasmTerminal .
  eq $expon(32) = 8 .
  eq $expon(64) = 11 .


  op $w-M : WasmTerminal -> WasmTerminal .

  var W_WN : WasmTerminal .
  ceq $w-M(W_WN) = $signif(W_WN) 
      if typecheck(W_WN, w-N) .


  op $w-E : WasmTerminal -> WasmTerminal .

  var W_WN : WasmTerminal .
  ceq $w-E(W_WN) = $expon(W_WN) 
      if typecheck(W_WN, w-N) .

  op exp :  -> WasmType [ctor] .
  eq typecheck(T, exp) = true .
  op fNmag : WasmTerminal -> WasmType [ctor] .
  var W-I : WasmTerminal .
  vars EXP W-M : WasmTerminal .
  ceq typecheck(W-I, fNmag(W-N)) = true 
   if typecheck(W-N, w-N) /\ ((W-M < (2 ^ $w-M(W-N))) and (((2 - (2 ^ ($w-E(W-N) - 1))) <= EXP) and (EXP <= ((2 ^ ($w-E(W-N) - 1)) - 1)))) .
  var W-I : WasmTerminal .
  vars EXP W-M : WasmTerminal .
  ceq typecheck(W-I, fNmag(W-N)) = true 
   if typecheck(W-N, w-N) /\ ((W-M < (2 ^ $w-M(W-N))) and ((2 - (2 ^ ($w-E(W-N) - 1))) == EXP)) .
  op INF :  -> WasmTerminal [ctor] .
  var W-N : WasmTerminal .
  eq typecheck(INF, fNmag(W-N)) = typecheck(W-N, w-N) .
  var W-I : WasmTerminal .
  vars W-M : WasmTerminal .
  ceq typecheck(W-I, fNmag(W-N)) = true 
   if typecheck(W-N, w-N) /\ ((1 <= W-M) and (W-M < (2 ^ $w-M(W-N)))) .
  op fN : WasmTerminal -> WasmType [ctor] .
  op POS _ : WasmTerminal -> WasmTerminal [ctor] .
  var W-N : WasmTerminal .
  var FNMAG1 : WasmTerminal .
  eq typecheck(POS FNMAG1, fN(W-N)) = typecheck(W-N, w-N) and typecheck(FNMAG1, fNmag(W-N)) .
  op NEG _ : WasmTerminal -> WasmTerminal [ctor] .
  var W-N : WasmTerminal .
  var FNMAG1 : WasmTerminal .
  eq typecheck(NEG FNMAG1, fN(W-N)) = typecheck(W-N, w-N) and typecheck(FNMAG1, fNmag(W-N)) .
  op f32 :  -> WasmType [ctor] .
  eq typecheck(T, f32) = typecheck(T, fN(32)) .
  op f64 :  -> WasmType [ctor] .
  eq typecheck(T, f64) = typecheck(T, fN(64)) .

  op $fzero : WasmTerminal -> WasmTerminal .

  var FZERO_WN : WasmTerminal .
  ceq $fzero(FZERO_WN) = POS SUBNORM 0 
      if typecheck(FZERO_WN, w-N) .


  op $fnat : WasmTerminal WasmTerminal -> WasmTerminal .

  var FNAT_WN : WasmTerminal .
  ceq $fnat(FNAT_WN, FNAT_WN) = POS NORM FNAT_WN 0 
      if typecheck(FNAT_WN, w-N) /\ typecheck(FNAT_WN, w-n) .


  op $fone : WasmTerminal -> WasmTerminal .

  var FONE_WN : WasmTerminal .
  ceq $fone(FONE_WN) = POS NORM 1 0 
      if typecheck(FONE_WN, w-N) .


  op $canon- : WasmTerminal -> WasmTerminal .

  var CANON_WN : WasmTerminal .
  ceq $canon-(CANON_WN) = (2 ^ ($signif(CANON_WN) - 1)) 
      if typecheck(CANON_WN, w-N) .

  op vN : WasmTerminal -> WasmType [ctor] .
  eq typecheck(T, vN(W-N)) = typecheck(W-N, w-N) /\ typecheck(T, uN(W-N)) .
  op v128 :  -> WasmType [ctor] .
  eq typecheck(T, v128) = typecheck(T, vN(128)) .
  op list : WasmTerminal -> WasmType [ctor] .
  var W-I : WasmTerminal .
  vars X* : WasmTerminal .
  ceq typecheck(W-I, list(eps)) = true 
   if (len(X*) < (2 ^ 32)) .
  op char :  -> WasmType [ctor] .
  var W-I : WasmTerminal .
  ceq typecheck(W-I, char) = true 
   if (((W-I >= 0) and (W-I <= 55295)) or ((W-I >= 57344) and (W-I <= 1114111))) .

  op $utf8 : WasmTerminal -> WasmTerminals .


  op name :  -> WasmType [ctor] .
  var W-I : WasmTerminal .
  vars CHAR* : WasmTerminal .
  ceq typecheck(W-I, name) = true 
   if (len($utf8(CHAR*)) < (2 ^ 32)) .
  op idx :  -> WasmType [ctor] .
  eq typecheck(T, idx) = typecheck(T, u32) .
  op laneidx :  -> WasmType [ctor] .
  eq typecheck(T, laneidx) = typecheck(T, u8) .
  op typeidx :  -> WasmType [ctor] .
  eq typecheck(T, typeidx) = typecheck(T, idx) .
  op funcidx :  -> WasmType [ctor] .
  eq typecheck(T, funcidx) = typecheck(T, idx) .
  op globalidx :  -> WasmType [ctor] .
  eq typecheck(T, globalidx) = typecheck(T, idx) .
  op tableidx :  -> WasmType [ctor] .
  eq typecheck(T, tableidx) = typecheck(T, idx) .
  op memidx :  -> WasmType [ctor] .
  eq typecheck(T, memidx) = typecheck(T, idx) .
  op tagidx :  -> WasmType [ctor] .
  eq typecheck(T, tagidx) = typecheck(T, idx) .
  op elemidx :  -> WasmType [ctor] .
  eq typecheck(T, elemidx) = typecheck(T, idx) .
  op dataidx :  -> WasmType [ctor] .
  eq typecheck(T, dataidx) = typecheck(T, idx) .
  op labelidx :  -> WasmType [ctor] .
  eq typecheck(T, labelidx) = typecheck(T, idx) .
  op localidx :  -> WasmType [ctor] .
  eq typecheck(T, localidx) = typecheck(T, idx) .
  op fieldidx :  -> WasmType [ctor] .
  eq typecheck(T, fieldidx) = typecheck(T, idx) .
  op externidx :  -> WasmType [ctor] .
  op FUNC _ : WasmTerminal -> WasmTerminal [ctor] .
  var FUNCIDX1 : WasmTerminal .
  eq typecheck(FUNC FUNCIDX1, externidx) = typecheck(FUNCIDX1, funcidx) .
  op GLOBAL _ : WasmTerminal -> WasmTerminal [ctor] .
  var GLOBALIDX1 : WasmTerminal .
  eq typecheck(GLOBAL GLOBALIDX1, externidx) = typecheck(GLOBALIDX1, globalidx) .
  op TABLE _ : WasmTerminal -> WasmTerminal [ctor] .
  var TABLEIDX1 : WasmTerminal .
  eq typecheck(TABLE TABLEIDX1, externidx) = typecheck(TABLEIDX1, tableidx) .
  op MEM _ : WasmTerminal -> WasmTerminal [ctor] .
  var MEMIDX1 : WasmTerminal .
  eq typecheck(MEM MEMIDX1, externidx) = typecheck(MEMIDX1, memidx) .
  op TAG _ : WasmTerminal -> WasmTerminal [ctor] .
  var TAGIDX1 : WasmTerminal .
  eq typecheck(TAG TAGIDX1, externidx) = typecheck(TAGIDX1, tagidx) .

  op $funcsxx : WasmTerminal -> WasmTerminals .
  eq $funcsxx(eps) = eps .

  vars FUNCSXX_WX FUNCSXX_XX* : WasmTerminal .
  ceq $funcsxx(FUNC FUNCSXX_WX FUNCSXX_XX*) = FUNCSXX_WX $funcsxx(FUNCSXX_XX*) 
      if typecheck(FUNCSXX_WX, idx) /\ typecheck(FUNCSXX_XX*, externidx) .

  vars FUNCSXX_EXTERNIDX FUNCSXX_XX* : WasmTerminal .
  ceq $funcsxx(FUNCSXX_EXTERNIDX FUNCSXX_XX*) = $funcsxx(FUNCSXX_XX*) 
      if typecheck(FUNCSXX_EXTERNIDX, externidx) /\ typecheck(FUNCSXX_XX*, externidx) [owise] .


  op $globalsxx : WasmTerminal -> WasmTerminals .
  eq $globalsxx(eps) = eps .

  vars GLOBALSXX_WX GLOBALSXX_XX* : WasmTerminal .
  ceq $globalsxx(GLOBAL GLOBALSXX_WX GLOBALSXX_XX*) = GLOBALSXX_WX $globalsxx(GLOBALSXX_XX*) 
      if typecheck(GLOBALSXX_WX, idx) /\ typecheck(GLOBALSXX_XX*, externidx) .

  vars GLOBALSXX_EXTERNIDX GLOBALSXX_XX* : WasmTerminal .
  ceq $globalsxx(GLOBALSXX_EXTERNIDX GLOBALSXX_XX*) = $globalsxx(GLOBALSXX_XX*) 
      if typecheck(GLOBALSXX_EXTERNIDX, externidx) /\ typecheck(GLOBALSXX_XX*, externidx) [owise] .


  op $tablesxx : WasmTerminal -> WasmTerminals .
  eq $tablesxx(eps) = eps .

  vars TABLESXX_WX TABLESXX_XX* : WasmTerminal .
  ceq $tablesxx(TABLE TABLESXX_WX TABLESXX_XX*) = TABLESXX_WX $tablesxx(TABLESXX_XX*) 
      if typecheck(TABLESXX_WX, idx) /\ typecheck(TABLESXX_XX*, externidx) .

  vars TABLESXX_EXTERNIDX TABLESXX_XX* : WasmTerminal .
  ceq $tablesxx(TABLESXX_EXTERNIDX TABLESXX_XX*) = $tablesxx(TABLESXX_XX*) 
      if typecheck(TABLESXX_EXTERNIDX, externidx) /\ typecheck(TABLESXX_XX*, externidx) [owise] .


  op $memsxx : WasmTerminal -> WasmTerminals .
  eq $memsxx(eps) = eps .

  vars MEMSXX_WX MEMSXX_XX* : WasmTerminal .
  ceq $memsxx(MEM MEMSXX_WX MEMSXX_XX*) = MEMSXX_WX $memsxx(MEMSXX_XX*) 
      if typecheck(MEMSXX_WX, idx) /\ typecheck(MEMSXX_XX*, externidx) .

  vars MEMSXX_EXTERNIDX MEMSXX_XX* : WasmTerminal .
  ceq $memsxx(MEMSXX_EXTERNIDX MEMSXX_XX*) = $memsxx(MEMSXX_XX*) 
      if typecheck(MEMSXX_EXTERNIDX, externidx) /\ typecheck(MEMSXX_XX*, externidx) [owise] .


  op $tagsxx : WasmTerminal -> WasmTerminals .
  eq $tagsxx(eps) = eps .

  vars TAGSXX_WX TAGSXX_XX* : WasmTerminal .
  ceq $tagsxx(TAG TAGSXX_WX TAGSXX_XX*) = TAGSXX_WX $tagsxx(TAGSXX_XX*) 
      if typecheck(TAGSXX_WX, idx) /\ typecheck(TAGSXX_XX*, externidx) .

  vars TAGSXX_EXTERNIDX TAGSXX_XX* : WasmTerminal .
  ceq $tagsxx(TAGSXX_EXTERNIDX TAGSXX_XX*) = $tagsxx(TAGSXX_XX*) 
      if typecheck(TAGSXX_EXTERNIDX, externidx) /\ typecheck(TAGSXX_XX*, externidx) [owise] .

  op free :  -> WasmType [ctor] .
  var F_TYPES_0 : WasmTerminals .
  var F_FUNCS_1 : WasmTerminals .
  var F_GLOBALS_2 : WasmTerminals .
  var F_TABLES_3 : WasmTerminals .
  var F_MEMS_4 : WasmTerminals .
  var F_ELEMS_5 : WasmTerminals .
  var F_DATAS_6 : WasmTerminals .
  var F_LOCALS_7 : WasmTerminals .
  var F_LABELS_8 : WasmTerminals .
  var F_TAGS_9 : WasmTerminals .
  eq typecheck({item('TYPES, F_TYPES_0) ; item('FUNCS, F_FUNCS_1) ; item('GLOBALS, F_GLOBALS_2) ; item('TABLES, F_TABLES_3) ; item('MEMS, F_MEMS_4) ; item('ELEMS, F_ELEMS_5) ; item('DATAS, F_DATAS_6) ; item('LOCALS, F_LOCALS_7) ; item('LABELS, F_LABELS_8) ; item('TAGS, F_TAGS_9)}, free) = typecheck(F_TYPES_0, typeidx) /\ typecheck(F_FUNCS_1, funcidx) /\ typecheck(F_GLOBALS_2, globalidx) /\ typecheck(F_TABLES_3, tableidx) /\ typecheck(F_MEMS_4, memidx) /\ typecheck(F_ELEMS_5, elemidx) /\ typecheck(F_DATAS_6, dataidx) /\ typecheck(F_LOCALS_7, localidx) /\ typecheck(F_LABELS_8, labelidx) /\ typecheck(F_TAGS_9, tagidx) .

  op $free-opt : WasmTerminal -> WasmTerminal .
  eq $free-opt(eps) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .

  var FREE_FREE : WasmTerminal .
  ceq $free-opt(FREE_FREE) = FREE_FREE 
      if typecheck(FREE_FREE, free) .


  op $free-list : WasmTerminal -> WasmTerminal .
  eq $free-list(eps) = {item('TYPES, eps) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} .

  vars FREE_FREE FREE_FREE'* : WasmTerminal .
  ceq $free-list(FREE_FREE FREE_FREE'*) = (FREE_FREE ++ $free-list(FREE_FREE'*)) 
      if typecheck(FREE_FREE, free) /\ typecheck(FREE_FREE'*, free) .


  op $free-typeidx : WasmTerminal -> WasmTerminal .

  var FREE_TYPEIDX : WasmTerminal .
  ceq $free-typeidx(FREE_TYPEIDX) = {item('TYPES, FREE_TYPEIDX) ; item('FUNCS, eps) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_TYPEIDX, typeidx) .


  op $free-funcidx : WasmTerminal -> WasmTerminal .

  var FREE_FUNCIDX : WasmTerminal .
  ceq $free-funcidx(FREE_FUNCIDX) = {item('TYPES, eps) ; item('FUNCS, FREE_FUNCIDX) ; item('GLOBALS, eps) ; item('TABLES, eps) ; item('MEMS, eps) ; item('ELEMS, eps) ; item('DATAS, eps) ; item('LOCALS, eps) ; item('LABELS, eps) ; item('TAGS, eps)} 
      if typecheck(FREE_FUNCIDX, funcidx) .


