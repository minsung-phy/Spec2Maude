      if typecheck(GROWTABLE_TABLEINST, tableinst) /\ typecheck(GROWTABLE_WN, w-n) /\ typecheck(GROWTABLE_WR, ref) /\ typecheck(GROWTABLE_TABLEINST', tableinst) /\ typecheck(GROWTABLE_AT, addrtype) /\ typecheck(GROWTABLE_WI, u64) /\ typecheck(GROWTABLE_J?, u64) /\ typecheck(GROWTABLE_RT, reftype) /\ typecheck(GROWTABLE_R'*, ref) /\ typecheck(GROWTABLE_I', u64) /\ (GROWTABLE_TABLEINST == {item('TYPE, (GROWTABLE_AT lbrack GROWTABLE_WI dotdot GROWTABLE_J? rbrack GROWTABLE_RT)) ; item('REFS, GROWTABLE_R'*)}) /\ (GROWTABLE_TABLEINST' == {item('TYPE, (GROWTABLE_AT lbrack GROWTABLE_I' dotdot GROWTABLE_J? rbrack GROWTABLE_RT)) ; item('REFS, GROWTABLE_R'* GROWTABLE_WR)}) /\ (GROWTABLE_I' == (len(GROWTABLE_R'*) + GROWTABLE_WN)) /\ (GROWTABLE_I' <= W-J) .


