load dsl/pretype 

mod SPECTEC-CORE is
  inc DSL-RECORD .
  inc BOOL .
  inc INT .

  --- Base Sorts
  subsort Int < WasmTerminal .
  subsort Nat < WasmTerminal .

  --- Allow type atoms to appear as terminals (for mixed AST encodings)
  subsort WasmType < WasmTerminal .
  subsort WasmTypes < WasmTerminals .

  --- Bool wrapper (avoid subsort Bool < WasmTerminal conflicts)
  op w-bool : Bool -> WasmTerminal [ctor] .

  --- Basic Wasm Types
  ops w-N w-M w-K w-n w-m w-X w-C w-I w-S w-T w-V w-b w-z w-L w-E : -> WasmType [ctor] .

  --- Special Operators
  op _shape-x_ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op slice : WasmTerminals WasmTerminal WasmTerminal -> WasmTerminals .
  op _<-_ : WasmTerminal WasmTerminals -> Bool .

  --- Generic record/terminal combinators (parser support)
  op merge : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op _=++_ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op any : -> WasmTerminal [ctor] .

  --- Common variables (declared once)
  var I : Int .
  vars W-I EXP : Int .
  vars W-N W-M : Nat .
  vars T W WW W-X : WasmTerminal .
  vars TS W* : WasmTerminals .

  --- Auto-collected tokens
  ops C Fnn FnnN1 FnnN2 Inn InnN1 InnN2 Jnn JnnN1 JnnN2 Lnn LnnN1 LnnN2 MN1 MN2 Vnn XN1 XN2 XN3 XN4 : -> WasmTerminal [ctor] .


  --- Auto-declared helper calls
  op $f : WasmTerminal WasmTerminal -> WasmTerminal .
  op $f : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .
  op $f : WasmTerminal WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .


  --- Declarations
  op $ANYREF :  -> WasmTerminal .
  op $ARRAYREF :  -> WasmTerminal .
  op $EQREF :  -> WasmTerminal .
  op $EXNREF :  -> WasmTerminal .
  op $EXTERNREF :  -> WasmTerminal .
