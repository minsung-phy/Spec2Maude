  --- Equations
  eq $replace-localtype ( CTORSETA0 LOCALTYPE-T LOCALTYPE-REST, 0, LOCALTYPE-LCT ) = LOCALTYPE-LCT LOCALTYPE-REST .
  eq $replace-localtype ( CTORUNSETA0 LOCALTYPE-T LOCALTYPE-REST, 0, LOCALTYPE-LCT ) = LOCALTYPE-LCT LOCALTYPE-REST .
  eq $replace-localtype ( CTORSETA0 LOCALTYPE-T LOCALTYPE-REST, s ( LOCALTYPE-N ), LOCALTYPE-LCT ) = CTORSETA0 LOCALTYPE-T $replace-localtype ( LOCALTYPE-REST, LOCALTYPE-N, LOCALTYPE-LCT ) .
  eq $replace-localtype ( CTORUNSETA0 LOCALTYPE-T LOCALTYPE-REST, s ( LOCALTYPE-N ), LOCALTYPE-LCT ) = CTORUNSETA0 LOCALTYPE-T $replace-localtype ( LOCALTYPE-REST, LOCALTYPE-N, LOCALTYPE-LCT ) .

  eq typecheck(JHS-T, N) = typecheck(JHS-T, nat) .

  eq typecheck(JHS-T, M) = typecheck(JHS-T, nat) .

  eq typecheck(JHS-T, K) = typecheck(JHS-T, nat) .

  eq typecheck(JHS-T, n) = typecheck(JHS-T, nat) .

  eq typecheck(JHS-T, m) = typecheck(JHS-T, nat) .




  ceq $min ( MIN0-LOWI, MIN0-LOWJ ) = $raw-lit ( MIN0-LOWI )

      if _<=_ ( ( $raw-lit ( MIN0-LOWI ) ), ( $raw-lit ( MIN0-LOWJ ) ) ) .
  eq $min ( MIN1-LOWI, MIN1-LOWJ ) = $raw-lit ( MIN1-LOWJ ) [owise] .




  eq $sum ( eps ) = 0 .
  eq $sum ( ( SUM1-LOWN SUM1-NSQ ) ) = _+_ ( ( $raw-lit ( SUM1-LOWN ) ), ( $sum ( SUM1-NSQ ) ) ) .





  eq $prod ( eps ) = 1 .
  eq $prod ( ( PROD1-LOWN PROD1-NSQ ) ) = _*_ ( ( $raw-lit ( PROD1-LOWN ) ), ( $prod ( PROD1-NSQ ) ) ) .





  eq $opt ( eps ) = eps .
  eq $opt ( OPT1-LOWW ) = OPT1-LOWW .





  eq $concat ( eps ) = eps .
  eq $concat ( ( CONCAT1-WS CONCAT1-WQS ) ) = CONCAT1-WS $concat ( CONCAT1-WQS ) .





  eq $concatn ( eps, CONCATN0-LOWN ) = eps .
  eq $concatn ( ( $repeat ( CONCATN1-WS, $raw-lit ( CONCATN1-LOWN ) ) $map-Srepeat-a2-s0 ( CONCATN1-WQS, ( $raw-lit ( CONCATN1-LOWN ) ) ) ), CONCATN1-LOWN ) = $repeat ( CONCATN1-WS, $raw-lit ( CONCATN1-LOWN ) ) $concatn ( ( $map-Srepeat-a2-s0 ( CONCATN1-WQS, ( $raw-lit ( CONCATN1-LOWN ) ) ) ), ( $raw-lit ( CONCATN1-LOWN ) ) ) .





  eq $concatopt ( eps ) = eps .
  eq $concatopt ( ( CONCATOPT1-WS CONCATOPT1-WQS ) ) = CONCATOPT1-WS $concat ( CONCATOPT1-WQS ) .

















  eq $disjoint ( eps ) = true .
  eq $disjoint ( ( DISJOINT1-LOWW DISJOINT1-WSQ ) ) = _and_ ( not ( ( DISJOINT1-LOWW <- DISJOINT1-WSQ ) ), $disjoint ( DISJOINT1-WSQ ) ) .





  eq $setminus1 ( SETMINUS10-LOWW, eps ) = SETMINUS10-LOWW .
  ceq $setminus1 ( SETMINUS11-LOWW, ( SETMINUS11-W1 SETMINUS11-WSQ ) ) = eps
