      if typecheck(RUNELEM_WX, idx) /\ typecheck(RUNELEM_RT, reftype) /\ typecheck(RUNELEM_E*, expr) /\ typecheck(RUNELEM_WN, w-n) .

  vars RUNELEM_E* RUNELEM_RT RUNELEM_WN RUNELEM_WX W-E : WasmTerminal .
  ceq $runelem-(RUNELEM_WX, ELEM RUNELEM_RT W-E DECLARE) = ELEM.DROP RUNELEM_WX 
      if typecheck(RUNELEM_WX, idx) /\ typecheck(RUNELEM_RT, reftype) /\ typecheck(RUNELEM_E*, expr) /\ typecheck(RUNELEM_WN, w-n) .

  vars RUNELEM_E* RUNELEM_INSTR* RUNELEM_RT RUNELEM_WN RUNELEM_WX RUNELEM_WY W-E : WasmTerminal .
  ceq $runelem-(RUNELEM_WX, ELEM RUNELEM_RT W-E ACTIVE RUNELEM_WY RUNELEM_INSTR*) = RUNELEM_INSTR* CONST I32 0 CONST I32 RUNELEM_WN TABLE.INIT RUNELEM_WY RUNELEM_WX ELEM.DROP RUNELEM_WX 
      if typecheck(RUNELEM_WX, idx) /\ typecheck(RUNELEM_RT, reftype) /\ typecheck(RUNELEM_E*, expr) /\ typecheck(RUNELEM_WN, w-n) /\ typecheck(RUNELEM_WY, idx) /\ typecheck(RUNELEM_INSTR*, instr) .


  op $evalexprs : WasmTerminal WasmTerminal -> WasmTerminal .

  var EVALEXPRS_WZ : WasmTerminal .
  ceq $evalexprs(EVALEXPRS_WZ, eps) = (EVALEXPRS_WZ eps) 
      if typecheck(EVALEXPRS_WZ, state) .

  vars EVALEXPRS_EXPR EVALEXPRS_EXPR'* EVALEXPRS_REF EVALEXPRS_REF'* EVALEXPRS_WZ EVALEXPRS_Z' EVALEXPRS_Z'' : WasmTerminal .
  ceq $evalexprs(EVALEXPRS_WZ, EVALEXPRS_EXPR EVALEXPRS_EXPR'*) = (EVALEXPRS_Z'' EVALEXPRS_REF EVALEXPRS_REF'*) 
      if typecheck(EVALEXPRS_WZ, state) /\ typecheck(EVALEXPRS_EXPR, expr) /\ typecheck(EVALEXPRS_EXPR'*, expr) /\ typecheck(EVALEXPRS_Z'', state) /\ typecheck(EVALEXPRS_REF, ref) /\ typecheck(EVALEXPRS_REF'*, ref) /\ typecheck(EVALEXPRS_Z', state) /\ Eval-expr(EVALEXPRS_WZ EVALEXPRS_EXPR EVALEXPRS_Z' EVALEXPRS_REF) /\ ((EVALEXPRS_Z'' EVALEXPRS_REF'*) == $evalexprs(EVALEXPRS_Z', EVALEXPRS_EXPR'*)) .


  op $evalexprss : WasmTerminal WasmTerminal -> WasmTerminal .

  var EVALEXPRSS_WZ : WasmTerminal .
  ceq $evalexprss(EVALEXPRSS_WZ, eps) = (EVALEXPRSS_WZ eps) 
      if typecheck(EVALEXPRSS_WZ, state) .

  vars EVALEXPRSS_EXPR'** EVALEXPRSS_EXPR* EVALEXPRSS_REF'** EVALEXPRSS_REF* EVALEXPRSS_WZ EVALEXPRSS_Z' EVALEXPRSS_Z'' EXPR'* REF'* : WasmTerminal .
  ceq $evalexprss(EVALEXPRSS_WZ, EVALEXPRSS_EXPR* EXPR'*) = (EVALEXPRSS_Z'' EVALEXPRSS_REF* REF'*) 
      if typecheck(EVALEXPRSS_WZ, state) /\ typecheck(EVALEXPRSS_EXPR*, expr) /\ typecheck(EVALEXPRSS_EXPR'**, expr) /\ typecheck(EVALEXPRSS_Z'', state) /\ typecheck(EVALEXPRSS_REF*, ref) /\ typecheck(EVALEXPRSS_REF'**, ref) /\ typecheck(EVALEXPRSS_Z', state) /\ ((EVALEXPRSS_Z' EVALEXPRSS_REF*) == $evalexprs(EVALEXPRSS_WZ, EVALEXPRSS_EXPR*)) /\ ((EVALEXPRSS_Z'' REF'*) == $evalexprss(EVALEXPRSS_Z', EXPR'*)) .


  op $evalglobals : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  var EVALGLOBALS_WZ : WasmTerminal .
  ceq $evalglobals(EVALGLOBALS_WZ, eps, eps) = (EVALGLOBALS_WZ eps) 
      if typecheck(EVALGLOBALS_WZ, state) .

  vars EVALGLOBALS_EXPR EVALGLOBALS_EXPR'* EVALGLOBALS_GT EVALGLOBALS_GT'* EVALGLOBALS_S' EVALGLOBALS_VAL EVALGLOBALS_VAL'* EVALGLOBALS_WA EVALGLOBALS_WF EVALGLOBALS_WS EVALGLOBALS_WZ EVALGLOBALS_Z' EVALGLOBALS_Z'' : WasmTerminal .
  ceq $evalglobals(EVALGLOBALS_WZ, EVALGLOBALS_GT EVALGLOBALS_GT'*, EVALGLOBALS_EXPR EVALGLOBALS_EXPR'*) = (EVALGLOBALS_Z'' EVALGLOBALS_VAL EVALGLOBALS_VAL'*) 
      if typecheck(EVALGLOBALS_WZ, state) /\ typecheck(EVALGLOBALS_GT, globaltype) /\ typecheck(EVALGLOBALS_GT'*, globaltype) /\ typecheck(EVALGLOBALS_EXPR, expr) /\ typecheck(EVALGLOBALS_EXPR'*, expr) /\ typecheck(EVALGLOBALS_Z'', state) /\ typecheck(EVALGLOBALS_VAL, val) /\ typecheck(EVALGLOBALS_VAL'*, val) /\ typecheck(EVALGLOBALS_Z', state) /\ typecheck(EVALGLOBALS_WS, store) /\ typecheck(EVALGLOBALS_WF, frame) /\ typecheck(EVALGLOBALS_S', store) /\ typecheck(EVALGLOBALS_WA, addr) /\ Eval-expr(EVALGLOBALS_WZ EVALGLOBALS_EXPR EVALGLOBALS_Z' EVALGLOBALS_VAL) /\ (EVALGLOBALS_Z' == EVALGLOBALS_WS semicolon EVALGLOBALS_WF) /\ ((EVALGLOBALS_S' EVALGLOBALS_WA) == $allocglobal(EVALGLOBALS_WS, EVALGLOBALS_GT, EVALGLOBALS_VAL)) /\ ((EVALGLOBALS_Z'' EVALGLOBALS_VAL'*) == $evalglobals(EVALGLOBALS_S' semicolon (EVALGLOBALS_WF[.'MODULE <- (value('MODULE, EVALGLOBALS_WF) ++ {item('GLOBALS, EVALGLOBALS_WA)})]), EVALGLOBALS_GT'*, EVALGLOBALS_EXPR'*)) .


  op $instantiate : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars BYTE* DATAMODE ELEMMODE EXPR-E* EXPR-G EXPR-T EXTERNADDR GLOBALTYPE I-D I-E I-F INSTANTIATE_BYTE** INSTANTIATE_DATA* INSTANTIATE_DATAMODE* INSTANTIATE_ELEM* INSTANTIATE_ELEMMODE* INSTANTIATE_EXPORT* INSTANTIATE_EXPRE** INSTANTIATE_EXPRG* INSTANTIATE_EXPRT* INSTANTIATE_EXTERNADDR* INSTANTIATE_FUNC* INSTANTIATE_GLOBAL* INSTANTIATE_GLOBALTYPE* INSTANTIATE_ID* INSTANTIATE_IE* INSTANTIATE_IF* INSTANTIATE_IMPORT* INSTANTIATE_INSTRD* INSTANTIATE_INSTRE* INSTANTIATE_INSTRS? INSTANTIATE_MEM* INSTANTIATE_MODULE INSTANTIATE_MODULEINST INSTANTIATE_MODULEINST0 INSTANTIATE_REFE** INSTANTIATE_REFT* INSTANTIATE_REFTYPE* INSTANTIATE_S''' INSTANTIATE_S'''' INSTANTIATE_START? INSTANTIATE_TABLE* INSTANTIATE_TABLETYPE* INSTANTIATE_TAG* INSTANTIATE_TYPE* INSTANTIATE_VALG* INSTANTIATE_WF INSTANTIATE_WS INSTANTIATE_WZ INSTANTIATE_X? INSTANTIATE_XTE* INSTANTIATE_XTI* INSTANTIATE_Z' INSTANTIATE_Z'' INSTANTIATE_Z''' REF-E* REFTYPE TABLETYPE W-X XT-I : WasmTerminal .
  ceq $instantiate(INSTANTIATE_WS, INSTANTIATE_MODULE, INSTANTIATE_EXTERNADDR*) = INSTANTIATE_S'''' semicolon {item('LOCALS, eps) ; item('MODULE, INSTANTIATE_MODULEINST)} semicolon INSTANTIATE_INSTRE* INSTANTIATE_INSTRD* INSTANTIATE_INSTRS? 
      if typecheck(INSTANTIATE_WS, store) /\ typecheck(INSTANTIATE_MODULE, module) /\ typecheck(INSTANTIATE_EXTERNADDR*, externaddr) /\ typecheck(INSTANTIATE_S'''', store) /\ typecheck(INSTANTIATE_MODULEINST, moduleinst) /\ typecheck(INSTANTIATE_INSTRE*, instr) /\ typecheck(INSTANTIATE_INSTRD*, instr) /\ typecheck(INSTANTIATE_INSTRS?, instr) /\ typecheck(INSTANTIATE_XTI*, externtype) /\ typecheck(INSTANTIATE_XTE*, externtype) /\ typecheck(INSTANTIATE_TYPE*, type) /\ typecheck(INSTANTIATE_IMPORT*, import) /\ typecheck(INSTANTIATE_TAG*, tag) /\ typecheck(INSTANTIATE_GLOBAL*, global) /\ typecheck(INSTANTIATE_MEM*, mem) /\ typecheck(INSTANTIATE_TABLE*, table) /\ typecheck(INSTANTIATE_FUNC*, func) /\ typecheck(INSTANTIATE_DATA*, data) /\ typecheck(INSTANTIATE_ELEM*, elem) /\ typecheck(INSTANTIATE_START?, start) /\ typecheck(INSTANTIATE_EXPORT*, export) /\ typecheck(INSTANTIATE_GLOBALTYPE*, globaltype) /\ typecheck(INSTANTIATE_EXPRG*, expr) /\ typecheck(INSTANTIATE_TABLETYPE*, tabletype) /\ typecheck(INSTANTIATE_EXPRT*, expr) /\ typecheck(INSTANTIATE_BYTE**, byte) /\ typecheck(INSTANTIATE_DATAMODE*, datamode) /\ typecheck(INSTANTIATE_REFTYPE*, reftype) /\ typecheck(INSTANTIATE_EXPRE**, expr) /\ typecheck(INSTANTIATE_ELEMMODE*, elemmode) /\ typecheck(INSTANTIATE_X?, idx) /\ typecheck(INSTANTIATE_MODULEINST0, moduleinst) /\ typecheck(INSTANTIATE_WZ, state) /\ typecheck(INSTANTIATE_Z', state) /\ typecheck(INSTANTIATE_VALG*, val) /\ typecheck(INSTANTIATE_Z'', state) /\ typecheck(INSTANTIATE_REFT*, ref) /\ typecheck(INSTANTIATE_Z''', state) /\ typecheck(INSTANTIATE_REFE**, ref) /\ typecheck(INSTANTIATE_S''', store) /\ typecheck(INSTANTIATE_WF, frame) /\ Module-ok(INSTANTIATE_MODULE INSTANTIATE_XTI* arrow INSTANTIATE_XTE*) /\ Externaddr-ok(INSTANTIATE_WS EXTERNADDR XT-I) /\ (INSTANTIATE_MODULE == MODULE INSTANTIATE_TYPE* INSTANTIATE_IMPORT* INSTANTIATE_TAG* INSTANTIATE_GLOBAL* INSTANTIATE_MEM* INSTANTIATE_TABLE* INSTANTIATE_FUNC* INSTANTIATE_DATA* INSTANTIATE_ELEM* INSTANTIATE_START? INSTANTIATE_EXPORT*) /\ (INSTANTIATE_GLOBAL* == GLOBAL GLOBALTYPE EXPR-G) /\ (INSTANTIATE_TABLE* == TABLE TABLETYPE EXPR-T) /\ (INSTANTIATE_DATA* == DATA BYTE* DATAMODE) /\ (INSTANTIATE_ELEM* == ELEM REFTYPE EXPR-E* ELEMMODE) /\ (INSTANTIATE_START? == START W-X) /\ (INSTANTIATE_MODULEINST0 == {item('TYPES, $alloctypes(INSTANTIATE_TYPE*)) ; item('TAGS, eps) ; item('GLOBALS, $globalsxa(INSTANTIATE_EXTERNADDR*)) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, $funcsxa(INSTANTIATE_EXTERNADDR*) (len(value('FUNCS, INSTANTIATE_WS)) + I-F)) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('EXPORTS, eps)}) /\ (INSTANTIATE_WZ == INSTANTIATE_WS semicolon {item('LOCALS, eps) ; item('MODULE, INSTANTIATE_MODULEINST0)}) /\ ((INSTANTIATE_Z' INSTANTIATE_VALG*) == $evalglobals(INSTANTIATE_WZ, INSTANTIATE_GLOBALTYPE*, INSTANTIATE_EXPRG*)) /\ ((INSTANTIATE_Z'' INSTANTIATE_REFT*) == $evalexprs(INSTANTIATE_Z', INSTANTIATE_EXPRT*)) /\ ((INSTANTIATE_Z''' REF-E*) == $evalexprss(INSTANTIATE_Z'', EXPR-E*)) /\ (INSTANTIATE_Z''' == INSTANTIATE_S''' semicolon INSTANTIATE_WF) /\ ((INSTANTIATE_S'''' INSTANTIATE_MODULEINST) == $allocmodule(INSTANTIATE_S''', INSTANTIATE_MODULE, INSTANTIATE_EXTERNADDR*, INSTANTIATE_VALG*, INSTANTIATE_REFT*, REF-E*)) /\ (INSTANTIATE_INSTRD* == $concat-(eps, $rundata-(I-D, index(INSTANTIATE_DATA*, I-D)))) /\ (INSTANTIATE_INSTRE* == $concat-(eps, $runelem-(I-E, index(INSTANTIATE_ELEM*, I-E)))) /\ (INSTANTIATE_INSTRS? == CALL W-X) .


  op $invoke : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .

  vars INVOKE_FUNCADDR INVOKE_T1* INVOKE_T2* INVOKE_VAL* INVOKE_WS T-1 VAL : WasmTerminal .
  ceq $invoke(INVOKE_WS, INVOKE_FUNCADDR, INVOKE_VAL*) = INVOKE_WS semicolon {item('LOCALS, eps) ; item('MODULE, {item('TYPES, eps) ; item('TAGS, eps) ; item('GLOBALS, eps) ; item('MEMS, eps) ; item('TABLES, eps) ; item('FUNCS, eps) ; item('DATAS, eps) ; item('ELEMS, eps) ; item('EXPORTS, eps)})} semicolon VAL REF.FUNC-ADDR INVOKE_FUNCADDR CALL-REF value('TYPE, index(value('FUNCS, INVOKE_WS), INVOKE_FUNCADDR)) 
      if typecheck(INVOKE_WS, store) /\ typecheck(INVOKE_FUNCADDR, funcaddr) /\ typecheck(INVOKE_VAL*, val) /\ typecheck(INVOKE_T1*, valtype) /\ typecheck(INVOKE_T2*, valtype) /\ Expand(value('TYPE, index(value('FUNCS, INVOKE_WS), INVOKE_FUNCADDR)) FUNC INVOKE_T1* arrow INVOKE_T2*) /\ Val-ok(INVOKE_WS VAL T-1) .


endm

