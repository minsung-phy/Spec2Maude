load dsl/pretype 

load 1-1 

mod 1_2_SYNTAX_VALUES is
  inc DSL-TERM .
  inc DSL-PRETYPE .
  inc DSL-EXEC .

  inc 1_1_SYNTAX_VALUES .

  subsort Int < WasmTerminal .
  subsort Nat < WasmTerminal .

  op nat : -> WasmType . 
  var i : Int .
  var T : WasmTerminal .

  op N :  -> WasmType .
  eq typecheck(T, N) = typecheck(T, WasmType) .
  op M :  -> WasmType .
  eq typecheck(T, M) = typecheck(T, WasmType) .
  op K :  -> WasmType .
  eq typecheck(T, K) = typecheck(T, WasmType) .
  op n :  -> WasmType .
  eq typecheck(T, n) = typecheck(T, WasmType) .
  op m :  -> WasmType .
  eq typecheck(T, m) = typecheck(T, WasmType) .

  op $min : WasmTerminal WasmTerminal -> WasmTerminal .
  var NAT : WasmTerminal .
  var NAT : WasmTerminal .
  var I : WasmTerminal .
  eq $min(I) = I .
  var I : WasmTerminal .
  eq $min(I) = J .


  op $sum : WasmTerminal -> WasmTerminal .
  var _ : WasmTerminal .
  eq sum(0) = 0 .
  eq sum(0) = (N + sum(0)) .


  op $prod : WasmTerminal -> WasmTerminal .
  var _ : WasmTerminal .
  eq prod(0) = 1 .
  eq prod(0) = (N * prod(0)) .


  op $opt_ : WasmTerminal WasmTerminal -> WasmTerminal .
