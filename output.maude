  op exp :  -> WasmType .
  eq typecheck(T, exp) = typecheck(T, WasmType) .
  op fNmag : WasmTerminal -> WasmType .
  var N_FNMAG : Nat .
  ceq typecheck(i, fNmag(N_FNMAG)) = true 
   if typecheck(N_FNMAG, N) /\ ((M < (2 ^ M(N_FNMAG))) /\ (((2 - (2 ^ (E(N_FNMAG) - 1))) <= EXP) /\ (EXP <= ((2 ^ (E(N_FNMAG) - 1)) - 1)))) .
  ceq typecheck(i, fNmag(N_FNMAG)) = true 
   if typecheck(N_FNMAG, N) /\ ((M < (2 ^ M(N_FNMAG))) /\ ((2 - (2 ^ (E(N_FNMAG) - 1))) == EXP)) .
  op INF : -> WasmTerminal .
  eq typecheck(INF, fNmag) = true .
  ceq typecheck(i, fNmag(N_FNMAG)) = true 
   if typecheck(N_FNMAG, N) /\ ((1 <= M) /\ (M < (2 ^ M(N_FNMAG)))) .
