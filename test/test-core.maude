--- =========================================================================
--- Spec2Maude Integration Test Suite
---
--- Tests the SPECTEC-CORE module's equational semantics:
---   1. Size/type primitives
---   2. Integer arithmetic ($iadd, $isub, $imul, $binop dispatch)
---   3. Comparison/test operators ($ieqz, $ieq, $ilt, $relop, $testop)
---   4. Conversion helpers ($signed, $inv-signed, $bool)
---   5. Aggregation helpers ($min, $sum, $prod)
---   6. Type-checking predicates (is-type)
---   7. Record operations (value, field update)
---   8. Step-pure reduction predicates (NOP, UNREACHABLE, BR-IF)
---
--- Run:  maude test/test-core.maude
--- All results appear after "result" lines.  Grep for unexpected values.
--- =========================================================================

load ../output.maude

--- =========================================================================
--- 1. Size / type primitives
--- =========================================================================

--- $size(I32) should be 32
red in SPECTEC-CORE : $size(I32) .

--- $size(I64) should be 64
red in SPECTEC-CORE : $size(I64) .

--- $size(F32) should be 32
red in SPECTEC-CORE : $size(F32) .

--- $sizenn(I32) = $size(I32) = 32  (requires is-type(I32, numtype) = true)
red in SPECTEC-CORE : $sizenn(I32) .

--- is-type(I32, numtype) should be true
red in SPECTEC-CORE : is-type(I32, numtype) .

--- is-type(I32, Inn) should be true  (I32 is an addrtype)
red in SPECTEC-CORE : is-type(I32, Inn) .

--- is-type(I32, addrtype) should be true
red in SPECTEC-CORE : is-type(I32, addrtype) .

--- =========================================================================
--- 2. Integer arithmetic
--- =========================================================================

--- $iadd(32, 3, 5) = (3 + 5) rem 2^32 = 8
red in SPECTEC-CORE : $iadd(32, 3, 5) .

--- $iadd(32, 0, 0) = 0
red in SPECTEC-CORE : $iadd(32, 0, 0) .

--- $isub(32, 10, 3) = (2^32 + 10 - 3) rem 2^32 = 7
red in SPECTEC-CORE : $isub(32, 10, 3) .

--- $isub(32, 0, 1) = (2^32 + 0 - 1) rem 2^32 = 4294967295  (unsigned wrap)
red in SPECTEC-CORE : $isub(32, 0, 1) .

--- $imul(32, 4, 5) = (4 * 5) rem 2^32 = 20
red in SPECTEC-CORE : $imul(32, 4, 5) .

--- $imul(32, 7, 7) = 49
red in SPECTEC-CORE : $imul(32, 7, 7) .

--- $binop(I32, ADD, 3, 5) should dispatch to $iadd(32, 3, 5) = 8
red in SPECTEC-CORE : $binop(I32, ADD, 3, 5) .

--- $binop(I32, SUB, 10, 3) should dispatch to $isub(32, 10, 3) = 7
red in SPECTEC-CORE : $binop(I32, SUB, 10, 3) .

--- $binop(I32, MUL, 6, 7) should dispatch to $imul(32, 6, 7) = 42
red in SPECTEC-CORE : $binop(I32, MUL, 6, 7) .

--- Large number: $iadd(32, 2147483647, 1) = 2147483648 (no overflow in u32)
red in SPECTEC-CORE : $iadd(32, 2147483647, 1) .

--- =========================================================================
--- 3. Comparison / test operators
--- =========================================================================

--- $bool(w-bool(true)) = 1
red in SPECTEC-CORE : $bool(w-bool(true)) .

--- $bool(w-bool(false)) = 0
red in SPECTEC-CORE : $bool(w-bool(false)) .

--- $ieqz(32, 0) = $bool(w-bool(0 == 0)) = $bool(w-bool(true)) = 1
red in SPECTEC-CORE : $ieqz(32, 0) .

--- $ieqz(32, 42) = $bool(w-bool(42 == 0)) = $bool(w-bool(false)) = 0
red in SPECTEC-CORE : $ieqz(32, 42) .

--- $ieq(32, 5, 5) = $bool(w-bool(5 == 5)) = 1
red in SPECTEC-CORE : $ieq(32, 5, 5) .

--- $ieq(32, 5, 6) = $bool(w-bool(5 == 6)) = 0
red in SPECTEC-CORE : $ieq(32, 5, 6) .

--- $ilt(32, w-U, 3, 5) = $bool(w-bool(3 < 5)) = 1
red in SPECTEC-CORE : $ilt(32, w-U, 3, 5) .

--- $ilt(32, w-U, 5, 3) = $bool(w-bool(5 < 3)) = 0
red in SPECTEC-CORE : $ilt(32, w-U, 5, 3) .

--- $testop(I32, EQZ, 0) should dispatch to $ieqz(32, 0) = 1
red in SPECTEC-CORE : $testop(I32, EQZ, 0) .

--- $testop(I32, EQZ, 1) should dispatch to $ieqz(32, 1) = 0
red in SPECTEC-CORE : $testop(I32, EQZ, 1) .

--- $relop(I32, w-EQ, 42, 42) should dispatch to $ieq(32, 42, 42) = 1
red in SPECTEC-CORE : $relop(I32, w-EQ, 42, 42) .

--- $relop(I32, w-EQ, 42, 43) = 0
red in SPECTEC-CORE : $relop(I32, w-EQ, 42, 43) .

--- =========================================================================
--- 4. Conversion helpers
--- =========================================================================

--- $signed(32, 3) = 3  (3 < 2^31, stays positive)
red in SPECTEC-CORE : $signed(32, 3) .

--- $signed(32, 2147483648) = 2147483648 - 2^32 = -2147483648
red in SPECTEC-CORE : $signed(32, 2147483648) .

--- $inv-signed(32, -1) = -1 + 2^32 = 4294967295
red in SPECTEC-CORE : $inv-signed(32, -1) .

--- $inv-signed(32, 3) = 3  (positive stays positive)
red in SPECTEC-CORE : $inv-signed(32, 3) .

--- =========================================================================
--- 5. Aggregation helpers
--- =========================================================================

--- $min(3, 5) = 3
red in SPECTEC-CORE : $min(3, 5) .

--- $min(7, 2) = 2
red in SPECTEC-CORE : $min(7, 2) .

--- $min(4, 4) = 4
red in SPECTEC-CORE : $min(4, 4) .

--- $sum(eps) = 0
red in SPECTEC-CORE : $sum(eps) .

--- NOTE: $sum(1 2 3) and $prod(2 3 4) do NOT reduce because the translator
--- declares `op $sum : WasmTerminal -> WasmTerminal` but equations pattern-match
--- on WasmTerminals (e.g. $sum(WN N*)). This is a known sort-mismatch limitation.

--- $prod(eps) = 1
red in SPECTEC-CORE : $prod(eps) .

--- =========================================================================
--- 6. Type-checking predicates
--- =========================================================================

--- is-type(42, w-N) = true  (w-N accepts anything)
red in SPECTEC-CORE : is-type(42, w-N) .

--- is-type(42, w-n) = true  (w-n accepts anything)
red in SPECTEC-CORE : is-type(42, w-n) .

--- is-type(3, uN(32)) = true  (0 <= 3 <= 2^32 - 1)
red in SPECTEC-CORE : is-type(3, uN(32)) .

--- is-type(3, iN(32)) = true
red in SPECTEC-CORE : is-type(3, iN(32)) .

--- is-type(3, num(I32)) = true  (3 is a valid i32 value)
red in SPECTEC-CORE : is-type(3, num(I32)) .

--- is-type(NOP, instr) = true
red in SPECTEC-CORE : is-type(NOP, instr) .

--- is-type(UNREACHABLE, instr) = true
red in SPECTEC-CORE : is-type(UNREACHABLE, instr) .

--- is-type(DROP, instr) = true
red in SPECTEC-CORE : is-type(DROP, instr) .

--- is-type(CONST I32 42, instr) = true
red in SPECTEC-CORE : is-type(CONST I32 42, instr) .

--- is-type(ADD, binop(I32)) = true  (ADD is a valid binop for Inn)
red in SPECTEC-CORE : is-type(ADD, binop(I32)) .

--- is-type(SUB, binop(I32)) = true
red in SPECTEC-CORE : is-type(SUB, binop(I32)) .

--- is-type(MUL, binop(I32)) = true
red in SPECTEC-CORE : is-type(MUL, binop(I32)) .

--- is-type(EQZ, testop(I32)) = true
red in SPECTEC-CORE : is-type(EQZ, testop(I32)) .

--- =========================================================================
--- 7. Record operations
--- =========================================================================

--- value('FOO, {item('FOO, 42) ; item('BAR, 99)}) = 42
red in SPECTEC-CORE : value('FOO, {item('FOO, 42) ; item('BAR, 99)}) .

--- value('BAR, {item('FOO, 42) ; item('BAR, 99)}) = 99
red in SPECTEC-CORE : value('BAR, {item('FOO, 42) ; item('BAR, 99)}) .

--- Field update: {item('X, 1) ; item('Y, 2)} [. 'X <- 10 ]
--- should produce {item('X, 10) ; item('Y, 2)}
red in SPECTEC-CORE : {item('X, 1) ; item('Y, 2)} [. 'X <- 10 ] .

--- value after update: value('X, ...[. 'X <- 10]) should be 10
red in SPECTEC-CORE : value('X, {item('X, 1) ; item('Y, 2)} [. 'X <- 10 ]) .

--- =========================================================================
--- 8. Step-pure reduction predicates
--- =========================================================================

--- Step-pure(NOP, eps) = true
red in SPECTEC-CORE : Step-pure(NOP, eps) .

--- Step-pure(UNREACHABLE, TRAP) = true
red in SPECTEC-CORE : Step-pure(UNREACHABLE, TRAP) .

--- NOTE: Drop/IF/LABEL/FRAME/LOCAL-TEE Step-pure tests don't reduce due
--- to Maude's kind-level matching with associative operators. Multi-element
--- WasmTerminals in Step-pure args (declared as WasmTerminal) cause
--- matching failures at the kind level. BR-IF works because its first-arg
--- pattern uses only ctor mixfix ops (CONST _ _, BR-IF _).

--- Step-pure for BR-IF-TRUE:
---   CONST I32 1 BR-IF 0 --> BR 0  (when c != 0)
red in SPECTEC-CORE : Step-pure(
  CONST I32 1 BR-IF 0,
  BR 0
) .

--- Step-pure for BR-IF-FALSE:
---   CONST I32 0 BR-IF 0 --> eps  (when c == 0)
red in SPECTEC-CORE : Step-pure(
  CONST I32 0 BR-IF 0,
  eps
) .

--- NOTE: Some multi-instruction Step-pure patterns (IF, DROP, LOCAL-TEE, etc.)
--- don't reduce due to kind-level matching limitations with the assoc `_ _`
--- operator.  Step-pure takes WasmTerminal but instruction sequences are
--- WasmTerminals.  BR-IF succeeds because its pattern uses only ctor
--- mixfix operators (CONST _ _, BR-IF _) for unambiguous assoc matching.

--- =========================================================================
--- End of test suite
--- =========================================================================

q
