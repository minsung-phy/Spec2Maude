syntax null = NULL

syntax addrtype =
  | I32 | I64

syntax numtype =
  | I32 | I64 | F32 | F64

syntax deftype =
  | _DEF rectype n

syntax typeuse/syn =
  | _IDX typeidx | ...
syntax typeuse/sem =
  | ... | deftype | REC n 

def $size(numtype) : nat       
def $size(I32) = 32
def $size(I64) = 64
def $size(F32) = 32
def $size(F64) = 64

def $sizenn(numtype) : nat   
def $sizenn(nt) = $size(nt)

syntax Inn = addrtype

syntax valtype/syn =
  | numtype | ...