load dsl/pretype 

mod SPECTEC-CORE is
  inc DSL-RECORD .
  inc BOOL .
  inc INT .

  --- Base Sorts
  subsort Int < WasmTerminal .
  subsort Nat < WasmTerminal .

  --- Allow type atoms to appear as terminals (for mixed AST encodings)
  subsort WasmType < WasmTerminal .
  subsort WasmTypes < WasmTerminals .

  --- Nat is a subtype of index-like and numeric-parameter sorts
  --- (spectec idx = u32 = nat; N/M/K are nat-valued type parameters)
  subsort Nat < N .
  subsort Nat < M .
  subsort Nat < K .
  subsort Nat < Labelidx .
  subsort Nat < Localidx .
  subsort Nat < Typeidx .
  subsort Nat < Funcidx .
  subsort Nat < Globalidx .
  subsort Nat < Tableidx .
  subsort Nat < Memidx .
  subsort Nat < Tagidx .
  subsort Nat < Elemidx .
  subsort Nat < Dataidx .
  subsort Nat < Fieldidx .
  subsort Nat < Addr .
  subsort Nat < Idx .

  --- Bool wrapper (avoid subsort Bool < WasmTerminal conflicts)
  op w-bool : Bool -> WasmTerminal [ctor] .

  --- Basic Wasm Types
  ops w-N w-M w-K w-n w-m w-X w-C w-I w-S w-T w-V w-b w-z w-L w-E : -> WasmType [ctor] .

  --- Special Operators
  --- Pair sort + well-typed witness for parametric type judgements.
  --- Non-parametric types use direct `mb T : S .` memberships.
  --- Parametric types emit `(mb|cmb) ( T hasType S ) : WellTyped [if ...] .`
  sort TypedTerm .
  sort WellTyped .
  subsort WellTyped < TypedTerm .
  op _hasType_ : WasmTerminal WasmType -> TypedTerm [ctor prec 95 gather (e e)] .
  --- Judgement sort for RelD relations.
  --- Baseline translator: most non-step RelD cases become `eq/ceq ... = valid`.
  --- Relations that need rewrite premises in their conditions (currently Steps)
  --- rewrite directly to `valid` instead of using a separate proof wrapper.
  sort Judgement .
  sort ValidJudgement .
  subsort ValidJudgement < Judgement .
  op valid : -> ValidJudgement [ctor] .
  op _shape-x_ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op slice : WasmTerminals WasmTerminal WasmTerminal -> WasmTerminals .
  op _<-_ : WasmTerminal WasmTerminals -> Bool .

  --- Generic record/terminal combinators (parser support)
  op merge : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op _=++_ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op any : -> WasmTerminal [ctor] .

  --- ExecConf: execution configuration for step-based semantics
  sort ExecConf .
  op <_|_> : WasmTerminal WasmTerminals -> ExecConf [ctor] .
  op step : ExecConf -> ExecConf [frozen (1)] .

  op focused-step : ExecConf -> ExecConf [frozen (1)] .

  --- Common variables (declared once)
  var EC : ExecConf .
  var I : Int .
  var W-I : Int .
  op EXP : -> Int .
  vars W-N W-M NLC NFC NHC : N .
  vars T W WW FQ : WasmTerminal .
  vars TS W* ISQ INSTRQ CQ : WasmTerminals .

  --- Auto-collected tokens
  ops ELSE dotdot lbrace rbrace rbrack : -> WasmTerminal [ctor] .


  --- Auto-declared helper calls
  op $f : WasmTerminal WasmTerminal -> WasmTerminal .
  op $f : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .
  op $f : WasmTerminal WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .


  --- Declarations
  op $ANYREF :  -> Reftype .
  op $ARRAYREF :  -> Reftype .
  op $E : WasmTerminal -> WasmTerminal .
  op $EQREF :  -> Reftype .
  op $EXNREF :  -> Reftype .
  op $EXTERNREF :  -> Reftype .
  op $FN : WasmTerminal -> WasmTerminal .
  op $FUNCREF :  -> Reftype .
