mod DSL-TERM is 
  sort SpectecTerminal .
  sort SpectecType .
endm

mod DSL-PRETYPE is
  inc DSL-TERM .
  inc NAT .
  inc INT .
  inc BOOL .
  sort SpectecTerminals .
  sort SpectecTypes .

  subsort Nat < SpectecTerminal .
  subsort SpectecTerminal < SpectecTerminals .
  subsort SpectecType < SpectecTypes . 
  op eps : -> SpectecTerminals .
  op _ _ : SpectecTerminals SpectecTerminals -> SpectecTerminals [ctor assoc id: eps] .

  op len : SpectecTerminals -> Nat .
  var W : SpectecTerminal .
  var WTS : SpectecTerminals .

  eq len(eps) = 0 .
  eq len(W WTS) = 1 + len(WTS) .

  var T : SpectecTerminal .
  var TS : SpectecTerminals .

  var N' : Nat .
  op index : SpectecTerminals Nat -> SpectecTerminals .
  eq index(eps, N') = eps .
  eq index(T TS, 0) = T .
  eq index(T TS, s(N')) = index(TS, N') .
endm

mod DSL-RECORD is 
  inc DSL-PRETYPE .
  inc QID .
  sort RecordItem .
  sort RecordItems .
  subsort RecordItem < RecordItems . 

  op EMPTY : -> RecordItem .
  op _;_ : RecordItems RecordItems -> RecordItems [ctor assoc id: EMPTY].
  op {_} : RecordItems -> SpectecTerminal .

  op item : Qid SpectecTerminals -> RecordItem .

  vars RI RI' : RecordItems . var R : RecordItem .
  vars F F' : Qid .
  var REC : SpectecTerminal .
  vars V V' : SpectecTerminals . 

  op value : Qid SpectecTerminal -> SpectecTerminal .
  op value : Qid RecordItems -> SpectecTerminals .
  eq value(F,{RI}) = value(F, RI) .
  eq value(F, EMPTY) = eps . 
  eq value(F, item(F, V) ; RI) = V .
  ceq value(F, R ; RI) = value(F, RI) if R =/= EMPTY .

  op _++_ : RecordItems RecordItems -> SpectecTerminal .
  eq RI ++ RI' = {RI ; RI'} .

  op _[._<-_] : SpectecTerminal Qid SpectecTerminals -> SpectecTerminal . 
  op _[._<-_] : RecordItems Qid SpectecTerminals -> SpectecTerminal .
  eq {item(F, V) ; RI} [. F <- V'] = {item(F, V') ; RI} .
  ceq {item(F, V) ; RI} [. F' <- V'] = item(F, V) ++ RI[. F' <- V'] if F =/= F' .

  op _[._=++_] : SpectecTerminal Qid SpectecTerminals -> SpectecTerminal .
  eq REC [. F =++ V'] = REC [. F <- (value(F, REC) V') ] .

  op _[_<-_] : SpectecTerminals SpectecTerminal SpectecTerminal -> SpectecTerminals [prec 50] .

  var H : SpectecTerminal .
  vars L : SpectecTerminals .
  vars IDX : Nat .
  vars VALUE NEWVALUE : SpectecTerminal .

  eq eps [ IDX <- NEWVALUE ] = eps .
  eq (H L) [ 0 <- NEWVALUE ] = NEWVALUE L .
  eq (H L) [ s(IDX) <- NEWVALUE ] = H (L [ IDX <- NEWVALUE ]) .
endm

mod SPECTEC-CORE is
  inc DSL-RECORD .
  inc BOOL .
  inc INT .

  --- Base Sorts
  subsort Int < SpectecTerminal .
  --- Nat < SpectecTerminal is provided by DSL-PRETYPE.

  --- Allow type atoms to appear as terminals (for mixed AST encodings)
  subsort SpectecType < SpectecTerminal .
  subsort SpectecTypes < SpectecTerminals .

  --- SpecTec terminal sequences use the single SpectecTerminals sequence sort.

  --- Source-derived Nat subsorts from SpecTec alias declarations.
  subsort Nat < Addr .
  subsort Nat < Arrayaddr .
  subsort Nat < Dataaddr .
  subsort Nat < Dataidx .
  subsort Nat < Elemaddr .
  subsort Nat < Elemidx .
  subsort Nat < Exnaddr .
  subsort Nat < Fieldidx .
  subsort Nat < Funcaddr .
  subsort Nat < Funcidx .
  subsort Nat < Globaladdr .
  subsort Nat < Globalidx .
  subsort Nat < Hostaddr .
  subsort Nat < Idx .
  subsort Nat < K .
  subsort Nat < Labelidx .
  subsort Nat < Laneidx .
  subsort Nat < Localidx .
  subsort Nat < M .
  subsort Nat < Memaddr .
  subsort Nat < Memidx .
  subsort Nat < N .
  subsort Nat < Structaddr .
  subsort Nat < Tableaddr .
  subsort Nat < Tableidx .
  subsort Nat < Tagaddr .
  subsort Nat < Tagidx .
  subsort Nat < Typeidx .
  subsort Nat < U16 .
  subsort Nat < U31 .
  subsort Nat < U32 .
  subsort Nat < U64 .
  subsort Nat < U8 .

  --- Syntax-category membership is represented by mb/cmb axioms, not by terminal subsorts.

  --- Bool wrapper emitted because source defs return Bool as a terminal.
  op w-bool : Bool -> SpectecTerminal [ctor] .

  --- Source type constructors are generated from SpecTec declarations.

  --- Pair sort + well-typed witness for parametric type judgements.
  --- Non-parametric types use direct `mb T : S .` memberships.
  --- Parametric types emit `(mb|cmb) ( T hasType S ) : WellTyped [if ...] .`
  sort TypedTerm .
  sort WellTyped .
  subsort WellTyped < TypedTerm .
  op _hasType_ : SpectecTerminal SpectecType -> TypedTerm [ctor prec 95 gather (e e)] .
  --- Judgement sort for RelD relations.
  --- Strict C1: source relation rules lower to primary `rl/crl => valid`.
  --- Definitional equations remain `eq/ceq` when they translate source defs.
  sort Judgement .
  sort ValidJudgement .
  subsort ValidJudgement < Judgement .
  op valid : -> ValidJudgement [ctor] .
  op index : SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $typed-index : SpectecType SpectecTerminals Nat -> SpectecTerminals .
  op $typed-index : SpectecType SpectecTerminals SpectecTerminals -> SpectecTerminals .
  op $repeat : SpectecTerminal Int -> SpectecTerminals .
  op $star-prefix : SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op $star-unprefix : SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op slice : SpectecTerminals SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op _<-_ : SpectecTerminal SpectecTerminals -> Bool .
  --- Source-derived executable decision mirrors for reference-cast `otherwise` rules.
  --- They are used only to make source `-- otherwise` priority decidable
  --- before recursive relation-premise search enters nonterminating failure paths.
  op $heaptype-sub? : SpectecTerminals SpectecTerminals SpectecTerminals -> Bool .
  op $reftype-sub? : SpectecTerminals SpectecTerminals SpectecTerminals -> Bool .

  --- Generic record merge combinator emitted because source record composition uses it.
  op merge : SpectecTerminal SpectecTerminal -> SpectecTerminal [ctor] .

  --- Record literals/updates come from DSL-RECORD and have sort SpectecTerminal.
  --- This keeps the baseline surface aligned with the SpecTec terminal model.

  --- Execution wrappers generated from source Step relation declarations.
  --- The wrapper result sorts prevent rewrite conditions from being
  --- satisfied by zero-step matching an unreduced relation call.
  sorts StepConf StepPureConf StepReadConf StepsConf .
  subsort Config < StepConf .
  subsort SpectecTerminals < StepPureConf .
  subsort SpectecTerminals < StepReadConf .
  subsort Config < StepsConf .
  op _;_ : Store Frame -> State [ctor prec 55] .
  op _;_ : State SpectecTerminals -> Config [ctor prec 60] .
  op step : Config -> StepConf [frozen (1)] .
  op step-pure : SpectecTerminals -> StepPureConf [frozen (1)] .
  op step-read : Config -> StepReadConf [frozen (1)] .
  op steps : Config -> StepsConf .

  --- Common variables (declared once)
  var EC : Config .
  op EXP : -> Int .
  var ZS : State .
  var T : SpectecTerminal .

  --- Generic SpecTec sequence indexing: xs[i*] maps scalar index over i*.
  --- This is representation substrate for source meta-expressions, not a
  --- judgement-specific executable shortcut.
  var INDEX-I : Nat .
  vars INDEX-TS INDEX-IS : SpectecTerminals .
  eq index(INDEX-TS, eps) = eps .
  eq index(INDEX-TS, INDEX-I INDEX-IS) = index(INDEX-TS, INDEX-I) index(INDEX-TS, INDEX-IS) .

  --- Type-aware SpecTec indexing for flat composite sequence elements.
  --- Source fields like localtype* contain source elements such as SET i32,
  --- which occupy multiple terminal tokens in the broad sequence carrier.
  var TYPED-INDEX-TY : SpectecType .
  var TYPED-INDEX-I : Nat .
  vars TYPED-INDEX-TS TYPED-INDEX-IS : SpectecTerminals .
  eq $typed-index(TYPED-INDEX-TY, TYPED-INDEX-TS, eps) = eps .
  ceq $typed-index(TYPED-INDEX-TY, TYPED-INDEX-TS, TYPED-INDEX-I TYPED-INDEX-IS) =
     $typed-index(TYPED-INDEX-TY, TYPED-INDEX-TS, TYPED-INDEX-I) $typed-index(TYPED-INDEX-TY, TYPED-INDEX-TS, TYPED-INDEX-IS)
   if TYPED-INDEX-IS =/= eps .

  --- Generic SpecTec membership test: x <- xs.
  vars MEMBER-X MEMBER-Y : SpectecTerminal .
  var MEMBER-YS : SpectecTerminals .
  eq MEMBER-X <- eps = false .
  eq MEMBER-X <- MEMBER-X MEMBER-YS = true .
  ceq MEMBER-X <- MEMBER-Y MEMBER-YS = MEMBER-X <- MEMBER-YS
   if MEMBER-X =/= MEMBER-Y .

  --- Generic SpecTec fixed repetition: e^n becomes $repeat(e,n).
  var REPEAT_N : Int .
  var REPEAT_ELEM : SpectecTerminal .
  eq $repeat(REPEAT_ELEM, 0) = eps .
  ceq $repeat(REPEAT_ELEM, REPEAT_N) = ( REPEAT_ELEM $repeat(REPEAT_ELEM, _-_ ( REPEAT_N, 1 )) )
   if _>_ ( REPEAT_N, 0 ) .

  --- Generic SpecTec sequence slicing: xs[i : n].
  vars SLICE_I SLICE_N : Int .
  var SLICE_ELEM : SpectecTerminal .
  var SLICE_REST : SpectecTerminals .
  eq slice(SLICE_REST, SLICE_I, 0) = eps .
  ceq slice(( SLICE_ELEM SLICE_REST ), 0, SLICE_N) = ( SLICE_ELEM slice(SLICE_REST, 0, _-_ ( SLICE_N, 1 )) )
   if _>_ ( SLICE_N, 0 ) .
  ceq slice(( SLICE_ELEM SLICE_REST ), SLICE_I, SLICE_N) = slice(SLICE_REST, _-_ ( SLICE_I, 1 ), SLICE_N)
   if _>_ ( SLICE_I, 0 ) .

  --- Generic SpecTec star-map lowering for flat prefix constructors.
  --- Source shapes such as (SET t)* become $star-prefix(SET, t*), and
  --- $star-unprefix recovers t* from a matching flat encoded sequence.
  vars STAR-PREFIX STAR-ELEM : SpectecTerminal .
  var STAR-REST : SpectecTerminals .
  eq $star-prefix(STAR-PREFIX, eps) = eps .
  eq $star-prefix(STAR-PREFIX, STAR-ELEM STAR-REST) = STAR-PREFIX STAR-ELEM $star-prefix(STAR-PREFIX, STAR-REST) .
  eq $star-unprefix(STAR-PREFIX, eps) = eps .
  eq $star-unprefix(STAR-PREFIX, STAR-PREFIX STAR-ELEM STAR-REST) = STAR-ELEM $star-unprefix(STAR-PREFIX, STAR-REST) .

  --- Auto-collected tokens
  ops ELSE dotdot lbrace rbrace rbrack : -> SpectecTerminal [ctor] .


  --- Auto-declared helper calls
  op $f : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $f : SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $f : SpectecTerminal SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .


  --- Declarations
  op $ANYREF :  -> SpectecTerminal .
  op $ARRAYREF :  -> SpectecTerminal .
  op $E : SpectecTerminal -> SpectecTerminal .
  op $EQREF :  -> SpectecTerminal .
  op $EXNREF :  -> SpectecTerminal .
  op $EXTERNREF :  -> SpectecTerminal .
  op $FN : SpectecTerminal -> SpectecTerminal .
  op $FUNCREF :  -> SpectecTerminal .
  op $I31REF :  -> SpectecTerminal .
  op $IN : SpectecTerminal -> SpectecTerminal .
  op $JN : SpectecTerminal -> SpectecTerminal .
  op $Ki :  -> SpectecTerminal .
  op $M : SpectecTerminal -> SpectecTerminal .
  op $ND :  -> Bool .
  op $NULLEXNREF :  -> SpectecTerminal .
  op $NULLEXTERNREF :  -> SpectecTerminal .
  op $NULLFUNCREF :  -> SpectecTerminal .
  op $NULLREF :  -> SpectecTerminal .
  op $R-fmadd :  -> SpectecTerminal .
  op $R-fmax :  -> SpectecTerminal .
  op $R-fmin :  -> SpectecTerminal .
  op $R-idot :  -> SpectecTerminal .
  op $R-iq15mulr :  -> SpectecTerminal .
  op $R-laneselect :  -> SpectecTerminal .
  op $R-swizzle :  -> SpectecTerminal .
  op $R-trunc-s :  -> SpectecTerminal .
  op $R-trunc-u :  -> SpectecTerminal .
  op $STRUCTREF :  -> SpectecTerminal .
  op $add-arrayinst : State SpectecTerminals -> State .
  op $add-exninst : State SpectecTerminals -> State .
  op $add-structinst : State SpectecTerminals -> State .
  op $allocdata : Store SpectecTerminal SpectecTerminals -> SpectecTerminal .
  op $allocdatas : Store SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $allocelem : Store SpectecTerminal SpectecTerminals -> SpectecTerminal .
  op $allocelems : Store SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $allocexport : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $allocexports : SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op $allocfunc : Store SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $allocfuncs : Store SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $allocglobal : Store SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $allocglobals : Store SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $allocmem : Store SpectecTerminal -> SpectecTerminal .
  op $allocmems : Store SpectecTerminals -> SpectecTerminal .
  op $allocmodule : Store SpectecTerminal SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $alloctable : Store SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $alloctables : Store SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $alloctag : Store SpectecTerminal -> SpectecTerminal .
  op $alloctags : Store SpectecTerminals -> SpectecTerminal .
  op $alloctypes : SpectecTerminals -> SpectecTerminals .
  op $arrayinst : State -> SpectecTerminals .
  op $as-deftype : SpectecTerminal -> SpectecTerminal .
  op $before : SpectecTerminal SpectecTerminal SpectecTerminal -> Bool .
  op $binop : SpectecTerminal SpectecTerminal SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $blocktype : State SpectecTerminal -> SpectecTerminal .
  op $bool : SpectecTerminal -> SpectecTerminal .
  op $canon : SpectecTerminal -> SpectecTerminal .
  op $cbytes : SpectecTerminal SpectecTerminal -> SpectecTerminals .
  op $ceilz : SpectecTerminal -> SpectecTerminal .
  op $clos-deftype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-deftypes : SpectecTerminals -> SpectecTerminals .
  op $clos-externtype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-moduletype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-tagtype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $clos-valtype : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $concat : SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op $concatn : SpectecTerminal SpectecTerminals SpectecTerminal -> SpectecTerminals .
  op $concatopt : SpectecTerminal SpectecTerminals -> SpectecTerminals .
  op $const : SpectecTerminal SpectecTerminal -> SpectecTerminal .
  op $cont-allocdatas-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocelems-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocfuncs-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocglobals-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmems-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c1 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c2 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c3 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c4 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c5 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c6 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-allocmodule-r0-c7 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-alloctables-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
