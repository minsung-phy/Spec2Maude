  eq $cfg-instrs(ZS ; ITS) = ITS .

  eq  is-val(CTORCONSTA2(T, W)) = true .
  eq  is-val(CTORVCONSTA2(T, W)) = true .
  eq  is-val(CTORREFNULLA1(W)) = true .
  eq  is-val(CTORREFI31NUMA1(W)) = true .
  eq  is-val(CTORREFSTRUCTADDRA1(W)) = true .
  eq  is-val(CTORREFARRAYADDRA1(W)) = true .
  eq  is-val(CTORREFFUNCADDRA1(W)) = true .
  eq  is-val(CTORREFEXNADDRA1(W)) = true .
  eq  is-val(CTORREFHOSTADDRA1(W)) = true .
  eq  is-val(CTORREFEXTERNA1(W)) = true .
  ceq is-val(W) = true if W : Val .
  eq  is-val(W) = false [owise] .

  ceq all-vals(W TS) = all-vals(TS) if is-val(W) .
  eq  all-vals(eps) = true .
  eq  all-vals(TS) = false [owise] .

  --- Label-context control-flow detector: true when the inner instr list
  --- begins with VAL* followed by a BR / RETURN / RETURN-CALL-REF / THROW-REF,
  --- i.e. a pattern that the top-level step-pure-* label rules already
  --- consume directly. In those cases heat must NOT fire, otherwise the
  --- control-flow instruction escapes its enclosing label wrapper.
  eq  needs-label-ctxt(eps) = false .
  ceq needs-label-ctxt(W TS) = needs-label-ctxt(TS) if is-val(W) .
  eq  needs-label-ctxt(CTORBRA1(T) TS) = true .
  eq  needs-label-ctxt(CTORRETURNA0 TS) = true .
  eq  needs-label-ctxt(CTORRETURNCALLREFA1(T) TS) = true .
  eq  needs-label-ctxt(CTORTHROWREFA0 TS) = true .
  eq  needs-label-ctxt(TS) = false [owise] .

  eq  is-trap(eps) = false .
  ceq is-trap(W TS) = is-trap(TS) if is-val(W) .
  eq  is-trap(CTORTRAPA0 TS) = true .
  eq  is-trap(TS) = false [owise] .

  --- Executable lifting for SpecTec substitution helpers over lists.
  --- Generated helper signatures are element-level (`typeuse`, `valtype`),
  --- but rules such as unroll/expand call them on `typeuse*` and `valtype*`.
  eq $subst-typeuse(eps, SUBST-L-TV, SUBST-L-TU) = eps .
  ceq $subst-typeuse(SUBST-L-W SUBST-L-WS, SUBST-L-TV, SUBST-L-TU) =
      $subst-typeuse(SUBST-L-W, SUBST-L-TV, SUBST-L-TU)
      $subst-typeuse(SUBST-L-WS, SUBST-L-TV, SUBST-L-TU)
   if SUBST-L-WS =/= eps .
  eq $subst-valtype(eps, SUBST-L-TV, SUBST-L-TU) = eps .
  ceq $subst-valtype(SUBST-L-W SUBST-L-WS, SUBST-L-TV, SUBST-L-TU) =
      $subst-valtype(SUBST-L-W, SUBST-L-TV, SUBST-L-TU)
      $subst-valtype(SUBST-L-WS, SUBST-L-TV, SUBST-L-TU)
   if SUBST-L-WS =/= eps .
  eq $subst-subtype(eps, SUBST-L-TV, SUBST-L-TU) = eps .
  ceq $subst-subtype(SUBST-L-W SUBST-L-WS, SUBST-L-TV, SUBST-L-TU) =
      $subst-subtype(SUBST-L-W, SUBST-L-TV, SUBST-L-TU)
      $subst-subtype(SUBST-L-WS, SUBST-L-TV, SUBST-L-TU)
   if SUBST-L-WS =/= eps .

  --- Executable lowering for SpecTec (i<n) type iterations.
  --- These helpers generate the finite sequences used by roll/unroll rules;
  --- without them the iterator variable becomes a free WasmTerminal.
  eq $rec-typevars(0) = eps .
  ceq $rec-typevars(TYPE-ITER-N) =
      $rec-typevars(TYPE-ITER-N - 1) CTORRECA1(TYPE-ITER-N - 1)
   if (TYPE-ITER-N > 0) .
  eq $def-typeuses(TYPE-ITER-RT, 0) = eps .
  ceq $def-typeuses(TYPE-ITER-RT, TYPE-ITER-N) =
      $def-typeuses(TYPE-ITER-RT, TYPE-ITER-N - 1)
      CTORWDEFA2(TYPE-ITER-RT, TYPE-ITER-N - 1)
   if (TYPE-ITER-N > 0) .
  eq $idx-typeuses(TYPE-ITER-X, 0) = eps .
  ceq $idx-typeuses(TYPE-ITER-X, TYPE-ITER-N) =
      $idx-typeuses(TYPE-ITER-X, TYPE-ITER-N - 1)
      CTORWIDXA1(TYPE-ITER-X + (TYPE-ITER-N - 1))
   if (TYPE-ITER-N > 0) .
  ceq $expanddt(EXP-FL-DT) = EXP-FL-CT
   if CTORSUBA3(eps, EXP-FL-TU, EXP-FL-CT) := $unrolldt(EXP-FL-DT) .
  --- Generic SpecTec list type witness.
  --- The source rule is polymorphic in the element type; this executable
  --- variable form makes `eps hasType list(val)` and similar instances work.
  cmb (LIST-TS hasType (list(LIST-TY))) : WellTyped
   if (len(LIST-TS) < (2 ^ 32)) .

  --- Executable frame record representation.
  --- SpecTec writes frames as {LOCALS ..., MODULE ...}. Direct Maude
  --- record-shape membership for that pattern can make sort inference
  --- diverge, so frame records are emitted as this typed constructor while
  --- preserving field projection and update behavior.
  eq value('LOCALS, $mk-frame(MK-FRAME-LOCALS, MK-FRAME-MODULE)) = MK-FRAME-LOCALS .
  eq value('MODULE, $mk-frame(MK-FRAME-LOCALS, MK-FRAME-MODULE)) = MK-FRAME-MODULE .
  eq $mk-frame(MK-FRAME-LOCALS, MK-FRAME-MODULE) [. 'LOCALS <- MK-FRAME-LOCALS2] = $mk-frame(MK-FRAME-LOCALS2, MK-FRAME-MODULE) .
  eq $mk-frame(MK-FRAME-LOCALS, MK-FRAME-MODULE) [. 'MODULE <- MK-FRAME-MODULE2] = $mk-frame(MK-FRAME-LOCALS, MK-FRAME-MODULE2) .

  --- Concrete record-state execution helpers.
  --- Generated SpecTec helper equations are typed as Store ; Frame.
  --- Record literals/updates have sort WasmTerminal, so add equivalent
  --- equations over WasmTerminal while preserving visible _;_ state syntax.
  eq $local((WT-S ; WT-F), WT-X) = index(value('LOCALS, WT-F), WT-X) .
  eq $with-local((WT-S ; WT-F), WT-X, WT-V) =
     (WT-S ; (WT-F [. 'LOCALS <- (value('LOCALS, WT-F) [WT-X <- WT-V])])) .

endm

