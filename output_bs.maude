  op $allocelem : Store WasmTerminal WasmTerminals -> WasmTerminal .
  op $allocelems : Store WasmTerminals WasmTerminals -> WasmTerminal .
  op $allocexport : WasmTerminal WasmTerminal -> WasmTerminal .
