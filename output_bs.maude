  eq  all-vals(TS) = false [owise] .

  --- Label-context control-flow detector: true when the inner instr list
  --- begins with VAL* followed by a BR / RETURN / RETURN-CALL-REF / THROW-REF,
  --- i.e. a pattern that the top-level step-pure-* label rules already
  --- consume directly. In those cases heat must NOT fire, otherwise the
  --- control-flow instruction escapes its enclosing label wrapper.
  eq  needs-label-ctxt(eps) = false .
  ceq needs-label-ctxt(W TS) = needs-label-ctxt(TS) if is-val(W) = true .
  eq  needs-label-ctxt(CTORBRA1(T) TS) = true .
  eq  needs-label-ctxt(CTORRETURNA0 TS) = true .
  eq  needs-label-ctxt(CTORRETURNCALLREFA1(T) TS) = true .
  eq  needs-label-ctxt(CTORTHROWREFA0 TS) = true .
  eq  needs-label-ctxt(TS) = false [owise] .

  eq  is-trap(eps) = false .
  ceq is-trap(W TS) = is-trap(TS) if is-val(W) = true .
  eq  is-trap(CTORTRAPA0 TS) = true .
  eq  is-trap(TS) = false [owise] .

endm

