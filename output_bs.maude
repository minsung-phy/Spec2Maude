  eq $is-spectec-start ( CTORSTARTA1 ( IS-START-FUNCIDX1 ) ) = true .
  eq $is-spectec-storagetype ( CTORBOTA0 ) = true .
  eq $is-spectec-storagetype ( CTORF32A0 ) = true .
  eq $is-spectec-storagetype ( CTORF64A0 ) = true .
  eq $is-spectec-storagetype ( CTORI16A0 ) = true .
  eq $is-spectec-storagetype ( CTORI32A0 ) = true .
  eq $is-spectec-storagetype ( CTORI64A0 ) = true .
  eq $is-spectec-storagetype ( CTORI8A0 ) = true .
  eq $is-spectec-storagetype ( CTORV128A0 ) = true .
  eq $is-spectec-subtype ( CTORSUBA3 ( IS-SUBTYPE-FINAL1, IS-SUBTYPE-TYPEUSE-LIST-TYPEUSE, IS-SUBTYPE-COMPTYPE1 ) ) = true .
  eq $is-spectec-subtype ( CTORSUBA3 ( eps, IS-SUBTYPE-TYPEUSE-LIST-TYPEUSE, IS-SUBTYPE-COMPTYPE1 ) ) = true .
  eq $is-spectec-type ( CTORTYPEA1 ( IS-TYPE-RECTYPE1 ) ) = true .
  eq $is-spectec-typeuse ( CTORRECA1 ( IS-TYPEUSE-N1 ) ) = true .
  eq $is-spectec-typeuse ( CTORWDEFA2 ( IS-TYPEUSE-RECTYPE1, IS-TYPEUSE-N1 ) ) = true .
  eq $is-spectec-typeuse ( CTORWIDXA1 ( IS-TYPEUSE-TYPEIDX1 ) ) = true .
  eq $is-spectec-valtype ( CTORBOTA0 ) = true .
  eq $is-spectec-valtype ( CTORF32A0 ) = true .
  eq $is-spectec-valtype ( CTORF64A0 ) = true .
  eq $is-spectec-valtype ( CTORI32A0 ) = true .
  eq $is-spectec-valtype ( CTORI64A0 ) = true .
  eq $is-spectec-valtype ( CTORV128A0 ) = true .
  eq $is-spectec-vec ( CTORVCONSTA2 ( IS-VEC-VECTYPE1, IS-VEC-VEC1 ) ) = true .
  eq $is-spectec-vectype ( CTORV128A0 ) = true .
  --- Source-derived sequence-category predicate for SpecTec val* premises.
  eq  $is-spectec-val-seq(eps) = true .
  ceq $is-spectec-val-seq(W TS) = $is-spectec-val-seq(TS)
   if W : Val .
  eq  $is-spectec-val-seq(TS) = false [owise] .

  --- Executable lifting for SpecTec substitution helpers over lists.
  --- Generated helper signatures are element-level (`typeuse`, `valtype`),
  --- but rules such as unroll/expand call them on `typeuse*` and `valtype*`.
  eq $subst-typeuse(eps, SUBST-L-TV, SUBST-L-TU) = eps .
  ceq $subst-typeuse(SUBST-L-W SUBST-L-WS, SUBST-L-TV, SUBST-L-TU) =
      $subst-typeuse(SUBST-L-W, SUBST-L-TV, SUBST-L-TU)
      $subst-typeuse(SUBST-L-WS, SUBST-L-TV, SUBST-L-TU)
   if SUBST-L-WS =/= eps .
  eq $subst-valtype(eps, SUBST-L-TV, SUBST-L-TU) = eps .
  ceq $subst-valtype(SUBST-L-W SUBST-L-WS, SUBST-L-TV, SUBST-L-TU) =
      $subst-valtype(SUBST-L-W, SUBST-L-TV, SUBST-L-TU)
      $subst-valtype(SUBST-L-WS, SUBST-L-TV, SUBST-L-TU)
   if SUBST-L-WS =/= eps .
  eq $subst-subtype(eps, SUBST-L-TV, SUBST-L-TU) = eps .
  ceq $subst-subtype(SUBST-L-W SUBST-L-WS, SUBST-L-TV, SUBST-L-TU) =
      $subst-subtype(SUBST-L-W, SUBST-L-TV, SUBST-L-TU)
      $subst-subtype(SUBST-L-WS, SUBST-L-TV, SUBST-L-TU)
   if SUBST-L-WS =/= eps .
  --- Generic SpecTec list type witness.
  --- The source rule is polymorphic in the element type; this executable
  --- variable form makes `eps hasType list(val)` and similar instances work.
  cmb (LIST-TS hasType (list(LIST-TY))) : WellTyped
   if (len(LIST-TS) < (2 ^ 32)) .

  --- Source frame record representation.
  --- SpecTec writes frames as {LOCALS ..., MODULE ...}; this generated
  --- constructor represents that source syntax alternative at sort Frame
  --- while preserving field projection and update behavior.
  eq value('LOCALS, CTORFRAMEA2(FRAME-LOCALS, FRAME-MODULE)) = FRAME-LOCALS .
  eq value('MODULE, CTORFRAMEA2(FRAME-LOCALS, FRAME-MODULE)) = FRAME-MODULE .
  eq CTORFRAMEA2(FRAME-LOCALS, FRAME-MODULE) [. 'LOCALS <- FRAME-LOCALS2] = CTORFRAMEA2(FRAME-LOCALS2, FRAME-MODULE) .
  eq CTORFRAMEA2(FRAME-LOCALS, FRAME-MODULE) [. 'MODULE <- FRAME-MODULE2] = CTORFRAMEA2(FRAME-LOCALS, FRAME-MODULE2) .

endm

