  op $cont-evalexprs-r1-c0 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
  op $cont-evalexprs-r1-c1 : SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals SpectecTerminals -> SpectecTerminal .
