  eq $is-spectec-typeuse ( CTORRECA1 ( IS-TYPEUSE-N1 ) ) = true .
  eq $is-spectec-typeuse ( CTORWDEFA2 ( IS-TYPEUSE-RECTYPE1, IS-TYPEUSE-N1 ) ) = true .
  eq $is-spectec-typeuse ( CTORWIDXA1 ( IS-TYPEUSE-TYPEIDX1 ) ) = true .
  eq $is-spectec-valtype ( CTORBOTA0 ) = true .
  eq $is-spectec-valtype ( CTORF32A0 ) = true .
  eq $is-spectec-valtype ( CTORF64A0 ) = true .
  eq $is-spectec-valtype ( CTORI32A0 ) = true .
  eq $is-spectec-valtype ( CTORI64A0 ) = true .
  eq $is-spectec-valtype ( CTORV128A0 ) = true .
  eq $is-spectec-vectype ( CTORV128A0 ) = true .
  --- Source-derived executable decision mirrors for Heaptype_sub/Reftype_sub.
  --- Equations below are generated from the source relation rules, not
  --- from hand-written Wasm constructor cases.  The primary `...-sub => valid`
  --- rules remain in the core; these Boolean mirrors only make `-- otherwise`
  --- executable before recursive relation-premise failure paths diverge.
  var SUBQ-C : SpectecTerminals .
  vars SUBQ-H1 SUBQ-H2 : Heaptype .
  vars SUBQ-RT1 SUBQ-RT2 : Reftype .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-ARRAY7-C , HEAPTYPE-SUB-ARRAY7-DEFTYPE , CTORARRAYA0 ) = true
      if CTORARRAYA1 ( HEAPTYPE-SUB-ARRAY7-FIELDTYPE ) := $expanddt ( HEAPTYPE-SUB-ARRAY7-DEFTYPE ) /\ $is-spectec-fieldtype ( HEAPTYPE-SUB-ARRAY7-FIELDTYPE ) .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-FUNC8-C , HEAPTYPE-SUB-FUNC8-DEFTYPE , CTORFUNCA0 ) = true
      if CTORFUNCARROWA2 ( HEAPTYPE-SUB-FUNC8-TS1, HEAPTYPE-SUB-FUNC8-TS2 ) := $expanddt ( HEAPTYPE-SUB-FUNC8-DEFTYPE ) /\ ( HEAPTYPE-SUB-FUNC8-TS1 hasType ( list ( valtype ) ) ) : WellTyped /\ ( HEAPTYPE-SUB-FUNC8-TS2 hasType ( list ( valtype ) ) ) : WellTyped .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-NOEXN15-C , CTORNOEXNA0 , HEAPTYPE-SUB-NOEXN15-HEAPTYPE ) = true
      if $heaptype-sub? ( HEAPTYPE-SUB-NOEXN15-C, HEAPTYPE-SUB-NOEXN15-HEAPTYPE, CTOREXNA0 ) == true .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-NOEXTERN16-C , CTORNOEXTERNA0 , HEAPTYPE-SUB-NOEXTERN16-HEAPTYPE ) = true
      if $heaptype-sub? ( HEAPTYPE-SUB-NOEXTERN16-C, HEAPTYPE-SUB-NOEXTERN16-HEAPTYPE, CTOREXTERNA0 ) == true .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-NOFUNC14-C , CTORNOFUNCA0 , HEAPTYPE-SUB-NOFUNC14-HEAPTYPE ) = true
      if $heaptype-sub? ( HEAPTYPE-SUB-NOFUNC14-C, HEAPTYPE-SUB-NOFUNC14-HEAPTYPE, CTORFUNCA0 ) == true .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-NONE13-C , CTORNONEA0 , HEAPTYPE-SUB-NONE13-HEAPTYPE ) = true
      if $heaptype-sub? ( HEAPTYPE-SUB-NONE13-C, HEAPTYPE-SUB-NONE13-HEAPTYPE, CTORANYA0 ) == true .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-REC12-C , CTORRECA1 ( HEAPTYPE-SUB-REC12-LOWI ) , index ( HEAPTYPE-SUB-REC12-TYPEUSES, HEAPTYPE-SUB-REC12-LOWJ ) ) = true
      if CTORSUBA3 ( HEAPTYPE-SUB-REC12-FINALS, HEAPTYPE-SUB-REC12-TYPEUSES, HEAPTYPE-SUB-REC12-CT ) := index ( value('RECS, HEAPTYPE-SUB-REC12-C), HEAPTYPE-SUB-REC12-LOWI ) /\ ( HEAPTYPE-SUB-REC12-TYPEUSES hasType ( list ( typeuse ) ) ) : WellTyped .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-STRUCT6-C , HEAPTYPE-SUB-STRUCT6-DEFTYPE , CTORSTRUCTA0 ) = true
      if CTORSTRUCTA1 ( HEAPTYPE-SUB-STRUCT6-FIELDTYPES ) := $expanddt ( HEAPTYPE-SUB-STRUCT6-DEFTYPE ) /\ ( HEAPTYPE-SUB-STRUCT6-FIELDTYPES hasType ( list ( fieldtype ) ) ) : WellTyped .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-TYPEIDX-L10-C , CTORWIDXA1 ( HEAPTYPE-SUB-TYPEIDX-L10-TYPEIDX ) , HEAPTYPE-SUB-TYPEIDX-L10-HEAPTYPE ) = true
      if $heaptype-sub? ( HEAPTYPE-SUB-TYPEIDX-L10-C, ( index ( value('TYPES, HEAPTYPE-SUB-TYPEIDX-L10-C), HEAPTYPE-SUB-TYPEIDX-L10-TYPEIDX ) ), HEAPTYPE-SUB-TYPEIDX-L10-HEAPTYPE ) == true .
  ceq $heaptype-sub? ( HEAPTYPE-SUB-TYPEIDX-R11-C , HEAPTYPE-SUB-TYPEIDX-R11-HEAPTYPE , CTORWIDXA1 ( HEAPTYPE-SUB-TYPEIDX-R11-TYPEIDX ) ) = true
      if $heaptype-sub? ( HEAPTYPE-SUB-TYPEIDX-R11-C, HEAPTYPE-SUB-TYPEIDX-R11-HEAPTYPE, ( index ( value('TYPES, HEAPTYPE-SUB-TYPEIDX-R11-C), HEAPTYPE-SUB-TYPEIDX-R11-TYPEIDX ) ) ) == true .
  ceq $reftype-sub? ( REFTYPE-SUB-NONNULL0-C , CTORREFA2 ( eps, REFTYPE-SUB-NONNULL0-HT1 ) , CTORREFA2 ( eps, REFTYPE-SUB-NONNULL0-HT2 ) ) = true
      if $heaptype-sub? ( REFTYPE-SUB-NONNULL0-C, REFTYPE-SUB-NONNULL0-HT1, REFTYPE-SUB-NONNULL0-HT2 ) == true .
  ceq $reftype-sub? ( REFTYPE-SUB-NULL1-C , CTORREFA2 ( CTORNULLA0, REFTYPE-SUB-NULL1-HT1 ) , CTORREFA2 ( CTORNULLA0, REFTYPE-SUB-NULL1-HT2 ) ) = true
      if $heaptype-sub? ( REFTYPE-SUB-NULL1-C, REFTYPE-SUB-NULL1-HT1, REFTYPE-SUB-NULL1-HT2 ) == true .
  eq $heaptype-sub? ( HEAPTYPE-SUB-ARRAY-EQ5-C , CTORARRAYA0 , CTORWEQA0 ) = true .
  eq $heaptype-sub? ( HEAPTYPE-SUB-BOT17-C , CTORBOTA0 , HEAPTYPE-SUB-BOT17-HEAPTYPE ) = true .
  eq $heaptype-sub? ( HEAPTYPE-SUB-EQ-ANY2-C , CTORWEQA0 , CTORANYA0 ) = true .
  eq $heaptype-sub? ( HEAPTYPE-SUB-I31-EQ3-C , CTORI31A0 , CTORWEQA0 ) = true .
  eq $heaptype-sub? ( HEAPTYPE-SUB-REFL0-C , HEAPTYPE-SUB-REFL0-HEAPTYPE , HEAPTYPE-SUB-REFL0-HEAPTYPE ) = true .
  eq $heaptype-sub? ( HEAPTYPE-SUB-STRUCT-EQ4-C , CTORSTRUCTA0 , CTORWEQA0 ) = true .
  eq $heaptype-sub?(SUBQ-C, CTORARRAYA0, CTORANYA0) = true .
  eq $heaptype-sub?(SUBQ-C, CTORI31A0, CTORANYA0) = true .
  eq $heaptype-sub?(SUBQ-C, CTORSTRUCTA0, CTORANYA0) = true .
  eq $heaptype-sub?(SUBQ-C, SUBQ-H1, SUBQ-H2) = false [owise] .
  eq $reftype-sub?(SUBQ-C, SUBQ-RT1, SUBQ-RT2) = false [owise] .

  var W : SpectecTerminal .
  var TS : SpectecTerminals .
  --- Source-derived sequence-category predicate for SpecTec val* premises.
  eq  $is-spectec-val-seq(eps) = true .
  ceq $is-spectec-val-seq(W TS) = $is-spectec-val-seq(TS)
   if W : Val .
  eq  $is-spectec-val-seq(TS) = false [owise] .

  --- Generic SpecTec list type witness.
  --- The source rule is polymorphic in the element type; this executable
  --- variable form makes `eps hasType list(val)` and similar instances work.
  var LIST-TY : SpectecTerminal .
  var LIST-TS : SpectecTerminals .
  cmb (LIST-TS hasType (list(LIST-TY))) : WellTyped
   if (len(LIST-TS) < (2 ^ 32)) .


endm

