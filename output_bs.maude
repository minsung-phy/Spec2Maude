load dsl/pretype 

mod SPECTEC-CORE is
  inc DSL-RECORD .
  inc BOOL .
  inc INT .

  --- Base Sorts
  subsort Int < WasmTerminal .
  subsort Nat < WasmTerminal .

  --- Allow type atoms to appear as terminals (for mixed AST encodings)
  subsort WasmType < WasmTerminal .
  subsort WasmTypes < WasmTerminals .

  --- SpecTec terminal sequences use the single WasmTerminals sequence sort.

  --- Nat is a subtype of index-like and numeric-parameter sorts
  --- (spectec idx = u32 = nat; N/M/K are nat-valued type parameters)
  subsort Nat < N .
  subsort Nat < M .
  subsort Nat < K .
  subsort Nat < Labelidx .
  subsort Nat < Localidx .
  subsort Nat < Typeidx .
  subsort Nat < Funcidx .
  subsort Nat < Globalidx .
  subsort Nat < Tableidx .
  subsort Nat < Memidx .
  subsort Nat < Tagidx .
  subsort Nat < Elemidx .
  subsort Nat < Dataidx .
  subsort Nat < Fieldidx .
  subsort Nat < Addr .
  subsort Nat < Idx .

  --- Syntax-category membership is represented by mb/cmb axioms, not by terminal subsorts.

  --- Bool wrapper (avoid subsort Bool < WasmTerminal conflicts)
  op w-bool : Bool -> WasmTerminal [ctor] .

  --- Basic Wasm Types
  ops w-N w-M w-K w-n w-m w-X w-C w-I w-S w-T w-V w-b w-z w-L w-E : -> WasmType [ctor] .

  --- Special Operators
  --- Pair sort + well-typed witness for parametric type judgements.
  --- Non-parametric types use direct `mb T : S .` memberships.
  --- Parametric types emit `(mb|cmb) ( T hasType S ) : WellTyped [if ...] .`
  sort TypedTerm .
  sort WellTyped .
  subsort WellTyped < TypedTerm .
  op _hasType_ : WasmTerminal WasmType -> TypedTerm [ctor prec 95 gather (e e)] .
  --- Judgement sort for RelD relations.
  --- Baseline translator: most non-step RelD cases become `eq/ceq ... = valid`.
  --- Relations that need rewrite premises in their conditions (currently Steps)
  --- rewrite directly to `valid` instead of using a separate proof wrapper.
  sort Judgement .
  sort ValidJudgement .
  subsort ValidJudgement < Judgement .
  op valid : -> ValidJudgement [ctor] .
  op _shape-x_ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op slice : WasmTerminals WasmTerminal WasmTerminal -> WasmTerminals .
  op _<-_ : WasmTerminal WasmTerminals -> Bool .

  --- Generic record/terminal combinators (parser support)
  op merge : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op _=++_ : WasmTerminal WasmTerminal -> WasmTerminal [ctor] .
  op any : -> WasmTerminal [ctor] .

  --- Record literals/updates come from DSL-RECORD and have sort WasmTerminal.
  --- This keeps the baseline surface aligned with the SpecTec terminal model.

  --- Config: execution configuration for relation-preserving semantics
  --- The relation operators return wrapper sorts so rewrite conditions
  --- cannot satisfy themselves by zero-step matching an unreduced call.
  sorts StepConf StepPureConf StepReadConf StepsConf .
  subsort Config < StepConf .
  subsort Config < StepsConf .
  subsort WasmTerminals < StepPureConf .
  subsort WasmTerminals < StepReadConf .
  op _;_ : Store Frame -> State [ctor prec 55] .
  op _;_ : State WasmTerminals -> Config [ctor prec 60] .
  op step : Config -> StepConf [frozen (1)] .
  op step-pure : WasmTerminals -> StepPureConf [frozen (1)] .
  op step-read : Config -> StepReadConf [frozen (1)] .
  op steps : Config -> StepsConf [frozen (1)] .

  op $cfg-state : Config -> State .
  op $cfg-instrs : Config -> WasmTerminals .

  --- Common variables (declared once)
  var EC : Config .
  var I : Int .
  var W-I : Int .
  op EXP : -> Int .
  vars W-N W-M NLC NFC NHC : N .
  var ZS : State .
  var ITS : WasmTerminals .
  var LIST-TY : WasmTerminal .
  var LIST-TS : WasmTerminals .
  vars MOD-TYPES MOD-TAGS MOD-GLOBALS MOD-MEMS MOD-TABLES MOD-FUNCS MOD-DATAS MOD-ELEMS MOD-EXPORTS : WasmTerminals .
  vars STORE-TAGS STORE-GLOBALS STORE-MEMS STORE-TABLES STORE-FUNCS STORE-DATAS STORE-ELEMS STORE-STRUCTS STORE-ARRAYS STORE-EXNS : WasmTerminals .
  vars FRAME-LOCALS FRAME-MODULE : WasmTerminals .
  vars MK-FRAME-LOCALS MK-FRAME-LOCALS2 MK-FRAME-MODULE MK-FRAME-MODULE2 : WasmTerminals .
  vars WT-S WT-F : WasmTerminal .
  var WT-X : Localidx .
  var WT-V : Val .
  vars VALOK-WT-S VALOK-C : WasmTerminal .
  var VALOK-NT : WasmTerminal .
  var EXP-FL-DT : Deftype .
  var EXP-FL-CT : Comptype .
  var EXP-FL-TU : WasmTerminals .
  var EXPAND-X-DT : Deftype .
  vars EXPAND-X-T1 EXPAND-X-T2 : WasmTerminals .
  var INVOKE-X-S : WasmTerminal .
  var INVOKE-S-S : Store .
  var INVOKE-X-FUNCADDR : Funcaddr .
  var INVOKE-X-VAL : WasmTerminals .
  var INVOKE-X-DT : Deftype .
  vars INVOKE-X-T1 INVOKE-X-T2 : WasmTerminals .
  var SUBST-L-W : WasmTerminal .
  vars SUBST-L-WS SUBST-L-TV SUBST-L-TU : WasmTerminals .
  var TYPE-ITER-X : Typeidx .
  var TYPE-ITER-RT : Rectype .
  var TYPE-ITER-N : Nat .
  vars T W WW FQ : WasmTerminal .
  vars TS W* ISQ INSTRSQ CQ : WasmTerminals .

  --- Auto-collected tokens
  ops ELSE dotdot lbrace rbrace rbrack : -> WasmTerminal [ctor] .


  --- Auto-declared helper calls
  op $f : WasmTerminal WasmTerminal -> WasmTerminal .
  op $f : WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .
  op $f : WasmTerminal WasmTerminal WasmTerminal WasmTerminal -> WasmTerminal .


  --- Declarations
  op $ANYREF :  -> WasmTerminal .
  op $ARRAYREF :  -> WasmTerminal .
  op $E : WasmTerminal -> WasmTerminal .
  op $EQREF :  -> WasmTerminal .
