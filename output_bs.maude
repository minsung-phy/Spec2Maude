   if T : Nat .




  ceq $min ( MIN0-I, MIN0-J ) = MIN0-I
      if _<=_ ( MIN0-I, MIN0-J ) .
  eq $min ( MIN1-I, MIN1-J ) = MIN1-J [owise] .




  eq $sum ( eps ) = 0 .
  eq $sum ( ( SUM1-N SUM1-NSQ ) ) = _+_ ( SUM1-N, $sum ( SUM1-NSQ ) ) .





  eq $prod ( eps ) = 1 .
  eq $prod ( ( PROD1-N PROD1-NSQ ) ) = _*_ ( PROD1-N, $prod ( PROD1-NSQ ) ) .





  eq $opt ( X, eps ) = eps .
  eq $opt ( X, OPT1-W ) = OPT1-W .





  eq $concat ( X, eps ) = eps .
  eq $concat ( X, ( CONCAT1-WS CONCAT1-WQS ) ) = CONCAT1-WS $concat ( X, CONCAT1-WQS ) .





  eq $concatn ( X, eps, CONCATN0-N ) = eps .
  ceq $concatn ( X, ( CONCATN1-WS WSQ ), CONCATN1-N ) = CONCATN1-WS $concatn ( X, WSQ, CONCATN1-N )
      if ( ( len ( CONCATN1-WS ) == CONCATN1-N ) ) .





  eq $concatopt ( X, eps ) = eps .
  eq $concatopt ( X, ( CONCATOPT1-W CONCATOPT1-WQS ) ) = CONCATOPT1-W $concat ( X, CONCATOPT1-WQS ) .

















  eq $disjoint ( X, eps ) = true .
  eq $disjoint ( X, ( DISJOINT1-W DISJOINT1-WSQ ) ) = _and_ ( not ( ( DISJOINT1-W <- DISJOINT1-WSQ ) ), $disjoint ( X, DISJOINT1-WSQ ) ) .





  eq $setminus1 ( X, SETMINUS10-W, eps ) = SETMINUS10-W .
